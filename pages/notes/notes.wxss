/* pages/notes/notes.wxss —— 优化版 */

.page-container {
  min-height: 100vh;
  padding: 0 32rpx;
  background: #FAFAFA;
}

/* ===== 日期头部 ===== */
.date-header {
  padding: 32rpx 0 24rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.date-main {
  font-size: 39rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: 0;
}

.date-sub {
  font-size: 28rpx;
  color: #5F6368;
  font-weight: 500;
}

/* ===== 编辑区域 — 更精致的卡片 ===== */
.editor-section {
  padding: 0 !important;
  overflow: hidden;
  border-radius: 20rpx !important;
  background: #FFFFFF;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.note-editor {
  width: 100%;
  min-height: 320rpx;
  max-height: 60vh;
  padding: 32rpx;
  font-size: 33rpx;
  color: #1D1D1F;
  line-height: 1.7;
  background: #FFFFFF;
  border: none;
  font-weight: 500;
  letter-spacing: 0;
}

.editor-footer {
  display: flex;
  justify-content: flex-end;
  padding: 0 32rpx 20rpx;
  border-top: 1rpx solid rgba(0,0,0,0.04);
  padding-top: 16rpx;
}

.char-count {
  font-size: 25rpx;
  color: #6B7280;
}

/* ===== 提示文字 ===== */
.tips-section {
  margin-top: 20rpx;
  text-align: center;
}

.tips-text {
  font-size: 27rpx;
  color: #5F6368;
  line-height: 1.6;
  letter-spacing: 0;
}

.reminder-section {
  margin-top: 24rpx;
  padding: 24rpx !important;
  border-radius: 18rpx !important;
  background: #FFFFFF;
}

.reminder-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.reminder-title {
  display: block;
  font-size: 30rpx;
  color: #1D1D1F;
  font-weight: 700;
}

.reminder-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 25rpx;
  color: #6B7280;
}

.reminder-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.reminder-picker {
  height: 68rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  background: rgba(142, 142, 147, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  box-sizing: border-box;
}

.reminder-picker text:first-child {
  font-size: 26rpx;
  color: #1D1D1F;
  font-weight: 600;
  white-space: nowrap;
}

.picker-arrow {
  font-size: 34rpx;
  color: #9CA3AF;
  line-height: 1;
}

/* ===== 保存区域 ===== */
.save-section {
  margin-top: 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 20rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FFB300, #FF8F00) !important;
  color: #5D3500;
  font-size: 35rpx;
  font-weight: 700;
  border-radius: 18rpx;
  border: none;
  letter-spacing: 0;
  transition: opacity 0.15s;
  box-shadow: 0 6rpx 18rpx rgba(255,143,0,.25);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.save-btn.disabled {
  background: #D1D5DB !important;
  color: #FFFFFF !important;
  opacity: 1;
  box-shadow: none;
}

.save-btn::after {
  border: none;
}

.clear-btn {
  font-size: 28rpx;
  color: #D32F2F;
  background: transparent;
  padding: 14rpx 36rpx;
  border: none;
  font-weight: 600;
  letter-spacing: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.clear-btn::after {
  border: none;
}

.bottom-spacer {
  height: 60rpx;
}
