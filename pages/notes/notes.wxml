<!--pages/notes/notes.wxml-->
<view class="page-container {{elderMode ? 'elder-mode' : ''}}">
  <!-- 日期头部 -->
  <view class="date-header">
    <text class="date-main">{{displayDate}}</text>
    <text class="date-sub">{{weekdayText}}</text>
  </view>

  <!-- 编辑区域 -->
  <view class="editor-section card">
    <textarea
      class="note-editor"
      placeholder="{{placeholder}}"
      value="{{noteContent}}"
      bindinput="onNoteInput"
      auto-height
      maxlength="200"
      focus="{{autoFocus}}"
    ></textarea>
    <view class="editor-footer">
      <text class="char-count">{{noteContent.length}}/200</text>
    </view>
  </view>

  <!-- 提示文字 -->
  <view class="tips-section">
    <text class="tips-text">给这一天留下一句话，记录此刻的心情或回忆</text>
  </view>

  <view class="reminder-section card">
    <view class="reminder-switch-row">
      <view>
        <text class="reminder-title">微信提醒</text>
        <text class="reminder-desc">{{reminderLabel}}</text>
      </view>
      <switch checked="{{remind}}" color="#007AFF" bindchange="onRemindSwitch" />
    </view>
    <view class="reminder-grid" wx:if="{{remind}}">
      <picker mode="selector" range="{{reminderAdvanceOptions}}" bindchange="onReminderAdvanceChange">
        <view class="reminder-picker">
          <text>{{reminderAdvanceLabel}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
      <picker mode="time" value="{{reminder.time}}" bindchange="onReminderTimeChange">
        <view class="reminder-picker">
          <text>{{reminder.time}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
      <picker mode="selector" range="{{reminderRepeatOptions}}" bindchange="onReminderRepeatChange">
        <view class="reminder-picker">
          <text>{{reminderRepeatLabel}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <button
      class="save-btn {{canSave ? '' : 'disabled'}}"
      disabled="{{!canSave}}"
      bindtap="onSave"
    >
      {{hasExistingNote ? '更新备注' : '保存备注'}}
    </button>

    <button
      class="clear-btn"
      wx:if="{{hasExistingNote && noteContent}}"
      bindtap="onClear"
    >
      清除备注
    </button>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-spacer safe-area-bottom"></view>
</view>
