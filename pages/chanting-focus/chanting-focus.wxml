<!--pages/chanting-focus/chanting-focus.wxml — 专注模式（沉浸式大按钮）-->
<view class="page">
  <view class="focus-back" bindtap="goBack">← 返回</view>

  <text class="focus-name">{{task.name}}</text>
  <text class="focus-count number-display">{{count}}</text>
  <text class="focus-unit">{{task.unit}}</text>

  <view class="focus-btn" bindtap="onTap">
    <text>+</text>
  </view>

  <text class="focus-target" wx:if="{{task.dailyTarget > 0}}">目标：{{task.dailyTarget}}{{task.unit}}/天</text>
</view>
