<!--pages/chanting-focus/chanting-focus.wxml — 专注模式（沉浸式大按钮）-->
<view class="page {{elderMode ? 'elder-mode' : ''}}">
  <view class="focus-back" bindtap="goBack">
    <text class="back-arrow">‹</text>
    <text>返回</text>
  </view>

  <view class="focus-main">
    <text class="focus-name">{{task.name}}</text>
    <view class="count-wrap">
      <text class="focus-count number-display">{{count}}</text>
      <text class="focus-unit">{{task.unit}}</text>
    </view>

    <view class="focus-btn" bindtap="onTap" hover-class="focus-btn-active">
      <text class="plus">+</text>
    </view>

    <view class="focus-target" wx:if="{{task.dailyTarget > 0}}">
      <text>目标</text>
      <text class="target-value">{{task.dailyTarget}}{{task.unit}}/天</text>
    </view>
    <view class="focus-target focus-target-empty" wx:else>
      <text>今日专注计数</text>
    </view>
  </view>
</view>
