/* 专注模式 — 极简沉浸 */
.page { min-height:100vh; background:linear-gradient(180deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%); display:flex; flex-direction:column; align-items:center; justify-content:center; color:#fff; }
.focus-name { font-size:32rpx; color:rgba(255,255,255,.6); margin-bottom:20rpx; letter-spacing:2rpx; }
.focus-count { font-size:160rpx; font-weight:200; color:#fff; font-family:-apple-system,'SF Pro Display',sans-serif; line-height:1; text-shadow:0 8rpx 40rpx rgba(175,82,222,.4); }
.focus-unit { font-size:30rpx; color:rgba(255,255,255,.4); margin-top:8rpx; }
.focus-btn { width:220rpx; height:220rpx; border-radius:50%; background:linear-gradient(135deg,#AF52DE,#7B1FA2); display:flex;align-items:center;justify-content:center; margin-top:60rpx; box-shadow:0 12rpx 48rpx rgba(175,82,222,.5), inset 0 -4rpx 16rpx rgba(0,0,0,.15); transition:transform .1s; }
.focus-btn text { font-size:96rpx; color:#fff; font-weight:200; line-height:1; }
.focus-btn:active { transform:scale(.92); }
.focus-target { font-size:24rpx; color:rgba(255,255,255,.35); margin-top:40rpx; }
.focus-back { position:fixed; top:calc(80rpx + env(safe-area-inset-top)); left:32rpx; padding:16rpx 24rpx; background:rgba(255,255,255,.1); border-radius:12rpx; font-size:24rpx; color:rgba(255,255,255,.6); }
