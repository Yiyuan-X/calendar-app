/* 专注模式 */
.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 50% 38%, rgba(238, 255, 78, 0.13) 0%, rgba(238, 255, 78, 0) 28%),
    linear-gradient(180deg, #161A2F 0%, #14213A 48%, #103D62 100%);
  color: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding: calc(120rpx + env(safe-area-inset-top)) 44rpx calc(64rpx + env(safe-area-inset-bottom));
}

.focus-back {
  position: fixed;
  top: calc(72rpx + env(safe-area-inset-top));
  left: 32rpx;
  min-width: 116rpx;
  height: 58rpx;
  padding: 0 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
  font-weight: 600;
  backdrop-filter: blur(18rpx);
}

.back-arrow {
  font-size: 37rpx;
  line-height: 1;
  transform: translateY(-1rpx);
}

.focus-main {
  width: 100%;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: translateY(-16rpx);
}

.focus-name {
  width: 100%;
  max-width: 620rpx;
  text-align: center;
  font-size: 33rpx;
  color: rgba(255, 255, 255, 0.66);
  font-weight: 600;
  line-height: 1.45;
  margin-bottom: 26rpx;
}

.count-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.focus-count {
  font-size: 166rpx;
  font-weight: 240;
  color: #FFFFFF;
  font-family: -apple-system, 'SF Pro Display', sans-serif;
  line-height: 0.94;
  text-shadow: 0 12rpx 48rpx rgba(13, 31, 56, 0.36);
}

.focus-unit {
  font-size: 31rpx;
  color: rgba(255, 255, 255, 0.42);
  margin-top: 18rpx;
  font-weight: 500;
}

.focus-btn {
  width: 222rpx;
  height: 222rpx;
  margin-top: 58rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #F0FF4D 0%, #D7F72A 52%, #AEE800 100%);
  box-shadow:
    0 18rpx 52rpx rgba(212, 255, 44, 0.28),
    0 8rpx 28rpx rgba(48, 105, 20, 0.18),
    inset 0 8rpx 18rpx rgba(255, 255, 255, 0.48),
    inset 0 -10rpx 20rpx rgba(77, 126, 0, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
}

.plus {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #263400;
  font-size: 92rpx;
  font-weight: 300;
  line-height: 1;
}

.focus-btn-active {
  transform: scale(0.94);
  opacity: 0.94;
}

.focus-target {
  margin-top: 42rpx;
  min-height: 54rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: rgba(255, 255, 255, 0.48);
  font-size: 26rpx;
  font-weight: 600;
}

.target-value {
  color: rgba(240, 255, 77, 0.78);
}

.focus-target-empty {
  color: rgba(255, 255, 255, 0.4);
}
