/* pages/calendar/calendar.wxss — 日历页样式（标准正文字号 28rpx） */

.page-container {
  min-height: 100vh;
  padding: 0 24rpx;
  background: #F5F5F7;
}

/* ==================== 月份导航 ==================== */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 8rpx 20rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: transparent;
  transition: background 0.15s;
}

.nav-btn:active { background: rgba(0, 0, 0, 0.04); }

.nav-arrow {
  font-size: 39rpx;
  color: #86868B;
  line-height: 1;
  font-weight: 300;
}

.month-title {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  padding: 10rpx 32rpx;
}

.year-text {
  font-size: 28rpx;
  color: #AEAEB2;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.month-text {
  font-size: 41rpx;
  color: #1D1D1F;
  font-weight: 700;
  letter-spacing: 3rpx;
}

/* ==================== 回到今天按钮 ==================== */
.back-today-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  margin: 0 0 8rpx;
  background: linear-gradient(135deg, #FFF7E6, #FFEEDD);
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 152, 0, 0.15);
}

.back-today-icon-text {
  font-size: 32rpx;
  color: #FF9800;
  line-height: 1;
}

.back-today-text {
  font-size: 28rpx;
  color: #E65100;
  font-weight: 600;
}

.back-today-bar:active {
  opacity: 0.75;
  transform: scale(0.98);
}

/* ==================== 星期标题 ==================== */
.week-header {
  display: flex;
  margin-bottom: 6rpx;
  padding: 12rpx 8rpx 14rpx;
}

.week-day-item {
  flex: 1;
  text-align: center;
  padding: 4rpx 0;
}

.week-day-text {
  font-size: 28rpx;
  color: #8E8E93;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.week-day-text.weekend { color: #D32F2F; opacity: 0.85; }

/* ==================== 日历网格（竞品风格） ==================== */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.day-cell {
  width: calc(100% / 7);
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 12rpx;
  position: relative;
  border-right: 1rpx solid rgba(0, 0, 0, 0.03);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
  transition: background 0.15s ease;
  box-sizing: border-box;
}

.day-cell:nth-child(7n) { border-right: none; }

.day-cell.current-month:active { background: rgba(139, 105, 20, 0.05); }

/* 非当月日期 — 更浅，明显区分 */
.day-cell.other-month .day-number,
.day-cell.other-month .marker {
  opacity: 0.18;
}

/* 日期数字 — 主视觉：大字加粗 */
.day-number {
  font-size: 39rpx;
  color: #1D1D1F;
  font-weight: 700;
  line-height: 1.2;
  z-index: 1;
}

/* 今天 — 红色文字（仅未选中且是今天时使用） */
.day-today {
  color: #B71C1C !important;
  font-weight: 700 !important;
}

/* 今天小圆点 */
.today-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #B71C1C;
  margin-top: 4rpx;
}

/* 选中状态 — 深红实心方块 + 白字（独立类名，无优先级冲突） */
.day-selected {
  width: 60rpx !important;
  height: 60rpx !important;
  line-height: 60rpx !important;
  text-align: center !important;
  background: linear-gradient(135deg, #B71C1C, #8B0000) !important;
  color: #FFFFFF !important;
  border-radius: 12rpx !important;
  font-weight: 800 !important;
  font-size: 34rpx !important;
  box-shadow: 0 3rpx 10rpx rgba(183, 28, 28, 0.35) !important;
  display: inline-block !important;
}

/* ==================== 标记文字（节气/农历/节日） ==================== */
/* 农历/标记 — 辅助小字 */
.marker {
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 96%;
  padding: 0 2rpx;
  font-weight: 400;
  margin-top: 3rpx;
}

/* 合并标记（如"父亲节·夏至"）：缩小字体以适配多文字 */
.combined-marker {
  font-size: 24rpx !important;
  color: #666;
  font-weight: 500;
  letter-spacing: 0;
}

/* 节气 — 绿色醒目 */
.solar-term-marker {
  color: #2E7D32;
  font-weight: 600;
}

/* 农历 — 浅灰小字 */
.lunar-marker {
  color: #AEAEB2;
  font-weight: 400;
}

/* 节日 — 加粗醒目 */
.festival-marker {
  padding: 0 4rpx;
  border-radius: 4rpx;
  font-weight: 700;
}

.festival-red { color: #D32F2F; }
.festival-purple { color: #7B1FA2; }
.festival-gold { color: #E65100; }

/* 重要日子标记（日历格子中显示用户自定义事件名称） */
.event-marker {
  color: #007AFF;
  font-weight: 600;
  padding: 0 4rpx;
  border-radius: 3rpx;
  background: rgba(0, 122, 255, 0.06);
}

/* 有重要日子格子的特殊样式 */
.day-cell.has-event .day-number {
  font-weight: 700;
}

/* 今天圆点（备用） */
.today-dot {
  display: none; /* 使用圆形数字模式，隐藏圆点 */
}

/* 多节日圆点指示器 */
.festival-dots {
  position: absolute;
  bottom: 6rpx;
  display: flex;
  gap: 5rpx;
}

.dot {
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
}

.dot-red { background: #FF3B30; }
.dot-purple { background: #AF52DE; }
.dot-gold { background: #DAA520; }

/* ==================== 详情面板 ==================== */
.detail-panel {
  margin-top: 24rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.panel-header {
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.panel-date {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  margin-bottom: 6rpx;
}

/* 面板日期标题（大标题） */
.panel-solar {
  font-size: 37rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: 0.5rpx;
}

.panel-weekday {
  font-size: 30rpx;
  color: #86868B;
  font-weight: 500;
}

/* 第一行：日期 + 星期 */
.panel-date-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

/* 第二行：节日胶囊标签行 */
.festival-pills-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

/* 节日胶囊 */
.festival-pill {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.6;
}

.pill-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.pill-name {
  white-space: nowrap;
}

/* 节日胶囊颜色 - 红色（法定/传统节日） */
.festival-pill.tag-red {
  color: #C62828;
  background: rgba(198, 40, 40, 0.08);
}
.festival-pill.tag-red .pill-dot { background: #C62828; }

/* 紫色（佛教纪念日） */
.festival-pill.tag-purple {
  color: #7B1FA2;
  background: rgba(123, 31, 162, 0.08);
}
.festival-pill.tag-purple .pill-dot { background: #7B1FA2; }

/* 金色（其他） */
.festival-pill.tag-gold {
  color: #E65100;
  background: rgba(230, 81, 0, 0.08);
}
.festival-pill.tag-gold .pill-dot { background: #E65100; }

/* 其他颜色 */
.festival-pill.tag-pink { color: #C2185B; background: rgba(194, 24, 91, 0.06); }
.festival-pill.tag-pink .pill-dot { background: #C2185B; }
.festival-pill.tag-blue { color: #1976D2; background: rgba(25, 118, 210, 0.06); }
.festival-pill.tag-blue .pill-dot { background: #1976D2; }
.festival-pill.tag-green { color: #2E7D32; background: rgba(46, 125, 50, 0.06); }
.festival-pill.tag-green .pill-dot { background: #2E7D32; }
.festival-pill.tag-gray,
.festival-pill.tag-orange { color: #555; background: rgba(0, 0, 0, 0.05); }
.festival-pill.tag-gray .pill-dot,
.festival-pill.tag-orange .pill-dot { background: #999; }

.panel-lunar {
  display: flex;
  align-items: center;
  gap: 5rpx;
  flex-wrap: wrap;
}

.lunar-year {
  font-size: 28rpx;
  color: #B8860B;
  font-weight: 500;
}

.lunar-animal {
  font-size: 28rpx;
  color: #B8860B;
}

.lunar-date {
  font-size: 28rpx;
  color: #AEAEB2;
}

/* 当天节日名称（跟在星期后面同一行） */
.festival-name-inline {
  font-size: 27rpx;
  font-weight: 600;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  line-height: 1.6;
  margin-left: 8rpx;
  display: inline-block;
  vertical-align: middle;
}

/* 节日标签颜色 */
.festival-name-inline.tag-red {
  color: #C62828;
  background: rgba(198, 40, 40, 0.08);
}

.festival-name-inline.tag-purple {
  color: #7B1FA2;
  background: rgba(123, 31, 162, 0.08);
}

.festival-name-inline.tag-gold {
  color: #E65100;
  background: rgba(230, 81, 0, 0.08);
}

.festival-name-inline.tag-gray,
.festival-name-inline.tag-pink,
.festival-name-inline.tag-blue,
.festival-name-inline.tag-green,
.festival-name-inline.tag-orange {
  color: #555;
  background: rgba(0, 0, 0, 0.05);
}

/* ==================== 信息卡片 ==================== */
.info-card {
  margin-bottom: 16rpx;
  padding: 26rpx 28rpx;
  border-radius: 20rpx !important;
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.card-label {
  display: inline-flex;
  margin-bottom: 12rpx;
}

/* 卡片内标题（略大于标准正文） */
.info-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1D1D1F;
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 0.5rpx;
}

/* 卡片描述（标准正文） */
.info-desc {
  font-size: 30rpx;
  color: #86868B;
  line-height: 1.65;
  display: block;
}

/* 节日项 */
.festival-item {
  display: flex;
  align-items: flex-start;
  gap: 0;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F2;
}

.festival-item:last-child { border-bottom: none; padding-bottom: 0; }
.festival-item:first-child { padding-top: 0; }

/* 左侧彩色竖条（替代原来的标签） */
.festival-color-bar {
  width: 6rpx;
  min-height: 100%;
  border-radius: 3rpx;
  flex-shrink: 0;
  margin-right: 18rpx;
}

.festival-color-bar.tag-red { background: linear-gradient(180deg, #FF6B6B, #EE5A5A); }
.festival-color-bar.tag-purple { background: linear-gradient(180deg, #9B59B6, #8E44AD); }
.festival-color-bar.tag-gold { background: linear-gradient(180deg, #DAA520, #B8860B); }
.festival-color-bar.tag-pink { background: linear-gradient(180deg, #E91E63, #C2185B); }
.festival-color-bar.tag-blue { background: linear-gradient(180deg, #2196F3, #1976D2); }
.festival-color-bar.tag-green { background: linear-gradient(180deg, #4CAF50, #388E3C); }

.festival-content {
  flex: 1;
  min-width: 0;
}

/* 名称 + 箭头同行 */
.festival-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 2rpx;
}

/* 节日名称（略大于标准正文） */
.festival-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
  display: block;
  margin-bottom: 3rpx;
}

/* 节日描述（标准正文） */
.festival-desc {
  font-size: 28rpx;
  color: #86868B;
  line-height: 1.55;
  display: block;
  margin-top: 4rpx;
}

/* 节日引言（标准正文） */
.festival-quote {
  font-size: 29rpx;
  color: #B8860B;
  font-style: italic;
  display: block;
  margin-top: 10rpx;
  line-height: 1.5;
  padding-left: 12rpx;
  border-left: 3rpx solid rgba(201, 169, 110, 0.3);
}

.arrow {
  font-size: 34rpx;
  color: #AEAEB2;
  flex-shrink: 0;
  font-weight: 300;
}

/* 备注卡片 */
.note-card {
  display: flex;
  flex-direction: column;
  gap: 6px;
  border-left: 4rpx solid #DAA520 !important;
  border-radius: 0 18rpx 18rpx 0 !important;
}

/* 备注预览（标准正文） */
.note-preview {
  font-size: 30rpx;
  color: #86868B;
  line-height: 1.65;
}

.edit-hint {
  font-size: 28rpx;
  color: #007AFF;
  font-weight: 500;
}

/* 添加备注按钮 */
.add-note-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx;
  background: #FFFFFF;
  border: 2rpx dashed rgba(142, 142, 147, 0.25);
  border-radius: 18rpx;
  margin-top: 14rpx;
  color: #AEAEB2;
  font-size: 30rpx;
  line-height: 1;
  transition: border-color 0.2s;
}

.add-note-btn:active {
  border-color: #007AFF;
  color: #007AFF;
}

.add-note-icon { font-size: 34rpx; }

/* 添加重要日子入口 */
.add-event-from-calendar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx;
  margin-top: 10rpx;
  color: #007AFF;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 1rpx;
  background: rgba(0, 122, 255, 0.05);
  border-radius: 18rpx;
  transition: background 0.15s;
}

.add-event-from-calendar:active { background: rgba(0, 122, 255, 0.1); }

.add-event-icon {
  font-size: 37rpx;
  line-height: 1;
  font-weight: 300;
}

.bottom-spacer { height: 60rpx; }

/* ==================== 分享操作栏（与今日页一致） ==================== */
.share-bar {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 8rpx 0 4rpx;
  opacity: 0.72;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin: 0 !important;
  padding: 10rpx 24rpx !important;
  border-radius: 50rpx !important;
  font-size: 26rpx !important;
  font-weight: 600 !important;
  line-height: 1 !important;
  border: none !important;
  background: transparent !important;
}

.share-btn::after { display: none !important; }

.share-btn:active {
  transform: scale(0.95);
  transition: transform 0.12s ease;
  opacity: 0.9;
}

/* 一键分享 / 朋友圈（白底金色文字，与今日页一致） */
.share-btn-primary:nth-child(1) {
  background: #FFFFFF !important;
  color: #8B6914 !important;
  box-shadow: none !important;
}

.share-btn-primary:nth-child(2) {
  background: #FFFFFF !important;
  color: #8B6914 !important;
  box-shadow: none !important;
}

.share-btn-icon {
  width: 30rpx;
  height: 30rpx;
}

.share-btn-text { font-size: 27rpx; letter-spacing: 1rpx; }

/* 保存按钮（次要样式，与今日页一致） */
.share-btn-save {
  background: linear-gradient(135deg, #FFF8E7, #FFECB3) !important;
  color: #8B6914 !important;
  box-shadow: 0 2rpx 10rpx rgba(139, 105, 20, 0.1) !important;
}

/* 标签颜色 */
.tag-red { background: #FFE5E5; color: #D93B3B; }
.tag-purple { background: #F3E8FF; color: #8E44AD; }
.tag-gold { background: #FFF3D6; color: #B8860B; }
.tag-pink { background: #FFE4F0; color: #C2185B; }
.tag-blue { background: #E5F2FF; color: #007AFF; }
.tag-green { background: #E5FAEF; color: #2E7D32; }
.tag-orange { background: #FFF3E0; color: #E65100; }
.tag-gray { background: #F2F2F7; color: #8E8E93; }

/* 小标签（辅助信息，可稍小） */
.tag {
  font-size: 25rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

/* ==================== 节气养生卡片 ==================== */
.solar-term-card {
  border-left: 5rpx solid #34C759 !important;
  padding-bottom: 28rpx !important;
}

.st-header {
  margin-bottom: 18rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* 节气名称（大标题） */
.st-name {
  color: #2E7D32 !important;
  font-size: 37rpx !important;
  margin-bottom: 6rpx !important;
}

/* 节气简介（标准正文） */
.st-desc {
  font-size: 30rpx;
  color: #555;
  line-height: 1.6;
  display: block;
}

.st-section {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
  align-items: flex-start;
}

/* 节气小标签 */
.st-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #34C759;
  white-space: nowrap;
  flex-shrink: 0;
  width: 80rpx;
}

/* 节气内容（标准正文） */
.st-text {
  font-size: 30rpx;
  color: #444;
  line-height: 1.65;
  flex: 1;
}

.st-tip {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border-radius: 14rpx;
  border-left: 3rpx solid #66BB6A;
}

/* 养生金句（标准正文） */
.tip-text {
  font-size: 30rpx;
  color: #2E7D32;
  line-height: 1.6;
  display: block;
  font-style: italic;
}

/* ==================== 黄历卡片（竞品风格升级） ==================== */
.huangli-card {
  margin-top: 16rpx;
  padding: 28rpx 24rpx !important;
  background: #fff !important;
  border-left: none !important;
  border-radius: 20rpx !important;
  box-shadow: 0 2rpx 16rpx rgba(139, 105, 20, 0.06);
}

/* ===== 第一行：农历大标题（参考竞品） ===== */
.hl-top-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.hl-nongli-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hl-nongli-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #B71C1C, #D32F2F);
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  letter-spacing: 2rpx;
}

/* 农历大字（特大标题） */
.hl-nongli-value {
  font-size: 41rpx;
  font-weight: 800;
  color: #1D1D1F;
  letter-spacing: 3rpx;
  font-family: -apple-system, 'SF Pro Display', serif;
}

.hl-top-right {
  flex-shrink: 0;
}

.hl-set-reminder {
  font-size: 26rpx;
  color: #AEAEB2;
  font-weight: 500;
}

/* ===== 第二行：干支行 ===== */
.hl-ganzhi-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid rgba(218, 165, 32, 0.08);
}

.hl-ganzhi-prefix {
  font-size: 26rpx;
}

/* 干支文字（标准正文） */
.hl-ganzhi-text {
  font-size: 30rpx;
  color: #5D4037;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ===== 第三行：佛历 + 斋日 ===== */
.hl-foli-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  padding: 12rpx 16rpx;
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.04), rgba(255, 152, 0, 0.03));
  border-radius: 10rpx;
  border-left: 3rpx solid rgba(156, 39, 176, 0.3);
}

/* 佛历文字（标准正文） */
.foli-text {
  font-size: 28rpx;
  color: #7B1FA2;
  font-weight: 600;
}

.zhai-tag-inline {
  display: inline-flex;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 25rpx;
  font-weight: 600;
}

.zhai-liu {
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.1), rgba(156, 39, 176, 0.06));
  color: #7B1FA2;
  border: 1rpx solid rgba(156, 39, 176, 0.15);
}

.zhai-shi {
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.12), rgba(255, 152, 0, 0.06));
  color: #E65100;
  border: 1rpx solid rgba(255, 152, 0, 0.2);
}

/* 宜忌区域 */
.hl-yiji-section {
  margin-bottom: 18rpx;
}

.hl-yi-group,
.hl-ji-group {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

/* 宜忌大字标签 */
.hl-yiji-label {
  font-size: 30rpx;
  font-weight: 800;
  width: 38rpx;
  height: 38rpx;
  line-height: 38rpx;
  text-align: center;
  border-radius: 8rpx;
  flex-shrink: 0;
  font-family: -apple-system, 'SF Pro Display', serif;
}

.yi-label {
  background: linear-gradient(135deg, #8B6914, #A08520);
  color: #fff;
  box-shadow: 0 2rpx 6rpx rgba(139, 105, 20, 0.25);
}

.ji-label {
  background: linear-gradient(135deg, #8B6914, #A08520);
  color: #fff;
  box-shadow: 0 2rpx 6rpx rgba(139, 105, 20, 0.25);
}

.hl-yiji-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
}

/* 宜忌标签文字（参考竞品：纯黑大字，无背景） */
.yi-tag {
  font-size: 32rpx;
  color: #1a1a1a;
  background: transparent;
  padding: 2rpx 6rpx;
  border-radius: 0;
  font-weight: 500;
  line-height: 1.6;
}

.ji-tag {
  font-size: 32rpx;
  color: #1a1a1a;
  background: transparent;
  padding: 2rpx 6rpx;
  border-radius: 0;
  font-weight: 500;
  line-height: 1.5;
}

/* 详情网格（冲煞/五行/方位） */
.hl-details-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx 8rpx;
  padding: 18rpx 16rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 14rpx;
  border: 1rpx solid rgba(218, 165, 32, 0.08);
}

.hl-detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 0;
}

/* 详情小标签 */
.detail-label {
  font-size: 25rpx;
  color: #AEAEB2;
  font-weight: 500;
}

/* 详情数值（标准正文） */
.detail-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #3C3C43;
  letter-spacing: 0.5rpx;
}

.value-warn { color: #E65100; }
.value-highlight { color: #DAA520; }
.value-good { color: #2E7D32; }
.value-bad { color: #C62828; }

/* 彭祖百忌 */
.hl-pengzu {
  margin-bottom: 14rpx;
  padding: 16rpx 18rpx;
  background: rgba(139, 105, 20, 0.04);
  border-radius: 12rpx;
  border-left: 3rpx solid rgba(218, 165, 32, 0.25);
}

.pengzu-title {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 10rpx;
}

.pengzu-icon {
  font-size: 26rpx;
}

/* 彭祖标题（标准正文） */
.pengzu-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #8B6914;
}

.pengzu-items {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

/* 彭祖条目（标准正文） */
.pengzu-item {
  font-size: 28rpx;
  color: #5D4037;
  line-height: 1.65;
  padding-left: 12rpx;
  border-left: 2rpx solid rgba(218, 165, 32, 0.15);
}

/* 建除说明 */
.hl-jianchu-desc {
  padding: 14rpx 18rpx;
  background: linear-gradient(135deg, rgba(218, 165, 32, 0.05) 0%, rgba(255, 215, 0, 0.03) 100%);
  border-radius: 12rpx;
  border: 1rpx solid rgba(218, 165, 32, 0.1);
}

/* 建除说明文字（标准正文） */
.jianchu-desc-text {
  font-size: 28rpx;
  color: #6D5A2E;
  line-height: 1.65;
  display: block;
}

/* ==================== 十二时辰区域（竞品风格） ==================== */
.hl-shichen-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(218, 165, 32, 0.12);
}

.shichen-title-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

/* 时辰标题 */
.shichen-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #8B6914;
  letter-spacing: 1rpx;
}

.shichen-sub {
  font-size: 25rpx;
  color: #AEAEB2;
  flex-shrink: 0;
}

/* 时辰列表 */
.shichen-list {
  display: flex;
  flex-direction: column;
}

/* 每个时辰行 — 参考竞品：白底 + 底部分割线 */
.shichen-item {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

/* 最后一个不要下边框 */
.shichen-item:last-child {
  border-bottom: none;
}

.shichen-item:active {
  background: rgba(218, 165, 32, 0.03);
}

/* ==================== 左侧：圆形地支 + 时间（两行） ==================== */
.sc-left {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  width: 260rpx;
  flex-shrink: 0;
}

.sc-zhi-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B6914, #A08520);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(139, 105, 20, 0.2);
}

/* 地支字 */
.sc-zhi-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #fff;
  font-family: -apple-system, 'SF Pro Display', serif;
}

.sc-time-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding-top: 2rpx;
}

/* 第一行：时辰名 + 时间（主文字） */
.sc-time-main {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  line-height: 1.4;
}

/* 第二行：冲煞（辅助小字） */
.sc-time-sub {
  font-size: 25rpx;
  color: #E65100;
  font-weight: 500;
  line-height: 1.3;
}

/* ==================== 右侧：宜忌（上下分行） ==================== */
.sc-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
  padding-left: 8rpx;
}

.sc-yi-area,
.sc-ji-area {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  min-width: 0;
}

/* 宜/忌 圆角标签 */
.sc-yi-label,
.sc-ji-label {
  font-size: 25rpx;
  font-weight: 800;
  width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  text-align: center;
  border-radius: 6rpx;
  flex-shrink: 0;
  font-family: -apple-system, 'SF Pro Display', serif;
}

.sc-yi-label {
  background: linear-gradient(135deg, #4CAF50, #388E3C);
  color: #fff;
}

.sc-ji-label {
  background: linear-gradient(135deg, #F44336, #D32F2F);
  color: #fff;
}

/* 标签滚动区 — 允许多行显示 */
.sc-tags-scroll {
  flex: 1;
  min-height: 36rpx;
}

.sc-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* 宜忌文字标签（纯黑大字，参考竞品） */
.sc-yi-tag,
.sc-ji-tag {
  font-size: 29rpx;
  color: #1a1a1a;
  background: transparent;
  padding: 0;
  border-radius: 0;
  font-weight: 500;
  line-height: 1.5;
  flex-shrink: 0;
}

/* 空状态占位文字 */
.sc-empty-tag {
  font-size: 27rpx;
  color: #999;
  line-height: 36rpx;
}

/* ==================== 图标 Image 样式 ==================== */
.add-note-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.hl-set-reminder {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 26rpx;
  color: #AEAEB2;
  font-weight: 500;
}

.reminder-icon {
  width: 26rpx;
  height: 26rpx;
}

.hl-ganzhi-prefix-img {
  width: 24rpx;
  height: 24rpx;
}

.pengzu-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.shichen-title-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  vertical-align: middle;
}
