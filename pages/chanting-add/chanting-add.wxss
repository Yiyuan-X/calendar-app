/* 添加功课页面 */
.page { min-height:100vh; background:#F5F5F7; padding:20rpx 24rpx; }

/* 搜索栏 */
.search-bar { background:#fff; border-radius:16rpx; padding:18rpx 24rpx; display:flex; align-items:center; gap:14rpx; margin-bottom:24rpx; box-shadow:0 2rpx 8rpx rgba(0,0,0,.03); }
.search-icon { width:32rpx; height:32rpx; flex-shrink:0; }
.search-input { flex:1; font-size: 30rpx; color:#1D1D1F; }
.search-clear { font-size: 30rpx; color:#AEAEB2; padding:8rpx; }
.clear-icon { width:24rpx; height:24rpx; display:block; }

/* 热门标签 */
.section-title { font-size: 27rpx; font-weight:600; color:#1D1D1F; margin:20rpx 0 14rpx 4rpx; display:flex; align-items:center; gap:8rpx; }
.section-title text { font-size: 25rpx; color:#AF52DE; }
.section-title-icon { width:26rpx; height:26rpx; flex-shrink:0; }

/* 功课卡片列表 */
.practice-list { display:flex; flex-direction:column; gap:12rpx; }
.p-item { background:#fff; border-radius:14rpx; padding:20rpx 24rpx; display:flex; align-items:center; justify-content:space-between; box-shadow:0 1rpx 6rpx rgba(0,0,0,.02); transition:all .15s; }
.p-item:active { transform:scale(.98); background:#FAFAFA; }
.p-left { display:flex; align-items:center; gap:14rpx; flex:1; min-width:0; }
.p-name { font-size: 30rpx; font-weight:600; color:#1D1D1F; }
.p-meta { font-size: 24rpx; color:#AEAEB2; margin-top:2rpx; }
.p-hot { font-size: 24rpx; color:#FF9500; background:rgba(255,149,0,.1); padding:2rpx 10rpx; border-radius:8rpx; margin-left:8rpx; }
.p-add { width:56rpx; height:56rpx; border-radius:50%; background:#FFCC00; display:flex;align-items:center;justify-content:center; flex-shrink:0; box-shadow:0 2rpx 8rpx rgba(255,204,0,.35); }
.p-add text { color:#fff; font-size: 34rpx; line-height:1; }
.p-del { width:56rpx; height:56rpx; border-radius:50%; background:#FF3B30; display:flex;align-items:center;justify-content:center; flex-shrink:0; }
.p-del text { color:#fff; font-size: 28rpx; line-height:1; font-weight:bold; }
.p-del-icon { width:24rpx; height:24rpx; }

/* 自定义区域 */
.custom-card { background:#fff; border-radius:18rpx; padding:28rpx 24rpx; margin-top:24rpx; box-shadow:0 2rpx 10rpx rgba(0,0,0,.03); }
.c-label { font-size: 27rpx; font-weight:600; color:#1D1D1F; margin-bottom:16rpx; display:flex; align-items:center; gap:8rpx; }
.c-label-icon { width:28rpx; height:28rpx; flex-shrink:0; }
.c-input { width:100%; height:88rpx; background:#F5F5F7; border-radius:14rpx; padding:0 24rpx; font-size: 30rpx; color:#1D1D1F; box-sizing:border-box; margin-bottom:16rpx; }
.c-row { display:flex; gap:16rpx; margin-bottom:16rpx; }
.c-row-2 { margin-bottom:20rpx; }
.c-input-sm { flex:1; height:80rpx; background:#F5F5F7; border-radius:14rpx; padding:0 20rpx; font-size: 28rpx; color:#1D1D1F; box-sizing:border-box; }
.c-btn { width:100%; height:88rpx; color:#fff; border-radius:16rpx; font-size: 32rpx; font-weight:600; display:flex;align-items:center;justify-content:center; line-height:1; letter-spacing:4rpx; }
.c-btn-yellow { background:#FFCC00; color:#1D1D1F; box-shadow:0 4rpx 14rpx rgba(255,204,0,.4); }
.c-btn::after { border:none; }
.c-btn:active { opacity:.85; }

.combo-card { margin-top:24rpx; }
.archived-combo-list { background:#FFF8E7; border:1rpx solid rgba(255,149,0,.18); border-radius:14rpx; padding:16rpx; margin-bottom:18rpx; }
.archived-combo-title { font-size:25rpx; font-weight:600; color:#8B6914; margin-bottom:10rpx; }
.archived-combo-item { display:flex; align-items:center; justify-content:space-between; gap:14rpx; padding:12rpx 0; }
.archived-combo-item + .archived-combo-item { border-top:1rpx solid rgba(139,105,20,.12); }
.archived-combo-info { flex:1; min-width:0; display:flex; flex-direction:column; gap:4rpx; }
.archived-combo-name { font-size:28rpx; font-weight:600; color:#1D1D1F; }
.archived-combo-meta { font-size:23rpx; color:#8A7A55; line-height:1.4; }
.archived-combo-btn { flex-shrink:0; height:54rpx; padding:0 22rpx; border-radius:27rpx; background:#FFCC00; color:#1D1D1F; font-size:25rpx; font-weight:600; display:flex; align-items:center; justify-content:center; }
.combo-row { display:flex; align-items:center; gap:12rpx; margin-bottom:16rpx; }
.combo-input { flex:0 0 220rpx; }
.combo-unit { font-size:28rpx; color:#6E6E73; }
.combo-preview { background:#F5F5F7; border-radius:14rpx; padding:14rpx 18rpx; margin-bottom:20rpx; }
.combo-preview-item { display:flex; align-items:center; justify-content:space-between; min-height:42rpx; font-size:26rpx; color:#1D1D1F; }
.combo-preview-item + .combo-preview-item { border-top:1rpx solid rgba(0,0,0,.05); }
.combo-preview-item text:last-child { color:#FF9500; font-weight:600; }

.empty-result { text-align:center; padding:60rpx 0; font-size: 28rpx; color:#AEAEB2; }
