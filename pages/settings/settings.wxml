<!--pages/settings/settings.wxml — 设置页面-->
<view class="page-container {{elderMode ? 'elder-mode' : ''}}">
  <!-- 标题 -->
  <view class="page-header">
    <text class="page-title">显示设置</text>
    <text class="page-subtitle">选择在日历上展示的佛教与传统日期</text>
  </view>

  <!-- 设置列表 -->
  <view class="settings-group">
    <!-- 长辈模式 -->
    <view class="setting-item">
      <view class="setting-left">
        <view class="setting-icon-wrap elder-icon">
          <text class="setting-icon-text">字</text>
        </view>
        <view class="setting-info">
          <text class="setting-name">长辈模式</text>
          <text class="setting-desc">使用更大的字号，适合阅读时看得更清楚</text>
        </view>
      </view>
      <switch
        checked="{{elderMode}}"
        color="#FFB300"
        bindchange="onSwitchElderMode"
      />
    </view>

    <!-- 六斋日 -->
    <view class="setting-item">
      <view class="setting-left">
        <view class="setting-icon-wrap liuzhai-icon">
          <image class="setting-icon-img" src="/images/icons/gen-lotus.svg" mode="aspectFit"></image>
        </view>
        <view class="setting-info">
          <text class="setting-name">六斋日</text>
          <text class="setting-desc">每月初八、十四、十五、廿三、月末两日</text>
        </view>
      </view>
      <switch
        checked="{{showLiuZhai}}"
        color="#FFB300"
        bindchange="onSwitchLiuZhai"
      />
    </view>

    <!-- 农历初一/十五 -->
    <view class="setting-item">
      <view class="setting-left">
        <view class="setting-icon-wrap lunar-icon">
          <image class="setting-icon-img" src="/images/icons/gen-moon.svg" mode="aspectFit"></image>
        </view>
        <view class="setting-info">
          <text class="setting-name">农历初一 / 十五</text>
          <text class="setting-desc">每月初一和十五在日历上标记显示</text>
        </view>
      </view>
      <switch
        checked="{{showLunarFestivals}}"
        color="#DAA520"
        bindchange="onSwitchLunarFestivals"
      />
    </view>

    <!-- 佛教纪念日 -->
    <view class="setting-item">
      <view class="setting-left">
        <view class="setting-icon-wrap buddhist-icon">
          <image class="setting-icon-img" src="/images/icons/fo.svg" mode="aspectFit"></image>
        </view>
        <view class="setting-info">
          <text class="setting-name">佛教纪念日</text>
          <text class="setting-desc">佛诞日、涅槃日、观音菩萨圣诞等</text>
        </view>
      </view>
      <switch
        checked="{{showBuddhistFestivals}}"
        color="#FFB300"
        bindchange="onSwitchBuddhistFestivals"
      />
    </view>
  </view>

  <!-- 帮助入口 -->
  <view class="settings-group">
    <view class="setting-item nav-setting" bindtap="goToHelp">
      <view class="setting-left">
        <view class="setting-icon-wrap help-icon">
          <image class="setting-icon-img" src="/images/icons/scroll.svg" mode="aspectFit"></image>
        </view>
        <view class="setting-info">
          <text class="setting-name">使用说明</text>
          <text class="setting-desc">了解黄历、今日、功过格和计数器的用法</text>
        </view>
      </view>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <!-- 反馈入口 -->
  <view class="settings-group">
    <view class="setting-item nav-setting" bindtap="copyWechat">
      <view class="setting-left">
        <view class="setting-icon-wrap feedback-icon">
          <image class="setting-icon-img" src="/images/icons/gen-prayer.svg" mode="aspectFit"></image>
        </view>
        <view class="setting-info">
          <text class="setting-name">反馈与交流</text>
          <text class="setting-desc">有建议、想做公司/个人小程序，或想学习小程序开发，都可以联系。微信 HSTS08，邮箱 914949158@qq.com</text>
        </view>
      </view>
      <text class="setting-action">复制</text>
    </view>
  </view>

  <!-- 推广小程序码 -->
  <view class="promo-card">
    <view class="promo-info">
      <text class="promo-title">推荐岁时记</text>
      <text class="promo-desc">长按或保存小程序码，分享给需要记录日子、查看黄历和做功课计数的朋友。</text>
    </view>
    <image
      class="promo-code"
      src="/images/promo-qrcode.png"
      mode="aspectFit"
      bindtap="previewPromotionCode"
    ></image>
    <button class="promo-share-btn" open-type="share">转发给朋友</button>
  </view>

  <!-- 说明区域 -->
  <view class="tips-card">
    <text class="tips-title">说明</text>
    <text class="tips-text">关闭后，对应日期的标记将不会出现在日历格子上。固定节日（如劳动节、国庆节）和农历传统节日（如春节、中秋）始终显示，不受此设置影响。</text>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-spacer"></view>
</view>
