/* pages/settings/settings.wxss — 设置页面样式（Apple 风格） */

.page-container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 0 24rpx 120rpx;
}

/* ==================== 页面标题 ==================== */
.page-header {
  padding: 36rpx 0 28rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1D1D1F;
  display: block;
  letter-spacing: 0.5rpx;
}

.page-subtitle {
  font-size: 25rpx;
  color: #86868B;
  margin-top: 8rpx;
  display: block;
  line-height: 1.5;
}

/* ==================== 设置分组 ==================== */
.settings-group {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F2;
  transition: background 0.15s ease;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: #FAFAFA;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.setting-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.liuzhai-icon { background: linear-gradient(135deg, #FFF8E1, #FFECB3); }
.lunar-icon { background: linear-gradient(135deg, #FFF9EC, #FFF3D6); }
.buddhist-icon { background: linear-gradient(135deg, #FFF8E1, #FFECB3); }
.elder-icon { background: linear-gradient(135deg, #FFF3D6, #FFE082); }
.help-icon { background: linear-gradient(135deg, #EEF2FF, #E0F2FE); }
.feedback-icon { background: linear-gradient(135deg, #FFF8E1, #FFECB3); }

.setting-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.setting-icon-text {
  color: #8B6914;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1;
}

.setting-info {
  flex: 1;
  min-width: 0;
}

.setting-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  display: block;
  line-height: 1.35;
}

.setting-desc {
  font-size: 25rpx;
  color: #AEAEB2;
  margin-top: 4rpx;
  display: block;
  line-height: 1.45;
}

.nav-setting {
  padding-right: 28rpx;
}

.setting-arrow {
  font-size: 39rpx;
  color: #C7C7CC;
  margin-left: 16rpx;
}

.setting-action {
  font-size: 26rpx;
  color: #8B6914;
  font-weight: 650;
  margin-left: 16rpx;
}

/* switch 组件微调 */
setting-item switch {
  transform: scale(0.95);
}

/* ==================== 说明卡片 ==================== */
.tips-card {
  background: #FFFFFF;
  border-radius: 18rpx;
  padding: 24rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

/* ==================== 推广小程序码 ==================== */
.promo-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.promo-info {
  width: 100%;
  margin-bottom: 22rpx;
}

.promo-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1D1D1F;
  line-height: 1.35;
}

.promo-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #86868B;
  line-height: 1.6;
}

.promo-code {
  width: 420rpx;
  height: 420rpx;
  border-radius: 18rpx;
  background: #FAFAFA;
}

.promo-share-btn {
  width: 100%;
  height: 84rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: #1D1D1F;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 650;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.promo-share-btn::after {
  border: none;
}

.tips-title {
  font-size: 27rpx;
  font-weight: 600;
  color: #1D1D1F;
  display: block;
  margin-bottom: 10rpx;
}

.tips-text {
  font-size: 25rpx;
  color: #86868B;
  line-height: 1.7;
  display: block;
}

.bottom-spacer {
  height: 60rpx;
}
