/* pages/festival-detail/festival-detail.wxss —— 优化版 */

.page-container {
  min-height: 100vh;
  padding: 0 32rpx;
  background: var(--bg-color);
}

/* ===== 头部 — 更有仪式感 ===== */
.detail-header {
  padding: 32rpx 0 28rpx;
}

.header-tag {
  display: inline-flex;
  margin-bottom: 18rpx;
}

.header-name {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}

.header-date,
.header-solar {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  font-weight: 400;
}

/* ===== 金句卡片 — 大字展示、有质感 ===== */
.quote-card {
  position: relative;
  padding: 48rpx 36rpx 40rpx;
  margin-bottom: 24rpx;
  background: var(--card-bg);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  text-align: center;
  overflow: hidden;
}

.quote-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg,
    transparent,
    var(--festival-gold),
    transparent
  );
  opacity: 0.6;
}

.quote-decoration {
  font-size: 80rpx;
  color: rgba(201, 169, 110, 0.12);
  line-height: 1;
  position: absolute;
  top: 16rpx;
  left: 28rpx;
  font-family: Georgia, 'Times New Roman', serif;
}

.quote-content {
  font-size: 36rpx;
  color: var(--text-primary);
  line-height: 1.75;
  letter-spacing: 1rpx;
  position: relative;
  z-index: 1;
  font-weight: 400;
}

/* ===== 描述区域 ===== */
.desc-section {
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  border-radius: var(--radius-lg) !important;
  border-left: 4rpx solid var(--festival-gold) !important;
}

.desc-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* ===== 信息列表 — 更精致 ===== */
.info-section {
  background: var(--card-bg);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 29rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.info-value {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.info-value-highlight {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.highlight-number {
  font-size: 43rpx;
  font-weight: 300;
  color: var(--festival-gold);
  letter-spacing: 0;
}

.highlight-unit {
  font-size: 26rpx;
  color: var(--festival-gold);
  font-weight: 500;
}

/* ===== 操作按钮 ===== */
.action-card {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 26rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
  line-height: 1;
  transition: background 0.15s;
}

.action-card:active {
  background: rgba(0, 122, 255, 0.05);
}

.action-icon {
  font-size: 36rpx;
  color: var(--accent-color);
  line-height: 1;
  font-weight: 300;
}

.action-text {
  font-size: 30rpx;
  color: var(--accent-color);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.bottom-spacer {
  height: 60rpx;
}
