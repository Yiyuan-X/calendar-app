/* pages/help/help.wxss */
.page {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 0 24rpx;
}

.header {
  padding: 36rpx 0 12rpx;
}

.title {
  display: block;
  font-size: 39rpx;
  font-weight: 750;
  color: #1D1D1F;
  line-height: 1.3;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
}

.section {
  margin-top: 26rpx;
}

.section-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.section-icon {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #1D1D1F;
}

.card {
  background: #FFFFFF;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.item {
  display: block;
  position: relative;
  padding-left: 24rpx;
  font-size: 30rpx;
  color: #3C3C43;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.item:last-child {
  margin-bottom: 0;
}

.item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 21rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #DAA520;
}

.bottom-space {
  height: 70rpx;
}

/* 更新日志 */
.version-card {
  padding: 28rpx 24rpx;
}

.version-item {
  margin-bottom: 8rpx;
}

.version-tag {
  display: inline-block;
  font-size: 28rpx;
  font-weight: 700;
  color: #FF8F00;
  background: linear-gradient(135deg, #FFF8E7, #FFFBF0);
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid rgba(255,149,0,0.12);
}

.version-detail {
  padding-left: 8rpx;
}

.version-detail .item {
  font-size: 27rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 6rpx;
}

.version-divider {
  height: 1rpx;
  background: linear-gradient(to right, transparent, rgba(0,0,0,0.06), transparent);
  margin: 24rpx 0;
}
