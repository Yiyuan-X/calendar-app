/* pages/help/help.wxss */
.page {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 0 24rpx;
}

.header {
  padding: 36rpx 0 12rpx;
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 750;
  color: #1D1D1F;
  line-height: 1.3;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
}

.section {
  margin-top: 26rpx;
}

.section-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.section-icon {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 29rpx;
  font-weight: 700;
  color: #1D1D1F;
}

.card {
  background: #FFFFFF;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.item {
  display: block;
  position: relative;
  padding-left: 24rpx;
  font-size: 28rpx;
  color: #3C3C43;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.item:last-child {
  margin-bottom: 0;
}

.item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 21rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #DAA520;
}

.bottom-space {
  height: 70rpx;
}
