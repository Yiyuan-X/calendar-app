.page-container {
  min-height: 100vh;
  padding: 0 24rpx 48rpx;
  background: #F5F5F7;
  box-sizing: border-box;
}

.page-header {
  padding: 36rpx 0 24rpx;
}

.page-title,
.page-subtitle {
  display: block;
}

.page-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1D1D1F;
}

.page-subtitle {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: #86868B;
}

.quote-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.quote-card {
  padding: 28rpx 24rpx 22rpx;
  background: #FFFFFF;
  border-radius: 18rpx;
  box-shadow: 0 2rpx 14rpx rgba(0, 0, 0, 0.04);
}

.quote-text {
  display: block;
  font-size: 31rpx;
  color: #5D4037;
  line-height: 1.72;
  font-weight: 650;
}

.quote-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #AEAEB2;
}

.quote-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.quote-btn {
  flex: 1;
  height: 70rpx;
  margin: 0;
  border-radius: 999rpx;
  background: #F5F5F7;
  color: #6B7280;
  font-size: 27rpx;
  font-weight: 650;
  line-height: 70rpx;
}

.quote-btn.primary {
  background: #1D1D1F;
  color: #FFFFFF;
}

.quote-btn::after {
  border: none;
}

.empty-state {
  min-height: 620rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 48rpx;
}

.empty-icon {
  width: 74rpx;
  height: 74rpx;
  opacity: 0.28;
  margin-bottom: 22rpx;
}

.empty-title {
  font-size: 31rpx;
  color: #1D1D1F;
  font-weight: 750;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8E8E93;
  line-height: 1.6;
}
