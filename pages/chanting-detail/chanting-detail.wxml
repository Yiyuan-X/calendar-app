<!--pages/chanting-detail/chanting-detail.wxml — 功课详情（标签页切换）-->
<view class="page {{elderMode ? 'elder-mode' : ''}}">
  <!-- 基本信息 -->
  <view class="info-card">
    <text class="info-name">{{task.name}}</text>
    <view class="info-meta">
      <text class="info-tag">{{task.unit}}</text>
      <text class="info-stat" wx:if="{{task.dailyTarget > 0}}">每日 {{task.dailyTarget}}{{task.unit}}</text>
      <text class="info-stat" wx:if="{{task.totalTarget > 0}}">总目标 {{task.totalTarget}}{{task.unit}}</text>
      <text class="info-stat" wx:if="{{task.dailyTarget === 0 && task.totalTarget === 0}}">不限量</text>
    </view>

    <!-- 目标设置 -->
    <view class="target-setting {{highlightTarget ? 'target-setting-highlight' : ''}}">
      <view class="ts-label"><image class="inline-icon" src="/images/icons/gen-gear.svg" mode="aspectFit"></image><text>目标设置</text></view>
      <view class="combo-target-wrap" wx:if="{{task.comboId}}">
        <view class="combo-target-row">
          <text class="ts-name combo-target-name">组合总目标</text>
          <input class="ts-input combo-target-input" type="number" placeholder="如 100" value="{{editComboGroupTarget}}" bindinput="onComboGroupTargetInput" bindconfirm="saveTargets" />
          <text class="ts-unit">组</text>
        </view>
        <view class="combo-target-row combo-daily-row">
          <text class="ts-name combo-target-name">组合每日目标</text>
          <input class="ts-input combo-target-input" type="number" placeholder="不限" value="{{editComboDailyGroupTarget}}" bindinput="onComboDailyGroupTargetInput" bindconfirm="saveTargets" />
          <text class="ts-unit">组</text>
        </view>
        <view class="combo-preview-mini">
          <text wx:for="{{comboPreview}}" wx:key="key">{{item.name}} {{item.target}}{{item.unit}}</text>
        </view>
        <view class="combo-preview-mini combo-preview-daily" wx:if="{{comboDailyPreview.length > 0}}">
          <text wx:for="{{comboDailyPreview}}" wx:key="key">每日 {{item.name}} {{item.target}}{{item.unit}}</text>
        </view>
        <view class="combo-progress-mini" wx:if="{{comboProgressText}}">
          <text>{{comboProgressText}}</text>
          <text wx:if="{{comboTodayProgressText}}">{{comboTodayProgressText}}</text>
        </view>
      </view>
      <view class="ts-row {{task.comboId ? 'combo-item-target-row' : ''}}">
        <view class="ts-item" wx:if="{{!task.comboId}}">
          <text class="ts-name">每日目标</text>
          <input class="ts-input" type="number" placeholder="不限" value="{{editDailyTarget}}" bindinput="onDailyTargetInput" bindconfirm="saveDailyTarget" />
          <text class="ts-unit">{{task.unit}}</text>
        </view>
        <view class="ts-item" wx:else>
          <text class="ts-name">本项每日目标</text>
          <text class="combo-total-readonly">{{editDailyTarget || '不限'}}{{editDailyTarget ? task.unit : ''}}</text>
        </view>
        <view class="ts-divider"></view>
        <view class="ts-item" wx:if="{{!task.comboId}}">
          <text class="ts-name">总目标</text>
          <input class="ts-input" type="number" placeholder="不限" value="{{editTotalTarget}}" bindinput="onTotalTargetInput" bindconfirm="saveTotalTarget" />
          <text class="ts-unit">{{task.unit}}</text>
        </view>
        <view class="ts-item" wx:else>
          <text class="ts-name">本项总目标</text>
          <text class="combo-total-readonly">{{editTotalTarget || 0}}{{task.unit}}</text>
        </view>
      </view>
      <view class="ts-save-row">
        <view class="ts-save-btn" catchtap="saveTargets"><text>保存目标</text></view>
      </view>
    </view>

    <!-- 达标状态 -->
    <view class="badge-done" wx:if="{{isDailyDone}}">
      <image class="badge-icon" src="/images/icons/gen-check.svg" mode="aspectFit"></image><text>今日已达标</text>
    </view>
    <view class="badge-done badge-total-done" wx:if="{{isTotalDone}}">
      <image class="badge-icon" src="/images/icons/gen-trophy.svg" mode="aspectFit"></image><text>总目标已完成</text>
    </view>

    <!-- 统计 -->
    <view class="stats-row">
      <view class="stat-box">
        <text class="stat-num purple number-display">{{total}}</text>
        <text class="stat-label">总{{task.unit}}数</text>
      </view>
      <view class="stat-box">
        <text class="stat-num green number-display">{{streak}}</text>
        <text class="stat-label">连续天数</text>
      </view>
      <view class="stat-box">
        <text class="stat-num orange number-display">{{todayCount}}</text>
        <text class="stat-label">今日</text>
      </view>
    </view>
  </view>

  <!-- 标签页导航 -->
  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === 'count' ? 'tab-active' : ''}}"
      data-tab="count"
      catchtap="switchTab"
    >
      <text>报数</text>
    </view>
    <view
      class="tab-item {{activeTab === 'supplement' ? 'tab-active' : ''}}"
      data-tab="supplement"
      catchtap="switchTab"
    >
      <text>补录</text>
    </view>
    <view
      class="tab-item {{activeTab === 'wish' ? 'tab-active' : ''}}"
      data-tab="wish"
      catchtap="switchTab"
    >
      <text>发愿</text>
    </view>
    <view
      class="tab-item {{activeTab === 'note' ? 'tab-active' : ''}}"
      data-tab="note"
      catchtap="switchTab"
    >
      <text>备注</text>
    </view>
    <view
      class="tab-item {{activeTab === 'records' ? 'tab-active' : ''}}"
      data-tab="records"
      catchtap="switchTab"
    >
      <text>记录</text>
    </view>
  </view>

  <!-- 标签页内容：报数 -->
  <view class="tab-panel" wx:if="{{activeTab === 'count'}}">
    <view class="card">
      <view class="quick-row">
        <view class="q-btn q-btn-1" catchtap="onQuick" data-n="{{quickButtons[0]}}"><text>+{{quickButtons[0]}}</text></view>
        <view class="q-btn q-btn-10" catchtap="onQuick" data-n="{{quickButtons[1]}}"><text>+{{quickButtons[1]}}</text></view>
        <view class="q-btn q-btn-100" catchtap="onQuick" data-n="{{quickButtons[2]}}"><text>+{{quickButtons[2]}}</text></view>
      </view>
      <view class="manual-row">
        <input class="m-input" type="number" placeholder="手动输入数量" value="{{manualNum}}" bindinput="onManualInput"/>
        <view class="m-btn" catchtap="onManualSubmit"><text>确认</text></view>
      </view>
    </view>
  </view>

  <!-- 标签页内容：补录 -->
  <view class="tab-panel" wx:if="{{activeTab === 'supplement'}}">
    <view class="card">
      <view class="supplement-area">
        <picker mode="date" value="{{suppDate}}" bindchange="onDatePick" end="{{todayStr}}">
          <view class="s-date">{{suppDate || '选择日期'}}</view>
        </picker>
        <input class="s-input" type="number" placeholder="数量" value="{{suppNum}}" bindinput="onSuppInput"/>
        <view class="s-btn" catchtap="onSuppSubmit"><text>补录</text></view>
      </view>
    </view>
  </view>

  <!-- 标签页内容：发愿 -->
  <view class="tab-panel" wx:if="{{activeTab === 'wish'}}">
    <view class="card textarea-wrap">
      <text class="t-label">今日发愿</text>
      <textarea
        class="t-editor"
        placeholder="写下今日的一句发愿..."
        value="{{detail.wish || ''}}"
        bindinput="onWishInput"
        auto-height
        maxlength="100"
      ></textarea>
      <view class="t-footer"><text class="t-save" catchtap="saveWish">保存</text></view>
    </view>
  </view>

  <!-- 标签页内容：备注 -->
  <view class="tab-panel" wx:if="{{activeTab === 'note'}}">
    <view class="card textarea-wrap">
      <textarea
        class="t-editor"
        placeholder="今日修行感受..."
        value="{{detail.note || ''}}"
        bindinput="onNoteInput"
        auto-height
        maxlength="300"
      ></textarea>
      <view class="t-footer"><text class="t-save" catchtap="saveNote">保存</text></view>
    </view>
  </view>

  <!-- 标签页内容：最近记录 -->
  <view class="tab-panel" wx:if="{{activeTab === 'records'}}">
    <view class="card">
      <scroll-view scroll-y style="max-height:500rpx;">
        <view class="record-list">
          <!-- 可编辑/可删除的记录项 -->
          <view class="r-row" wx:for="{{recentRecords}}" wx:key="date">
            <view class="r-item {{editingIndex === index ? 'r-item-editing' : ''}}" bindtap="onRecordTap" data-index="{{index}}" data-date="{{item.date}}" data-count="{{item.count}}">
              <text class="r-date">{{item.date}}</text>
              <!-- 点击后变为输入框 -->
              <block wx:if="{{editingIndex === index}}">
                <input class="r-input" type="number" value="{{editCount}}" focus="{{editingIndex === index}}" bindinput="onEditCountInput" bindconfirm="saveEditCount" bindblur="saveEditCount" data-index="{{index}}" />
              </block>
              <block wx:else>
                <text class="r-count">{{item.count}}</text><text class="r-unit">{{task.unit}}</text>
              </block>
            </view>
            <!-- 删除按钮（始终显示） -->
            <view class="r-del-btn" catchtap="onDeleteRecord" data-index="{{index}}" data-date="{{item.fullDate || item.date}}">
              <image class="r-del-icon" src="/images/icons/gen-cross.svg" mode="aspectFit"></image>
            </view>
          </view>
          <view wx:if="{{recentRecords.length === 0}}" class="r-empty">暂无记录</view>
        </view>
      </scroll-view>
    </view>
    <view class="r-tip" wx:if="{{recentRecords.length > 0}}"><text>点击数字可修改 · 点 ✕ 删除</text></view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <view class="ab-btn ab-focus" bindtap="goFocus"><text>专注模式</text></view>
    <view class="ab-btn ab-del" bindtap="onDelete"><text>删除功课</text></view>
  </view>

  <view class="bottom-pad safe-area-bottom"></view>
</view>
