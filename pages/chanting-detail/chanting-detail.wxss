/* 功课详情页 */
.page { min-height:100vh; background:#F5F5F7; padding:0 24rpx; }

/* 顶部提示语 */
.detail-tip { font-size: 25rpx; color: #A1887F; text-align: center; padding: 20rpx 10rpx; line-height: 1.5; }

/* 头部信息 */
.info-card { background:#fff; border-radius:20rpx; padding:28rpx; margin-top:20rpx; box-shadow:0 2rpx 12rpx rgba(0,0,0,.03); }
.info-name { font-size: 37rpx; font-weight:700; color:#1D1D1F; margin-bottom:6rpx; }
.info-meta { display:flex; gap:20rpx; flex-wrap:wrap; }
.info-tag { font-size: 25rpx; color:#E68A00; background:rgba(255,179,0,.12); padding:4rpx 14rpx; border-radius:8rpx; }
.info-stat { font-size: 25rpx; color:#AEAEB2; }

/* 目标设置 */
.target-setting { background: linear-gradient(135deg, #FFF8E1 0%, #FFFBF0 100%); border-radius: 16rpx; padding: 24rpx 28rpx; margin-top: 16rpx; border: 1.5rpx solid rgba(255, 179, 0, 0.2); }
.target-setting-highlight { background: linear-gradient(135deg, #FFF3D6 0%, #FFEFC7 100%); border: 2rpx solid rgba(255, 179, 0, 0.45); box-shadow: 0 4rpx 20rpx rgba(255, 179, 0, 0.15); }
.ts-label { font-size: 28rpx; font-weight: 600; color: #5D4037; margin-bottom: 18rpx; display: flex; align-items: center; gap: 10rpx; }
.inline-icon { width: 30rpx; height: 30rpx; flex-shrink: 0; }
.ts-row { display: flex; align-items: center; gap: 16rpx; }
.ts-item { flex: 1; display: flex; align-items: center; gap: 8rpx; }
.ts-name { font-size: 25rpx; color: #A1887F; white-space: nowrap; width: 100rpx; }
.ts-input { flex: 1; height: 68rpx; background: #FFFFFF; border-radius: 12rpx; padding: 0 16rpx; font-size: 30rpx; color: #1D1D1F; text-align: center; box-sizing: border-box; border: 1.5rpx solid rgba(0, 0, 0, 0.06); }
.ts-unit { font-size: 25rpx; color: #A1887F; white-space: nowrap; }
.ts-divider { width: 1.5rpx; height: 52rpx; background: rgba(255, 179, 0, 0.25); border-radius: 1rpx; }
.ts-save-row { margin-top: 20rpx; display: flex; justify-content: center; }
.ts-save-btn { padding: 14rpx 56rpx; background: linear-gradient(135deg, #FFB300, #FF8F00); border-radius: 30rpx; display: inline-flex; align-items: center; justify-content: center; line-height: 1; box-shadow: 0 4rpx 12rpx rgba(255, 143, 0, 0.3); }
.ts-save-btn text { color: #fff; font-size: 28rpx; font-weight: 600; letter-spacing: 1rpx; }

/* 达标标记 */
.badge-done { background:linear-gradient(135deg,#E8F5E9,#C8E6C9); border-radius:12rpx; padding:12rpx 24rpx; margin-top:14rpx; display:flex; align-items:center; justify-content:center; gap:8rpx; }
.badge-done text { font-size: 26rpx; color:#2E7D32; font-weight:600; }
.badge-icon { width:28rpx; height:28rpx; flex-shrink:0; }
.badge-total-done { background:linear-gradient(135deg,#FFF8E1,#FFECB3); }
.badge-total-done text { color:#E65100; }

/* 统计概览 */
.stats-row { display:flex; gap:12rpx; margin-top:20rpx; }
.stat-box { flex:1; background:#FAFAFA; border-radius:14rpx; padding:18rpx 12rpx; text-align:center; }
.stat-num { font-size: 36rpx; font-weight:750; color:#1D1D1F; font-family:-apple-system,'SF Pro Display',sans-serif; }
.stat-num.purple { color:#FFB300; }
.stat-num.green { color:#34C759; }
.stat-num.orange { color:#FF9500; }
.stat-label { font-size: 24rpx; color:#AEAEB2; margin-top:4rpx; }

/* 分区标题 */
.section { margin-top:24rpx; }
.section-title { font-size: 29rpx; font-weight:600; color:#1D1D1F; margin-bottom:14rpx; display:flex; align-items:center; gap:8rpx; }
.section-title-icon { width:30rpx; height:30rpx; flex-shrink:0; }

/* 卡片通用 */
.card { background:#fff; border-radius:18rpx; padding:24rpx; box-shadow:0 2rpx 10rpx rgba(0,0,0,.03); }

/* 快捷报数 */
.quick-row { display:flex; gap:14rpx; margin-bottom:16rpx; }
.q-btn { flex:1; height:64rpx; border-radius:12rpx; display:flex;align-items:center;justify-content:center; line-height:1; font-size: 27rpx; font-weight:600; color:#fff; }
.q-btn::after { border:none; }
.q-btn-1 { background:linear-gradient(135deg,#FFD54F,#FFB300); box-shadow:0 4rpx 14rpx rgba(255,179,0,.22); }
.q-btn-10 { background:linear-gradient(135deg,#FFB300,#FF9800); box-shadow:0 4rpx 14rpx rgba(255,152,0,.24); }
.q-btn-100 { background:linear-gradient(135deg,#FFA000,#F57C00); box-shadow:0 4rpx 14rpx rgba(245,124,0,.24); }
.q-btn:active { transform:scale(.96); opacity:.85; }

.manual-row { display:flex; gap:12rpx; align-items:center; }
.m-input { flex:1; height:80rpx; background:#F5F5F7; border-radius:14rpx; padding:0 20rpx; font-size: 30rpx; color:#1D1D1F; box-sizing:border-box; }
.m-btn { width:140rpx; height:80rpx; border-radius:14rpx; background:linear-gradient(135deg,#FFB300,#FF8F00); color:#fff; font-size: 28rpx; font-weight:600; display:flex;align-items:center;justify-content:center; line-height:1; letter-spacing:2rpx; box-shadow:0 4rpx 14rpx rgba(255,143,0,.22); }
.m-btn::after { border:none; }

/* 补录 */
.supplement-area { display:flex; gap:12rpx; align-items:center; }
.s-date { flex:1; height:76rpx; background:#F5F5F7; border-radius:14rpx; padding:0 20rpx; font-size: 28rpx; color:#1D1D1F; box-sizing:border-box; }
.s-input { width:160rpx; height:76rpx; background:#F5F5F7; border-radius:14rpx; padding:0 16rpx; font-size: 28rpx; text-align:center; color:#1D1D1F; box-sizing:border-box; }
.s-btn { width:120rpx; height:76rpx; border-radius:14rpx; background:#FF9500; color:#fff; font-size: 26rpx; font-weight:600; display:flex;align-items:center;justify-content:center; line-height:1; }
.s-btn::after { border:none; }

/* 发愿/备注 */
.textarea-wrap { margin-top:8rpx; }
.t-label { font-size: 26rpx; font-weight:600; color:#3C3C43; margin-bottom:10rpx; display:flex; align-items:center; gap:6rpx; }
.t-editor { width:100%; min-height:120rpx; background:#F5F5F7; border-radius:14rpx; padding:18rpx 20rpx; font-size: 28rpx; color:#1D1D1F; box-sizing:border-box; line-height:1.6; }
.t-footer { display:flex; justify-content:flex-end; padding-top:12rpx; }
.t-save { font-size: 30rpx; color:#E68A00; font-weight:700; padding:12rpx 28rpx; display:inline-flex; align-items:center; justify-content:center; line-height:1; background:rgba(255,179,0,.1); border-radius:20rpx; }

/* 最近记录 */
.record-list { display:flex; flex-direction:column; gap:8rpx; max-height:400rpx; overflow-y:auto; }
.r-item { display:flex; align-items:center; justify-content:space-between; padding:14rpx 16rpx; background:#FAFAFA; border-radius:12rpx; }
.r-date { font-size: 26rpx; color:#3C3C43; font-weight:500; }
.r-count { font-size: 30rpx; font-weight:700; color:#FF9800; }
.r-unit { font-size: 24rpx; color:#AEAEB2; }

/* 操作按钮 */
.action-bar { margin:32rpx 0; display:flex; gap:16rpx; }
.ab-btn { flex:1; height:88rpx; border-radius:16rpx; font-size: 30rpx; font-weight:600; display:flex;align-items:center;justify-content:center; line-height:1; letter-spacing:2rpx; }
.ab-btn::after { border:none; }
.ab-focus { background:linear-gradient(135deg,#FFD54F,#FF9800); color:#5D3500; box-shadow:0 4rpx 16rpx rgba(255,152,0,.26); }
.ab-del { background:#FFF0F0; color:#FF3B30; }

/* 标签页导航 */
.tab-bar { display: flex; background: #fff; border-radius: 16rpx; padding: 6rpx; margin-top: 20rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,.03); }
.tab-item { flex: 1; text-align: center; padding: 16rpx 0; border-radius: 12rpx; font-size: 27rpx; font-weight: 500; color: #AEAEB2; transition: all .2s ease; }
.tab-item:active { opacity: .7; }
.tab-active { background: linear-gradient(135deg, #FFD54F, #FFB300); color: #5D3500; font-weight: 700; box-shadow: 0 2rpx 8rpx rgba(255,179,0,.25); }

/* 标签页内容 */
.tab-panel { margin-top: 20rpx; animation: fadeIn .2s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8rpx); } to { opacity: 1; transform: translateY(0); } }

/* 最近记录空状态 */
.r-empty { padding: 50rpx 0; text-align: center; color: #AEAEB2; font-size: 26rpx; }

.bottom-pad { height:40rpx; }
