<!--pages/index/index.wxml — 首页：节日 + 倒计时 + 金句-->
<view class="page-container {{elderMode ? 'elder-mode' : ''}}">
  <!-- 顶部：今日信息 + 金句（左右布局） -->
  <view class="header-section">
    <view class="header-top-row">
      <!-- 左侧：日期信息 -->
      <view class="header-left">
        <view class="today-header">
          <text class="today-date">{{todayInfo.year}}年{{todayInfo.month}}月{{todayInfo.day}}日</text>
          <text class="today-lunar">{{todayInfo.lunarMonth}}{{todayInfo.lunarDay}}</text>
          <text class="today-ganzhi" wx:if="{{todayInfo.ganzhiYear}}"> {{todayInfo.ganzhiYear}}年</text>
        </view>
        <!-- 今日节日标签 -->
        <view class="festival-tags-row" wx:if="{{todayFestivals.length > 0}}">
          <view class="festival-tag {{item.tagClass}}" wx:for="{{todayFestivals}}" wx:key="name">
            {{item.name}}
          </view>
        </view>
      </view>
      <!-- 右侧：每日金句 -->
      <view class="header-quote">
        <text
          class="quote-text-inline"
          wx:for="{{dailyQuoteLines}}"
          wx:key="*this"
        >{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 节气养生卡片（图1简洁风格） -->
  <view class="sth2-card" wx:if="{{todaySolarTermHealth}}">
    <view class="sth2-title-row">
      <image class="sth2-icon" src="/images/icons/leaf.svg" mode="aspectFit"></image>
      <text class="sth2-name">{{todaySolarTermName}}</text>
    </view>
    <text class="sth2-period" wx:if="{{todaySolarTermPeriod}}">{{todaySolarTermPeriod}}</text>
    <text class="sth2-desc">{{todaySolarTermHealth.desc}}</text>
    <text class="sth2-text">{{todaySolarTermHealth.health}}</text>
    <text class="sth2-text">{{todaySolarTermHealth.diet}}</text>
    <view class="sth2-tip"><text>{{todaySolarTermHealth.tip}}</text></view>
    <view class="daily-tip-inline" wx:if="{{dailyVegetarianTip}}">
      <text class="daily-tip-label">今日推荐</text>
      <text class="daily-tip-text">{{dailyVegetarianTip}}</text>
    </view>
  </view>

  <!-- 当前节气（非当天）的简短提示 -->
  <view class="sth2-card sth2-mini" wx:elif="{{currentSolarTermName}}">
    <view class="sth2-title-row">
      <image class="sth2-icon" src="/images/icons/leaf.svg" mode="aspectFit"></image>
      <text class="sth2-name">当前节气：{{currentSolarTermName}}</text>
    </view>
    <text class="sth2-period" wx:if="{{currentSolarTermPeriod}}">{{currentSolarTermPeriod}}</text>
    <view class="sth2-tip" wx:if="{{currentSolarTermTip}}"><text>{{currentSolarTermTip}}</text></view>
    <view class="daily-tip-inline" wx:if="{{dailyVegetarianTip}}">
      <text class="daily-tip-label">今日推荐</text>
      <text class="daily-tip-text">{{dailyVegetarianTip}}</text>
    </view>
  </view>

  <!-- 重要日子倒计时（展示名称 + 目标日期） -->
  <view class="section-block">
    <view class="section-header">
      <text class="section-title">重要日子</text>
      <view class="add-btn-small" bindtap="goToAddEventWithDate">
        <text>+</text>
      </view>
    </view>

    <view class="events-list" wx:if="{{upcomingEvents.length > 0}}">
      <view
        class="event-item"
        wx:for="{{upcomingEvents}}"
        wx:key="id"
        data-event="{{item}}"
        bindlongpress="onDeleteEvent"
        bindtap="goToEditEvent"
      >
        <view class="event-main">
          <view class="event-top-row">
            <view class="event-dot {{item.dotClass}}"></view>
            <text class="event-name">{{item.name}}</text>
            <text class="event-category-tag">{{item.categoryName}}</text>
          </view>
          <view class="event-bottom-row">
            <text class="event-target-date">{{item.displayDate}}</text>
            <view class="event-countdown-area">
              <text class="event-subtitle {{item.isCountdown ? '' : 'past'}}">{{item.subtitleText}}</text>
              <text class="event-days {{!item.isCountdown ? 'past' : ''}}">{{item.daysAway}}</text>
              <text class="event-unit">天</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-add-area" wx:else bindtap="goToAddEvent">
      <text class="add-icon-large">+</text>
      <text class="add-text">添加重要日子</text>
    </view>
  </view>

  <!-- 近期日子（列表式：展示节日名称 + 类型 + 描述） -->
  <view class="section-block" wx:if="{{upcomingFestivals.length > 0}}">
    <view class="section-header">
      <text class="section-title">近期日子</text>
    </view>

    <view class="festivals-list-v">
      <view
        class="festival-card {{item.chipColor}}"
        wx:for="{{upcomingFestivals}}"
        wx:key="index"
        data-festival="{{item}}"
        bindtap="goToFestivalDetail"
      >
        <view class="fc-left">
          <view class="fc-date-box">
            <text class="fc-month">{{item.festMonth}}</text>
            <text class="fc-day">{{item.festDay}}</text>
          </view>
        </view>

        <view class="fc-right">
          <view class="fc-name-row">
            <view class="fc-title-group">
              <text class="fc-name">{{item.displayName}}</text>
              <text class="fc-type-tag" wx:if="{{item.typeLabel}}">{{item.typeLabel}}</text>
            </view>
            <view class="festival-countdown-area {{item.countdownClass}}">
              <text class="festival-countdown-prefix">{{item.countdownPrefix}}</text>
              <text class="festival-countdown-days" wx:if="{{item.countdownDays}}">{{item.countdownDays}}</text>
              <text class="festival-countdown-unit" wx:if="{{item.countdownUnit}}">{{item.countdownUnit}}</text>
            </view>
          </view>
          <text class="fc-desc" wx:if="{{item.displayDesc}}">{{item.displayDesc}}</text>
          <text class="fc-desc fc-desc-alt" wx:elif="{{item.lunarDateText}}">{{item.lunarDateText}}</text>
        </view>
      </view>
    </view>
  </view>


  <!-- 功能操作区：功过格 + 显示设置（并排醒目卡片） -->
  <view class="action-row">
    <view class="action-card merit-entry" bindtap="goToMerit">
      <image class="action-icon-img action-tab-icon" src="/images/merit.png" mode="aspectFit"></image>
      <view class="action-info">
        <text class="action-title">功过格</text>
        <text class="action-subtitle">了凡四训 · 善恶行记录</text>
      </view>
      <view class="action-badge {{meritTodayNet !== null ? (meritTodayNet >= 0 ? 'badge-positive' : 'badge-negative') : 'badge-empty'}}" wx:if="{{meritTodayNet !== null}}">
        <text>{{meritTodayNet >= 0 ? '+' : ''}}{{meritTodayNet}}</text>
      </view>
      <text class="action-arrow">›</text>
    </view>

    <view class="action-card settings-entry-prominent" bindtap="goToSettings">
      <view class="settings-icon-circle">
        <image class="settings-icon-img2" src="/images/icons/settings.svg" mode="aspectFit"></image>
      </view>
      <view class="action-info">
        <text class="action-title">显示设置</text>
        <text class="action-subtitle">自定义节日 · 节气等</text>
      </view>
      <text class="action-arrow">›</text>
    </view>
  </view>

  <!-- 分享操作栏 -->
  <view class="share-bar">
    <button class="share-btn share-btn-primary" open-type="share">
      <image class="share-btn-icon" src="/images/icons/share-wechat.svg" mode="aspectFit"></image>
      <text class="share-btn-text">一键分享</text>
    </button>
    <button class="share-btn share-btn-primary" bindtap="shareToMoments">
      <image class="share-btn-icon" src="/images/icons/share-moments.svg" mode="aspectFit"></image>
      <text class="share-btn-text">朋友圈</text>
    </button>
    <button class="share-btn share-btn-save" bindtap="saveImage">
      <image class="share-btn-icon" src="/images/icons/save.svg" mode="aspectFit"></image>
      <text class="share-btn-text">保存</text>
    </button>
  </view>

  <!-- 底部签名 -->
  <view class="footer-signature">
    <text>岁时记 · 记录时光</text>
  </view>

  <!-- 隐藏的 Canvas（用于生成分享海报） -->
  <canvas type="2d" id="shareCanvas" style="position:fixed;left:-9999px;top:-9999px;width:500px;height:750px;"></canvas>
</view>
