<!--pages/index/index.wxml — 首页：节日 + 倒计时 + 金句-->
<view class="page-container {{elderMode ? 'elder-mode' : ''}}">
  <!-- 顶部：今日信息 + 金句（左右布局） -->
  <view class="header-section">
    <view class="header-top-row">
      <!-- 左侧：日期信息 -->
      <view class="header-left">
        <view class="today-header">
          <text class="today-date">{{todayInfo.year}}年{{todayInfo.month}}月{{todayInfo.day}}日</text>
          <text class="today-lunar">农历{{todayInfo.lunarMonth}}{{todayInfo.lunarDay}}</text>
          <text class="today-ganzhi" wx:if="{{todayInfo.ganzhiYear}}">{{todayInfo.ganzhiYear}}年</text>
        </view>
        <!-- 今日节日标签 -->
        <view class="festival-tags-row" wx:if="{{todayFestivals.length > 0}}">
          <view class="festival-tag {{item.tagClass}}" wx:for="{{todayFestivals}}" wx:key="name">
            {{item.name}}
          </view>
        </view>
      </view>
      <!-- 右侧：每日金句 -->
      <view class="header-quote" bindtap="onDailyQuoteTap">
        <text
          class="quote-text-inline"
          wx:for="{{dailyQuoteLines}}"
          wx:key="*this"
        >{{item}}</text>
        <view class="quote-actions">
          <view class="quote-action {{dailyQuoteFavorited ? 'active' : ''}}" catchtap="toggleDailyQuoteFavorite">
            <image class="quote-action-icon" src="/images/icons/heart.svg" mode="aspectFit"></image>
            <text>{{dailyQuoteFavorited ? '已收藏' : '收藏'}}</text>
          </view>
          <view class="quote-action" catchtap="showDailySignOptions">
            <image class="quote-action-icon" src="/images/icons/gen-camera.svg" mode="aspectFit"></image>
            <text>今日签图</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 节气养生卡片（默认折叠：只显示推荐摘要两行） -->
  <view class="sth2-card {{stExpanded ? 'sth2-expanded' : ''}}" wx:if="{{showDailyRecommendCard}}" bindtap="toggleStExpand">
    <view class="sth2-recommend-row">
      <text class="sth2-recommend-label">今日推荐</text>
      <text class="sth2-toggle-icon">{{stExpanded ? '收起' : '展开'}}</text>
    </view>
    <text class="sth2-recommend-summary">{{dailyRecommendText}}</text>
    <view class="sth2-meta-row sth2-meta-collapsed" wx:if="{{dailyRecommendTermName || dailyRecommendTermPeriod}}">
      <image class="sth2-icon" src="/images/icons/leaf.svg" mode="aspectFit"></image>
      <text class="sth2-name">{{dailyRecommendTermName}}</text>
      <text class="sth2-period-inline" wx:if="{{dailyRecommendTermPeriod}}">{{dailyRecommendTermPeriod}}</text>
    </view>

    <!-- 折叠内容：点击展开后显示 -->
    <view class="sth2-detail" wx:if="{{stExpanded}}">
      <text class="sth2-desc" wx:if="{{todaySolarTermHealth && todaySolarTermHealth.desc}}">{{todaySolarTermHealth.desc}}</text>
      <text class="sth2-text" wx:if="{{todaySolarTermHealth && todaySolarTermHealth.health}}">{{todaySolarTermHealth.health}}</text>
      <text class="sth2-text" wx:if="{{todaySolarTermHealth && todaySolarTermHealth.diet}}">{{todaySolarTermHealth.diet}}</text>
      <view class="sth2-tip" wx:if="{{todaySolarTermHealth && todaySolarTermHealth.tip}}"><text>{{todaySolarTermHealth.tip}}</text></view>
      <view class="sth2-tip" wx:if="{{currentSolarTermTip}}"><text>{{currentSolarTermTip}}</text></view>
    </view>
  </view>

  <!-- 重要日子倒计时（展示名称 + 目标日期） -->
  <view class="section-block">
    <view class="section-header">
      <text class="section-title">重要日子</text>
      <view class="add-btn-small" bindtap="goToAddEventWithDate">
        <text>添加</text>
      </view>
    </view>

    <view class="events-list" wx:if="{{upcomingEvents.length > 0}}">
      <view
        class="event-item"
        wx:for="{{upcomingEvents}}"
        wx:key="id"
        data-event="{{item}}"
        bindlongpress="onDeleteEvent"
        bindtap="goToEditEvent"
      >
        <view class="event-main">
          <view class="event-top-row">
            <view class="event-dot {{item.dotClass}}"></view>
            <text class="event-name">{{item.name}}</text>
            <text class="event-category-tag">{{item.categoryName}}</text>
          </view>
          <view class="event-bottom-row">
            <text class="event-target-date">{{item.displayDate}}</text>
            <view class="event-countdown-area">
              <text class="event-subtitle {{item.isCountdown ? '' : 'past'}}">{{item.subtitleText}}</text>
              <text class="event-days {{!item.isCountdown ? 'past' : ''}}">{{item.daysAway}}</text>
              <text class="event-unit">天</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-add-area" wx:else bindtap="goToAddEvent">
      <text class="add-icon-large">+</text>
      <text class="add-text">添加重要日子</text>
    </view>
  </view>

  <!-- 近期节日（列表式：默认显示3条，点击展开更多） -->
  <view class="section-block" wx:if="{{upcomingFestivals.length > 0}}">
    <view class="section-header">
      <text class="section-title">近期节日</text>
      <text class="festivals-toggle-btn" wx:if="{{festivalsMoreCount > 0}}" bindtap="toggleFestivalsExpand">
        {{festivalsExpanded ? '收起' : '显示更多近期节日 (' + festivalsMoreCount + ')'}}
      </text>
    </view>

    <view class="festivals-list-v">
      <view
        class="festival-card {{item.chipColor}}"
        wx:for="{{festivalsExpanded ? upcomingFestivals : upcomingFestivals.slice(0, 3)}}"
        wx:key="index"
        data-festival="{{item}}"
        bindtap="goToFestivalDetail"
      >
        <view class="fc-left">
          <view class="fc-date-box">
            <text class="fc-month">{{item.festMonth}}</text>
            <text class="fc-day">{{item.festDay}}</text>
          </view>
        </view>

        <view class="fc-right">
          <view class="fc-name-row">
            <view class="fc-title-group">
              <text class="fc-name">{{item.displayName}}</text>
              <text class="fc-type-tag" wx:if="{{item.typeLabel}}">{{item.typeLabel}}</text>
            </view>
            <view class="festival-countdown-area {{item.countdownClass}}">
              <text class="festival-countdown-prefix">{{item.countdownPrefix}}</text>
              <text class="festival-countdown-days" wx:if="{{item.countdownDays}}">{{item.countdownDays}}</text>
              <text class="festival-countdown-unit" wx:if="{{item.countdownUnit}}">{{item.countdownUnit}}</text>
            </view>
          </view>
          <text class="fc-desc" wx:if="{{item.displayDesc}}">{{item.displayDesc}}</text>
          <text class="fc-desc fc-desc-alt" wx:elif="{{item.lunarDateText}}">{{item.lunarDateText}}</text>
        </view>
      </view>
    </view>
  </view>


  <!-- 功能操作区：积善 + 显示设置（并排醒目卡片） -->
  <view class="action-row">
    <view class="action-card card-tool-action-entry" bindtap="goToCardTool">
      <image class="action-icon-img action-tab-icon" src="/images/icons/gen-camera.svg" mode="aspectFit"></image>
      <view class="action-info">
        <text class="action-title">禅意做图</text>
        <text class="action-subtitle">日签 · 节气 · 分享卡片</text>
      </view>
      <text class="action-arrow">›</text>
    </view>

    <view class="action-card settings-entry-prominent" bindtap="goToSettings">
      <view class="settings-icon-circle">
        <image class="settings-icon-img2" src="/images/icons/settings.svg" mode="aspectFit"></image>
      </view>
      <view class="action-info">
        <text class="action-title">显示设置</text>
        <text class="action-subtitle">使用说明，自定义长辈模式等</text>
      </view>
      <text class="action-arrow">›</text>
    </view>
  </view>

  <!-- 分享操作栏 -->
  <view class="share-bar">
    <view class="share-asset-grid">
      <button class="share-btn share-asset-btn" open-type="share" data-share-type="almanac">
        <image class="share-btn-icon" src="/images/icons/share-wechat.svg" mode="aspectFit"></image>
        <text class="share-btn-text">今日黄历</text>
      </button>
      <button class="share-btn share-asset-btn" open-type="share" data-share-type="quote">
        <image class="share-btn-icon" src="/images/icons/star.svg" mode="aspectFit"></image>
        <text class="share-btn-text">金句</text>
      </button>
      <button class="share-btn share-asset-btn" open-type="share" data-share-type="event">
        <image class="share-btn-icon" src="/images/icons/clock.svg" mode="aspectFit"></image>
        <text class="share-btn-text">纪念日</text>
      </button>
      <button class="share-btn share-asset-btn" open-type="share" data-share-type="practice">
        <image class="share-btn-icon" src="/images/icons/gen-chart.svg" mode="aspectFit"></image>
        <text class="share-btn-text">本月修心</text>
      </button>
    </view>
    <view class="share-poster-actions">
      <button class="share-btn share-btn-primary" bindtap="shareToMoments">
        <image class="share-btn-icon" src="/images/icons/share-moments.svg" mode="aspectFit"></image>
        <text class="share-btn-text">朋友圈</text>
      </button>
      <button class="share-btn share-btn-save" bindtap="saveImage">
        <image class="share-btn-icon" src="/images/icons/save.svg" mode="aspectFit"></image>
        <text class="share-btn-text">保存</text>
      </button>
    </view>
  </view>

  <!-- 底部签名 -->
  <view class="footer-signature">
    <text>岁时记 · 记录时光</text>
  </view>

  <!-- 隐藏的 Canvas（用于生成分享海报） -->
  <canvas type="2d" id="shareCanvas" style="position:fixed;left:-9999px;top:-9999px;width:500px;height:750px;"></canvas>
</view>
