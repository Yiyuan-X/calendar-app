/* pages/index/index.wxss — 首页样式（全面UI优化版） */

.page-container {
  min-height: 100vh;
  padding: 0 24rpx 40rpx;
  background: linear-gradient(180deg, #FFFDF7 0%, #F6F4EF 100%);
}

/* ==================== 顶部区域：日期 + 金句 ==================== */
.header-section {
  padding-top: 28rpx;
  margin-bottom: 4rpx;
}

.header-top-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.header-left {
  flex: 1 1 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
  align-items: flex-start;
}

.today-header {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  flex-wrap: wrap;
}

/* 日期（大标题，不换行） */
.today-date {
  font-size: 38rpx;
  font-weight: 800;
  color: #1D1D1F;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
}

/* 农历（第二行，带「农历」前缀） */
.today-lunar {
  display: inline;
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 600;
}

/* 干支年（独立一行显示） */
.today-ganzhi {
  display: block;
  font-size: 25rpx;
  color: #8B7355;
  font-weight: 500;
  margin-top: 2rpx;
}

/* 今日节日标签 */
.festival-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 6rpx;
}

.festival-tag {
  display: inline-flex;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.tag-trad { background: linear-gradient(135deg, #FFE5E5, #FFCDCD); color: #C0392B; }
.tag-buddha { background: linear-gradient(135deg, #F3E8FF, #E9D5FF); color: #7C3AED; }
.tag-solar { background: linear-gradient(135deg, #E5FAEF, #BBF7D0); color: #059669; }

/* 右侧金句 */
.header-quote {
  flex: 1 1 0;
  min-height: 120rpx;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  text-align: center;
  padding: 20rpx 16rpx 18rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 252, 244, 0.95), rgba(255, 247, 224, 0.55));
  border-left: 4rpx solid rgba(201, 144, 32, 0.4);
  border-radius: 0 18rpx 18rpx 0;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10px);
}

.header-quote::before {
  content: "“";
  position: absolute;
  left: 12rpx;
  top: 2rpx;
  font-size: 52rpx;
  line-height: 1;
  color: rgba(201, 144, 32, 0.2);
  font-family: Georgia, 'Times New Roman', serif;
}

/* 金句文字（正体、居中显示） */
.quote-text-inline {
  display: block;
  max-width: 100%;
  font-size: 32rpx;
  color: #956706;
  font-style: normal;
  line-height: 1.65;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  word-break: keep-all;
  overflow-wrap: break-word;
  text-align: center;
}

.quote-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: nowrap;
  gap: 12rpx;
  margin-top: 10rpx;
  white-space: nowrap;
}

.quote-action {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  height: 36rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.62);
  color: #9A6B00;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 36rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.quote-action.active {
  color: #C2410C;
  background: rgba(255, 237, 213, 0.82);
}

.quote-action-icon {
  width: 20rpx;
  height: 20rpx;
  flex-shrink: 0;
}

.elder-mode .header-quote {
  flex-basis: 0;
}

.elder-mode .header-quote .quote-text-inline {
  font-size: 34rpx !important;
}

/* ==================== 节气推荐卡：留白、柔和、日签感 ==================== */
.sth2-card {
  margin: 24rpx 0 28rpx;
  padding: 24rpx 26rpx 26rpx;
  background:
    radial-gradient(circle at 90% 18%, rgba(255, 255, 255, 0.52) 0, rgba(255, 255, 255, 0) 34%),
    linear-gradient(135deg, #FFF7DF 0%, #FFF1C7 58%, #F4F7E7 100%);
  border-radius: 24rpx;
  border-left: 5rpx solid rgba(255, 179, 0, 0.82);
  box-shadow: 0 8rpx 28rpx rgba(184, 134, 74, 0.1);
}

.sth2-recommend-row,
.sth2-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sth2-recommend-row {
  min-height: 38rpx;
  margin-bottom: 10rpx;
}

.sth2-meta-row {
  margin-top: 18rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(139, 105, 20, 0.09);
}

.sth2-meta-collapsed {
  margin-top: 18rpx;
  padding-top: 14rpx;
}

.sth2-recommend-label {
  flex-shrink: 0;
  color: #B8860B;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 0.5rpx;
}

.sth2-recommend-summary {
  display: -webkit-box;
  color: #5E5147;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.72;
  overflow: hidden;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  letter-spacing: 0.2rpx;
}

/* 叶子图标 — 缩小为精致的装饰性图标 */
.sth2-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.75;
  flex-shrink: 0;
}

/* 节气名称（大标题） */
.sth2-name {
  font-size: 27rpx;
  font-weight: 900;
  color: #5D4037;
  letter-spacing: 1rpx;
  font-family: -apple-system, 'PingFang SC', 'SF Pro Display', serif;
}

.sth2-period-inline {
  flex: 1;
  min-width: 0;
  color: #9A6B00;
  font-size: 24rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sth2-toggle-icon {
  margin-left: auto;
  color: rgba(154, 107, 0, 0.76);
  font-size: 23rpx;
  font-weight: 700;
  flex-shrink: 0;
  padding-left: 18rpx;
}

.sth2-detail {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(139, 105, 20, 0.1);
}

/* 节气日期范围 */
.sth2-period {
  display: block;
  font-size: 25rpx;
  color: #9A6B00;
  font-weight: 500;
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
  padding-left: 56rpx; /* 与名称左对齐 */
}

/* 节气简介（标准正文） */
.sth2-desc {
  display: block;
  font-size: 29rpx;
  color: #374151;
  line-height: 1.75;
  margin-bottom: 10rpx;
  text-align: justify;
}

/* 养生/饮食文字（稍小，层次分明） */
.sth2-text {
  display: block;
  font-size: 27rpx;
  color: #4B5563;
  line-height: 1.72;
  margin-bottom: 6rpx;
}

/* 金句提示条 */
.sth2-tip {
  margin-top: 14rpx;
  padding: 14rpx 18rpx;
  background: rgba(255, 255, 255, 0.65);
  border-radius: 14rpx;
  border-left: 4rpx solid rgba(255, 179, 0, 0.35);
}

.sth2-tip text {
  font-size: 26rpx;
  color: #8B6914;
  font-style: italic;
  line-height: 1.62;
  display: block;
}

/* 迷你节气卡片（非当天显示的简短版） */
.sth2-mini {
  padding: 18rpx 22rpx;
}

.sth2-mini .sth2-icon {
  width: 36rpx;
  height: 36rpx;
}

.sth2-mini .sth2-name {
  font-size: 28rpx;
  letter-spacing: 1rpx;
}

.sth2-mini .sth2-period {
  font-size: 24rpx;
  padding-left: 48rpx;
  margin-bottom: 6rpx;
}

/* ==================== 重要日子区块 ==================== */
.section-block {
  margin: 24rpx 0 14rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

/* 区块标题 */
.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
  letter-spacing: 1.5rpx;
}

.add-btn-small {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 6rpx 18rpx;
  background: linear-gradient(135deg, #FFF8E7, #FFECB3);
  border-radius: 999rpx;
  border: 1.5rpx solid rgba(255, 179, 0, 0.2);
  transition: background 0.15s, box-shadow 0.15s;
}

.add-btn-small:active {
  background: linear-gradient(135deg, #FFECB3, #FFE082);
  box-shadow: 0 2rpx 8rpx rgba(255, 179, 0, 0.15);
}

.add-btn-small text {
  font-size: 25rpx;
  color: #F59E0B;
  font-weight: 700;
  line-height: 1;
}

/* 事件列表 */
.events-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.event-item {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 3rpx 14rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s, box-shadow 0.15s;
}

.event-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.event-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.event-top-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.event-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-red { background: #FF3B30; }
.dot-blue { background: #FFB300; }
.dot-green { background: #34C759; }
.dot-orange { background: #FF9500; }
.dot-purple { background: #AF52DE; }

/* 事件名称（标准正文+） */
.event-name {
  font-size: 31rpx;
  font-weight: 700;
  color: #1F2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-category-tag {
  font-size: 24rpx;
  color: #FFF;
  background: #C7C7CC;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.event-bottom-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.event-target-date {
  font-size: 25rpx;
  color: #AEAEB2;
  font-weight: 400;
}

.event-countdown-area {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-left: auto;
}

.event-subtitle {
  font-size: 24rpx;
  color: #86868B;
  font-weight: 500;
}

.event-subtitle.past { color: #C7C7CC; }

/* 倒计时天数（醒目） */
.event-days {
  font-size: 34rpx;
  font-weight: 900;
  color: #F59E0B;
  letter-spacing: 0.5rpx;
}

.event-days.past { color: #C7C7CC; }

.event-unit {
  font-size: 24rpx;
  color: #86868B;
  font-weight: 500;
}

/* 空状态 */
.empty-add-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 40rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 3rpx 14rpx rgba(0, 0, 0, 0.04);
}

.add-icon-large {
  font-size: 48rpx;
  color: #C7C7CC;
  font-weight: 200;
  line-height: 1;
}

.add-text {
  font-size: 28rpx;
  color: #AEAEB2;
  font-weight: 500;
}

/* ==================== 近期节日卡片列表 ==================== */
.festivals-list-v {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.festival-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 22rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 3rpx 14rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s;
}

.festival-card:active { transform: scale(0.98); }

.fc-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.fc-date-box {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #F5F5F7;
  border-radius: 14rpx;
}

.fc-month {
  font-size: 24rpx;
  color: #86868B;
  font-weight: 600;
}

.fc-day {
  font-size: 30rpx;
  font-weight: 800;
  color: #1D1D1F;
  line-height: 1.2;
}

.fc-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.fc-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.fc-title-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  flex: 1;
}

/* 节日名称（标准正文+） */
.fc-name {
  font-size: 31rpx;
  font-weight: 700;
  color: #1F2937;
  flex: 0 1 auto;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.festival-countdown-area {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 4rpx;
  flex-shrink: 0;
  min-width: 112rpx;
}

.festival-countdown-prefix {
  font-size: 24rpx;
  color: #86868B;
  font-weight: 500;
}

.festival-countdown-days {
  font-size: 33rpx;
  font-weight: 900;
  color: #F59E0B;
  letter-spacing: 0.5rpx;
}

.festival-countdown-unit {
  font-size: 24rpx;
  color: #86868B;
  font-weight: 500;
}

.festival-countdown-area.fc-today .festival-countdown-prefix {
  color: #F59E0B;
  font-size: 27rpx;
  font-weight: 800;
}

.festival-countdown-area.fc-soon .festival-countdown-days {
  color: #FF9500;
}

.festival-countdown-area.fc-normal .festival-countdown-days {
  color: #F59E0B;
}

.fc-type-tag {
  font-size: 24rpx;
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.fc-desc {
  font-size: 26rpx;
  color: #86868B;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.fc-desc-alt {
  font-size: 25rpx;
  color: #AEAEB2;
}

/* ==================== 功能操作区：功过格 + 显示设置（并排醒目卡片） ==================== */
.action-row {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0 16rpx;
}

.action-card {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  box-shadow: 0 4rpx 18rpx rgba(109, 79, 48, 0.07);
  transition: transform 0.15s, box-shadow 0.15s;
  position: relative;
  overflow: hidden;
}

.action-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
}

/* 功过格/积善卡片 — 暖金色渐变，与整体风格协调 */
.merit-entry {
  background: linear-gradient(135deg, #D4A017 0%, #B8860B 50%, #CD853F 100%);
}

.card-tool-action-entry {
  background:
    radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.68) 0, rgba(255, 255, 255, 0) 34%),
    linear-gradient(135deg, #FFF5E3 0%, #F4DFC4 56%, #E8D0B2 100%);
  border: 1.5rpx solid rgba(184, 134, 74, 0.22);
  box-shadow: 0 5rpx 18rpx rgba(151, 105, 62, 0.12);
}

.card-tool-action-entry::before {
  content: '';
  position: absolute;
  right: -18rpx;
  bottom: -28rpx;
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: rgba(167, 126, 80, 0.08);
}

.card-tool-action-entry::after {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 16rpx;
  width: 72rpx;
  height: 2rpx;
  background: rgba(167, 126, 80, 0.22);
}

/* 显示设置卡片 — 更醒目的渐变背景 */
.settings-entry-prominent {
  background: linear-gradient(135deg, #FFF8E7 0%, #FFF1C7 100%);
  border: 1.5rpx solid rgba(255, 179, 0, 0.18);
}

.action-icon-img {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.action-tab-icon {
  opacity: 0.95;
}

.action-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
  flex: 1;
  margin-left: 14rpx;
}

.action-title {
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 0.5rpx;
}

.merit-entry .action-title {
  color: #FFFFFF;
}

.card-tool-action-entry .action-title {
  color: #6B4F39;
}

.settings-entry-prominent .action-title {
  color: #5D4037;
}

.action-subtitle {
  font-size: 24rpx;
  font-weight: 400;
  letter-spacing: 0.3rpx;
}

.merit-entry .action-subtitle {
  color: rgba(255, 255, 255, 0.5);
}

.card-tool-action-entry .action-subtitle {
  color: #A06F3F;
}

.settings-entry-prominent .action-subtitle {
  color: #9A6B00;
}

/* 功过格数值徽章 */
.action-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 44rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.action-badge text {
  font-size: 28rpx;
  font-weight: 900;
}

.badge-positive {
  background: rgba(52, 199, 89, 0.2);
}

.badge-positive text { color: #34C759; }

.badge-negative {
  background: rgba(255, 59, 48, 0.2);
}

.badge-negative text { color: #FF3B30; }

.badge-empty {
  background: transparent;
}

/* 箭头 */
.action-arrow {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.55);
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 6rpx;
}

.settings-entry-prominent .action-arrow {
  color: #D4A017;
}

.card-tool-action-entry .action-arrow {
  color: #B88655;
}

.draft-badge {
  position: absolute;
  top: 14rpx;
  right: 52rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #FFFFFF;
  background: #C94B3E;
  border-radius: 16rpx;
  padding: 0 8rpx;
}

.card-tool-action-entry .action-tab-icon {
  opacity: 0.82;
  filter: sepia(0.35) saturate(0.9) hue-rotate(350deg);
}

/* 设置图标圆形背景 */
.settings-icon-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB300, #FF8F00);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 3rpx 12rpx rgba(255, 179, 0, 0.3);
}

.settings-icon-img2 {
  width: 28rpx;
  height: 28rpx;
  filter: brightness(0) invert(1);
}

/* ==================== 快捷设置悬浮按钮 ==================== */
/* ==================== 分享操作栏 ==================== */
.share-bar {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 16rpx 0 12px;
  margin: 6rpx -24rpx 0;
  width: calc(100% + 48rpx);
  box-sizing: border-box;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  margin: 0 !important;
  padding: 0 12rpx !important;
  height: 58rpx !important;
  min-width: 0 !important;
  border-radius: 999rpx !important;
  font-size: 24rpx !important;
  font-weight: 600 !important;
  line-height: 58rpx !important;
  border: none !important;
  background: transparent !important;
  box-sizing: border-box;
  overflow: hidden;
}

.share-btn::after { display: none !important; }

.share-btn:active {
  transform: scale(0.95);
  opacity: 0.85;
}

.share-asset-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  width: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.share-asset-btn {
  background: #FFFFFF !important;
  color: #8B6914 !important;
  box-shadow: 0 2rpx 10rpx rgba(139, 105, 20, 0.05) !important;
}

.share-poster-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  width: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.share-btn-primary {
  background: linear-gradient(135deg, #DAA520, #B8860B) !important;
  color: #FFFFFF !important;
  box-shadow: 0 5rpx 18rpx rgba(218, 165, 32, 0.35) !important;
}

.share-btn-save {
  background: linear-gradient(135deg, #FFF8E7, #FFECB3) !important;
  color: #8B6914 !important;
  box-shadow: 0 5rpx 18rpx rgba(139, 105, 20, 0.1) !important;
}

.share-btn-icon {
  width: 25rpx;
  height: 25rpx;
  flex-shrink: 0;
}

.share-btn-text {
  max-width: 100%;
  font-size: 24rpx;
  letter-spacing: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ==================== 底部签名 ==================== */
.footer-signature {
  text-align: center;
  padding: 16rpx 0 28rpx;
}

.footer-signature text {
  font-size: 25rpx;
  color: #D1D5DB;
  font-weight: 400;
  letter-spacing: 3rpx;
}

/* ==================== 底部导航栏 ==================== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 110rpx;
  background: #FFFFFF;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex: 1;
  height: 100%;
  transition: all 0.15s ease;
  position: relative;
}

.nav-item:active { opacity: 0.6; }

.nav-icon {
  font-size: 44rpx;
  line-height: 1;
  transition: transform 0.15s ease;
}

.nav-item:active .nav-icon { transform: scale(0.85); }

.nav-text {
  font-size: 25rpx;
  font-weight: 500;
  color: #AEAEB2;
  letter-spacing: 0.5rpx;
  transition: all 0.15s ease;
}

.nav-item.active .nav-text {
  color: #007AFF;
  font-weight: 700;
}

/* 选中指示器 */
.nav-item.active::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  width: 32rpx;
  height: 5rpx;
  background: #007AFF;
  border-radius: 3rpx;
}

/* 底部占位 */
.bottom-spacer {
  height: calc(110rpx + env(safe-area-inset-bottom));
}
