/* pages/index/index.wxss — 首页样式（全面UI优化版） */

.page-container {
  min-height: 100vh;
  padding: 0 24rpx 40rpx;
  background: linear-gradient(180deg, #F8F9FC 0%, #F0F2F8 100%);
}

/* ==================== 顶部区域：日期 + 金句 ==================== */
.header-section {
  padding-top: 28rpx;
  margin-bottom: 4rpx;
}

.header-top-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.today-header {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  flex-wrap: wrap;
}

/* 日期（大标题） */
.today-date {
  font-size: 42rpx;
  font-weight: 800;
  color: #1D1D1F;
  letter-spacing: 1rpx;
}

/* 农历日期（标准正文） */
.today-lunar {
  font-size: 27rpx;
  color: #6B7280;
  font-weight: 600;
}

/* 干支年（辅助信息） */
.today-ganzhi {
  font-size: 22rpx;
  color: #AEAEB2;
  font-weight: 400;
}

/* 今日节日标签 */
.festival-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 6rpx;
}

.festival-tag {
  display: inline-flex;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.tag-trad { background: linear-gradient(135deg, #FFE5E5, #FFCDCD); color: #C0392B; }
.tag-buddha { background: linear-gradient(135deg, #F3E8FF, #E9D5FF); color: #7C3AED; }
.tag-solar { background: linear-gradient(135deg, #E5FAEF, #BBF7D0); color: #059669; }

/* 右侧金句 */
.header-quote {
  flex-shrink: 0;
  max-width: 300rpx;
  text-align: right;
  padding: 6rpx 0 0 12rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 16rpx;
  padding: 16rpx 18rpx;
  backdrop-filter: blur(10px);
}

/* 金句文字（略小于标准，优雅感） */
.quote-text-inline {
  font-size: 24rpx;
  color: #6366F1;
  font-style: italic;
  line-height: 1.6;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* ==================== 节气卡片（优化：紧凑、精致） ==================== */
.sth2-card {
  margin: 20rpx 0 16rpx;
  padding: 26rpx 26rpx 22rpx;
  background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 40%, #FEF3C7 100%);
  border-radius: 24rpx;
  border-left: 6rpx solid #10B981;
  box-shadow: 0 4rpx 20rpx rgba(16, 185, 129, 0.12);
}

/* 节气标题行：图标 + 名称 */
.sth2-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

/* 叶子图标 — 缩小为精致的装饰性图标 */
.sth2-icon {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.75;
  flex-shrink: 0;
}

/* 节气名称（大标题） */
.sth2-name {
  font-size: 38rpx;
  font-weight: 900;
  color: #065F46;
  letter-spacing: 5rpx;
  font-family: -apple-system, 'PingFang SC', 'SF Pro Display', serif;
}

/* 节气日期范围 */
.sth2-period {
  display: block;
  font-size: 23rpx;
  color: #558B2F;
  font-weight: 500;
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
  padding-left: 56rpx; /* 与名称左对齐 */
}

/* 节气简介（标准正文） */
.sth2-desc {
  display: block;
  font-size: 27rpx;
  color: #374151;
  line-height: 1.75;
  margin-bottom: 10rpx;
  text-align: justify;
}

/* 养生/饮食文字（稍小，层次分明） */
.sth2-text {
  display: block;
  font-size: 25rpx;
  color: #4B5563;
  line-height: 1.72;
  margin-bottom: 6rpx;
}

/* 金句提示条 */
.sth2-tip {
  margin-top: 14rpx;
  padding: 14rpx 18rpx;
  background: rgba(255, 255, 255, 0.65);
  border-radius: 14rpx;
  border-left: 4rpx solid rgba(16, 185, 129, 0.35);
}

.sth2-tip text {
  font-size: 24rpx;
  color: #047857;
  font-style: italic;
  line-height: 1.62;
  display: block;
}

/* 迷你节气卡片（非当天显示的简短版） */
.sth2-mini {
  padding: 22rpx 24rpx;
}

.sth2-mini .sth2-icon {
  width: 36rpx;
  height: 36rpx;
}

.sth2-mini .sth2-name {
  font-size: 30rpx;
  letter-spacing: 2rpx;
}

.sth2-mini .sth2-period {
  font-size: 21rpx;
  padding-left: 48rpx;
  margin-bottom: 6rpx;
}

/* ==================== 素食养生语录卡片（图2详细风格） ==================== */
.dvt2-card {
  margin: 20rpx 0;
  padding: 26rpx 26rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid #F59E0B;
}

.dvt2-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* "节气·养生" 标题（加大加粗，更有存在感） */
.dvt2-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1D1D1F;
  letter-spacing: 2rpx;
}

.dvt2-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 语录正文（重点内容，大一号） */
.dvt2-content {
  font-size: 29rpx;
  color: #374151;
  line-height: 1.8;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  text-align: justify;
}

/* ==================== 重要日子区块 ==================== */
.section-block {
  margin: 24rpx 0 14rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #111827;
  letter-spacing: 1.5rpx;
}

.add-btn-small {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 122, 255, 0.06);
  border-radius: 50%;
  transition: background 0.15s;
}

.add-btn-small:active { background: rgba(0, 122, 255, 0.12); }

.add-btn-small text {
  font-size: 32rpx;
  color: #007AFF;
  font-weight: 300;
  line-height: 1;
}

/* 事件列表 */
.events-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.event-item {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 3rpx 14rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s, box-shadow 0.15s;
}

.event-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.event-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.event-top-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.event-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-red { background: #FF3B30; }
.dot-blue { background: #007AFF; }
.dot-green { background: #34C759; }
.dot-orange { background: #FF9500; }
.dot-purple { background: #AF52DE; }

/* 事件名称（标准正文+） */
.event-name {
  font-size: 29rpx;
  font-weight: 700;
  color: #1F2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-category-tag {
  font-size: 18rpx;
  color: #FFF;
  background: #C7C7CC;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.event-bottom-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.event-target-date {
  font-size: 23rpx;
  color: #AEAEB2;
  font-weight: 400;
}

.event-countdown-area {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-left: auto;
}

.event-subtitle {
  font-size: 21rpx;
  color: #86868B;
  font-weight: 500;
}

.event-subtitle.past { color: #C7C7CC; }

/* 倒计时天数（醒目） */
.event-days {
  font-size: 32rpx;
  font-weight: 900;
  color: #F59E0B;
  letter-spacing: 0.5rpx;
}

.event-days.past { color: #C7C7CC; }

.event-unit {
  font-size: 21rpx;
  color: #86868B;
  font-weight: 500;
}

/* 空状态 */
.empty-add-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 40rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 3rpx 14rpx rgba(0, 0, 0, 0.04);
}

.add-icon-large {
  font-size: 48rpx;
  color: #C7C7CC;
  font-weight: 200;
  line-height: 1;
}

.add-text {
  font-size: 26rpx;
  color: #AEAEB2;
  font-weight: 500;
}

/* ==================== 近期节日卡片列表 ==================== */
.festivals-list-v {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.festival-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 3rpx 14rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s;
}

.festival-card:active { transform: scale(0.98); }

.fc-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.fc-date-box {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #F5F5F7;
  border-radius: 14rpx;
}

.fc-month {
  font-size: 19rpx;
  color: #86868B;
  font-weight: 600;
}

.fc-day {
  font-size: 28rpx;
  font-weight: 800;
  color: #1D1D1F;
  line-height: 1.2;
}

.fc-countdown-badge {
  font-size: 17rpx;
  font-weight: 600;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.countdown-soon { background: #FFE5E5; color: #D93B3B; }
.countdown-normal { background: #E5F2FF; color: #007AFF; }
.countdown-far { background: #F2F2F7; color: #8E8E93; }

.fc-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.fc-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* 节日名称（标准正文+） */
.fc-name {
  font-size: 29rpx;
  font-weight: 700;
  color: #1F2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fc-type-tag {
  font-size: 17rpx;
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.fc-desc {
  font-size: 24rpx;
  color: #86868B;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.fc-desc-alt {
  font-size: 22rpx;
  color: #AEAEB2;
}

/* ==================== 功能操作区：功过格 + 显示设置（并排醒目卡片） ==================== */
.action-row {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0 16rpx;
}

.action-card {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.07);
  transition: transform 0.15s, box-shadow 0.15s;
  position: relative;
  overflow: hidden;
}

.action-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
}

/* 功过格卡片 */
.merit-entry {
  background: linear-gradient(135deg, #1E1B4B 0%, #312E81 100%);
}

/* 显示设置卡片 — 更醒目的渐变背景 */
.settings-entry-prominent {
  background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 50%, #C7D2FE 100%);
  border: 1.5rpx solid rgba(99, 102, 241, 0.15);
}

.action-icon-img {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.action-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
  flex: 1;
  margin-left: 14rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 0.5rpx;
}

.merit-entry .action-title {
  color: #FFFFFF;
}

.settings-entry-prominent .action-title {
  color: #3730A3;
}

.action-subtitle {
  font-size: 21rpx;
  font-weight: 400;
  letter-spacing: 0.3rpx;
}

.merit-entry .action-subtitle {
  color: rgba(255, 255, 255, 0.5);
}

.settings-entry-prominent .action-subtitle {
  color: #6366F1;
}

/* 功过格数值徽章 */
.action-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 44rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.action-badge text {
  font-size: 26rpx;
  font-weight: 900;
}

.badge-positive {
  background: rgba(52, 199, 89, 0.2);
}

.badge-positive text { color: #34C759; }

.badge-negative {
  background: rgba(255, 59, 48, 0.2);
}

.badge-negative text { color: #FF3B30; }

.badge-empty {
  background: transparent;
}

/* 箭头 */
.action-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 6rpx;
}

.settings-entry-prominent .action-arrow {
  color: #A5B4FC;
}

/* 设置图标圆形背景 */
.settings-icon-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366F1, #8B5CF6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 3rpx 12rpx rgba(99, 102, 241, 0.3);
}

.settings-icon-img2 {
  width: 28rpx;
  height: 28rpx;
  filter: brightness(0) invert(1);
}

/* ==================== 快捷设置悬浮按钮 ==================== */
.quick-settings-fab {
  position: fixed;
  right: 28rpx;
  bottom: 160rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366F1, #8B5CF6);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(99, 102, 241, 0.4);
  z-index: 900;
  transition: transform 0.2s, box-shadow 0.2s;
}

.quick-settings-fab:active {
  transform: scale(0.9);
  box-shadow: 0 3rpx 12rpx rgba(99, 102, 241, 0.3);
}

.fab-icon {
  width: 44rpx;
  height: 44rpx;
  filter: brightness(0) invert(1);
}

/* ==================== 分享操作栏 ==================== */
.share-bar {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 0 10rpx;
  margin-top: 4rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin: 0 !important;
  padding: 14rpx 32rpx !important;
  border-radius: 50rpx !important;
  font-size: 26rpx !important;
  font-weight: 600 !important;
  line-height: 1.2 !important;
  border: none !important;
  background: transparent !important;
}

.share-btn::after { display: none !important; }

.share-btn:active {
  transform: scale(0.95);
  opacity: 0.85;
}

.share-btn-primary:nth-child(1) {
  background: linear-gradient(135deg, #E8F5E9, #F1F8E9) !important;
  color: #2E7D32 !important;
  box-shadow: 0 2rpx 10rpx rgba(46, 125, 50, 0.1) !important;
}

.share-btn-primary:nth-child(2) {
  background: linear-gradient(135deg, #E3F2FD, #E8F5E9) !important;
  color: #1565C0 !important;
  box-shadow: 0 2rpx 10rpx rgba(21, 101, 192, 0.08) !important;
}

.share-btn-save {
  background: linear-gradient(135deg, #FFF8E7, #FFECB3) !important;
  color: #8B6914 !important;
  box-shadow: 0 2rpx 10rpx rgba(139, 105, 20, 0.1) !important;
}

.share-btn-icon {
  width: 30rpx;
  height: 30rpx;
}

.share-btn-text {
  font-size: 25rpx;
  letter-spacing: 1rpx;
}

/* ==================== 底部签名 ==================== */
.footer-signature {
  text-align: center;
  padding: 16rpx 0 28rpx;
}

.footer-signature text {
  font-size: 22rpx;
  color: #D1D5DB;
  font-weight: 400;
  letter-spacing: 3rpx;
}

/* ==================== 底部导航栏 ==================== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 110rpx;
  background: #FFFFFF;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex: 1;
  height: 100%;
  transition: all 0.15s ease;
  position: relative;
}

.nav-item:active { opacity: 0.6; }

.nav-icon {
  font-size: 44rpx;
  line-height: 1;
  transition: transform 0.15s ease;
}

.nav-item:active .nav-icon { transform: scale(0.85); }

.nav-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #AEAEB2;
  letter-spacing: 0.5rpx;
  transition: all 0.15s ease;
}

.nav-item.active .nav-text {
  color: #007AFF;
  font-weight: 700;
}

/* 选中指示器 */
.nav-item.active::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  width: 32rpx;
  height: 5rpx;
  background: #007AFF;
  border-radius: 3rpx;
}

/* 底部占位 */
.bottom-spacer {
  height: calc(110rpx + env(safe-area-inset-bottom));
}
