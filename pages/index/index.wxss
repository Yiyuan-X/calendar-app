/* pages/index/index.wxss — 首页样式（Apple 极简风格） */

/* ==================== 页面容器 ==================== */
.page-container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 0 28rpx 120rpx;
}

/* ==================== 顶部今日信息 + 金句（左右布局） ==================== */
.header-section {
  padding: 36rpx 0 24rpx;
}

/* 顶行：日期(左) + 金句(右) */
.header-top-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

/* 左侧日期区域 */
.header-left {
  flex-shrink: 0;
  min-width: 0;
}

.today-header {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}

.today-date {
  font-size: 56rpx;
  font-weight: 750;
  color: #1D1D1F;
  letter-spacing: -1.5rpx;
  font-family: -apple-system, 'SF Pro Display', sans-serif;
  line-height: 1.1;
}

.today-lunar {
  font-size: 26rpx;
  color: #86868B;
  font-weight: 500;
}

.today-ganzhi {
  font-size: 22rpx;
  color: #AEAEB2;
}

/* 今日节日标签行 */
.festival-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.festival-tag {
  font-size: 21rpx;
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 18rpx;
  font-weight: 500;
  line-height: 1.4;
}

.tag-red { background: linear-gradient(135deg, #FF6B6B, #EE5A5A); }
.tag-purple { background: linear-gradient(135deg, #9B8FFF, #7C5CFC); }
.tag-gold { background: linear-gradient(135deg, #E8B86D, #D4A24A); }
.tag-pink { background: linear-gradient(135deg, #FF9EC4, #FF6BA3); }
.tag-blue { background: linear-gradient(135deg, #5AC8FA, #34AADC); }

/* ==================== 每日金句（内嵌顶部右侧） ==================== */
.header-quote {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-top: 6rpx;
  min-width: 0;
}

.quote-text-inline {
  font-size: 24rpx;
  color: #AEAEB2;
  line-height: 1.65;
  text-align: right;
  font-style: italic;
  font-family: -apple-system, 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  letter-spacing: 0.5rpx;
}

/* ==================== 日历卡片（与日历页统一风格） ==================== */
.calendar-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

/* 月份导航（与日历页一致） */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 8rpx 20rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: transparent;
  transition: background 0.15s;
}

.nav-btn:active { background: rgba(0, 0, 0, 0.04); }

.nav-arrow {
  font-size: 36rpx;
  color: #86868B;
  line-height: 1;
  font-weight: 300;
}

.month-title {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  padding: 10rpx 32rpx;
}

.year-text {
  font-size: 24rpx;
  color: #AEAEB2;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.month-text {
  font-size: 38rpx;
  color: #1D1D1F;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.today-hint {
  font-size: 23rpx;
  color: #007AFF;
  font-weight: 500;
  margin-left: 4rpx;
}

/* 星期标题（与日历页一致） */
.week-header {
  display: flex;
  margin-bottom: 6rpx;
  padding: 12rpx 8rpx 14rpx;
}

.week-day-item {
  flex: 1;
  text-align: center;
  padding: 4rpx 0;
}

.week-day-text {
  font-size: 24rpx;
  color: #AEAEB2;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.week-day-text.weekend { color: #FF3B30; opacity: 0.55; }

/* 日历网格（与日历页一致的格子风格） */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
}

.day-cell {
  width: calc(100% / 7);
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 10rpx;
  position: relative;
  border-right: 1rpx solid rgba(0, 0, 0, 0.03);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
  transition: background 0.15s ease;
  box-sizing: border-box;
}

.day-cell:nth-child(7n) { border-right: none; }

.day-cell.current-month:active { background: rgba(0, 122, 255, 0.05); }

/* 非当月日期 — 降低可见度 */
.day-cell.other-month .day-number,
.day-cell.other-month .marker {
  opacity: 0.25;
}

/* 日期数字 */
.day-number {
  font-size: 28rpx;
  color: #1D1D1F;
  font-weight: 500;
  line-height: 1.3;
  z-index: 1;
}

/* 今天 — 蓝色圆形 */
.day-cell.today .day-number {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  background: #007AFF;
  color: #FFFFFF !important;
  border-radius: 50%;
  font-weight: 600;
  font-size: 26rpx;
}

/* 今天隐藏下方标记文字 */
.day-cell.today .marker { display: none; }

/* 选中状态 */
.day-cell.selected:not(.today) {
  background: rgba(0, 122, 255, 0.06);
}

.day-cell.selected:not(.today) .day-number {
  font-weight: 700;
  color: #007AFF;
}

/* 标记文字（节气/农历/节日/事件 — 与日历页一致） */
.marker {
  font-size: 18rpx;
  line-height: 1.35;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 92%;
  padding: 0 2rpx;
  font-weight: 500;
  margin-top: 1rpx;
}

.solar-term-marker { color: #34C759; }

.lunar-marker {
  color: #AEAEB2;
  font-weight: 400;
  transform: scale(0.9);
}

.festival-marker {
  padding: 0 4rpx;
  border-radius: 3rpx;
  font-weight: 600;
}

.festival-red { color: #FF3B30; }
.festival-purple { color: #AF52DE; }
.festival-gold { color: #DAA520; }

.event-marker {
  color: #007AFF;
  font-weight: 600;
  padding: 0 4rpx;
  border-radius: 3rpx;
  background: rgba(0, 122, 255, 0.06);
}

/* 有重要日子格子的特殊样式 */
.day-cell.has-event .day-number {
  font-weight: 700;
}

/* 节日标记 */
.has-festival .day-number { font-weight: 600; }
.has-buddhist .day-number { color: #AF52DE; }
.has-buddhist.today .day-number { background: #AF52DE; color: #fff !important; }

/* 多节日圆点指示器 */
.festival-dots {
  position: absolute;
  bottom: 6rpx;
  display: flex;
  gap: 5rpx;
}

.dot {
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
}

.dot-red { background: #FF3B30; }
.dot-purple { background: #AF52DE; }
.dot-gold { background: #DAA520; }

/* ==================== 区块通用 ==================== */
.section-block {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 26rpx 26rpx 22rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.section-icon { font-size: 27rpx; }

.section-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #1D1D1F;
  flex: 1;
  letter-spacing: 0.5rpx;
}

.add-btn-small {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #F0F0F5;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s ease;
}

.add-btn-small:active { background: #E0E0E8; transform: scale(0.9); }
.add-btn-small text { font-size: 28rpx; color: #007AFF; line-height: 1; margin-bottom: 2rpx; }

/* ==================== 重要日子倒计时 ==================== */
.events-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.event-item {
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.15s ease;
  /* 分割线效果 */
  position: relative;
}

.event-item:not(:last-child)::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 44rpx;
  right: 0;
  height: 1rpx;
  background: #F0F0F2;
}

.event-item:active { background: #F5F5F7; }

.event-main {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.event-top-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.event-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-pink { background: #FF69B4; }
.dot-red { background: #FF3B30; }
.dot-green { background: #34C759; }
.dot-blue { background: #007AFF; }

.event-name {
  font-size: 28rpx;
  color: #1D1D1F;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.event-category-tag {
  font-size: 19rpx;
  color: #8E8E93;
  background: #F2F2F7;
  padding: 3rpx 14rpx;
  border-radius: 10rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.event-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 22rpx;
}

.event-target-date {
  font-size: 22rpx;
  color: #AEAEB2;
  font-weight: 400;
}

.event-countdown-area {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
}

.event-subtitle {
  font-size: 20rpx;
  color: #86868B;
  font-weight: 400;
}

.event-subtitle.past { color: #C7C7CC; }

.event-days {
  font-size: 40rpx;
  font-weight: 750;
  color: #1D1D1F;
  font-family: -apple-system, 'SF Pro Display', sans-serif;
  line-height: 1;
  min-width: 40rpx;
  text-align: right;
}

.event-days.past { color: #C7C7CC; }

.event-unit {
  font-size: 20rpx;
  color: #86868B;
  font-weight: 400;
}

.empty-add-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 16rpx;
  gap: 12rpx;
}

.add-icon-large {
  font-size: 56rpx;
  color: #D1D1D6;
  line-height: 1;
  font-weight: 200;
}

.add-text {
  font-size: 24rpx;
  color: #AEAEB2;
}

/* ==================== 近期节日（纵向卡片列表） ==================== */
.festivals-list-v {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.festival-card {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  transition: all 0.2s ease;
  border-left: 5rpx solid transparent;
}

.festival-card:active { opacity: 0.75; transform: scale(0.98); }

/* 红色 — 法定/重要 */
.chip-red {
  background: linear-gradient(135deg, #FFFBFA, #FFF5F5);
  border-left-color: #EE5A5A;
}
.chip-red .fc-month,
.chip-red .fc-day { color: #D93B3B; }
.chip-red .fc-countdown-badge { background: #FFE5E5; color: #D93B3B; }
.chip-red .fc-type-tag { background: #FDE8E8; color: #C0392B; }

/* 紫色 — 佛教 */
.chip-purple {
  background: linear-gradient(135deg, #FAFAFF, #F5F0FF);
  border-left-color: #9B59B6;
}
.chip-purple .fc-month,
.chip-purple .fc-day { color: #8E44AD; }
.chip-purple .fc-countdown-badge { background: #F3E8FF; color: #8E44AD; }
.chip-purple .fc-type-tag { background: #EBDEF0; color: #7D3C98; }

/* 金色 — 传统 */
.chip-gold {
  background: linear-gradient(135deg, #FFFEFA, #FFF9EC);
  border-left-color: #DAA520;
}
.chip-gold .fc-month,
.chip-gold .fc-day { color: #B8860B; }
.chip-gold .fc-countdown-badge { background: #FFF3D6; color: #B8860B; }
.chip-gold .fc-type-tag { background: #FEF5D7; color: #9A7B0A; }

/* 粉色 — 纪念 */
.chip-pink {
  background: linear-gradient(135deg, #FFF9FB, #FFF0F5);
  border-left-color: #FF69B4;
}
.chip-pink .fc-month,
.chip-pink .fc-day { color: #DB7093; }
.chip-pink .fc-countdown-badge { background: #FFE4F0; color: #DB7093; }
.chip-pink .fc-type-tag { background: #FCE4EC; color: #C2185B; }

/* 左侧日期区 */
.fc-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 76rpx;
  gap: 2rpx;
}

.fc-date-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1.2;
}

.fc-month {
  font-size: 19rpx;
  font-weight: 600;
}

.fc-day {
  font-size: 34rpx;
  font-weight: 750;
  font-family: -apple-system, 'SF Pro Display', sans-serif;
  line-height: 1.05;
}

/* 倒计时标签 */
.fc-countdown-badge {
  font-size: 17rpx;
  font-weight: 600;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  margin-top: 6rpx;
  white-space: nowrap;
}

.fc-tomorrow { background: #E8F5E9; color: #2E7D32; }
.fc-soon { background: #FFF3E0; color: #E65100; }
.fc-normal { background: #F0F0F5; color: #666; }

/* 右侧信息区 */
.fc-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
  min-width: 0;
}

.fc-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.fc-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1D1D1F;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fc-type-tag {
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.fc-desc {
  font-size: 22rpx;
  color: #86868B;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.fc-desc-alt {
  font-size: 21rpx;
  color: #AEAEB2;
  font-style: italic;
}

/* ==================== 设置入口 ==================== */
.settings-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx;
  margin-top: 8rpx;
  background: #FFFFFF;
  border-radius: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  transition: all 0.15s ease;
}

.settings-entry:active { background: #F5F5F7; transform: scale(0.98); }

.settings-icon { font-size: 28rpx; line-height: 1; }

.settings-text {
  font-size: 25rpx;
  color: #86868B;
  font-weight: 500;
}

.settings-arrow {
  font-size: 30rpx;
  color: #C7C7CC;
  font-weight: 300;
}

/* ==================== 底部签名 ==================== */
.footer-signature {
  text-align: center;
  padding: 32rpx 0 48rpx;
}

.footer-signature text {
  font-size: 21rpx;
  color: #D1D1D6;
  letter-spacing: 3rpx;
  font-weight: 400;
}

/* ==================== 节气养生卡片（首页） ==================== */
.solar-term-health-card {
  margin: 16rpx 0;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #F1F8E9 0%, #FFFFFF 100%);
  border-radius: 20rpx;
  border-left: 5rpx solid #66BB6A;
  box-shadow: 0 2rpx 12rpx rgba(102, 187, 106, 0.08);
}

.sth-header {
  margin-bottom: 14rpx;
}

.sth-tag {
  font-size: 26rpx;
  font-weight: 700;
  color: #2E7D32;
  display: block;
  margin-bottom: 6rpx;
}

.sth-desc {
  font-size: 24rpx;
  color: #555;
  line-height: 1.55;
  display: block;
}

.sth-body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sth-item {
  font-size: 23rpx;
  color: #444;
  line-height: 1.6;
  display: block;
}

.sth-tip-line {
  margin-top: 8rpx;
  padding: 12rpx 16rpx;
  background: rgba(102, 187, 106, 0.1);
  border-radius: 10rpx;
  font-size: 23rpx;
  color: #2E7D32;
  line-height: 1.55;
  display: block;
  font-style: italic;
}

/* 迷你版（非节气日显示当前节气简短提示） */
.sth-mini {
  padding: 18rpx 24rpx;
  border-left-width: 3rpx;
}

.sth-mini-text {
  font-size: 24rpx;
  color: #2E7D32;
  line-height: 1.5;
  display: block;
}

/* ==================== 功过格入口（首页） ==================== */
.merit-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  margin-top: 8rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFFBF0 50%, #FFFFFF 100%);
  border-radius: 20rpx;
  border-left: 5rpx solid #DAA520;
  box-shadow: 0 2rpx 12rpx rgba(218, 165, 32, 0.08);
  transition: all 0.15s ease;
}

.merit-entry:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(218, 165, 32, 0.12);
}

.merit-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}

.merit-icon {
  font-size: 36rpx;
  line-height: 1;
  flex-shrink: 0;
}

.merit-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.merit-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #5D4037;
  letter-spacing: 1rpx;
}

.merit-subtitle {
  font-size: 21rpx;
  color: #A1887F;
  letter-spacing: 0.5rpx;
}

.merit-right {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.merit-net {
  font-size: 32rpx;
  font-weight: 750;
  font-family: -apple-system, 'SF Pro Display', sans-serif;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.net-positive {
  color: #2E7D32;
  background: rgba(46, 125, 50, 0.08);
}

.net-negative {
  color: #C62828;
  background: rgba(198, 40, 40, 0.06);
}

.merit-arrow {
  font-size: 30rpx;
  color: #C7C7CC;
  font-weight: 300;
}

.merit-arrow-alone {
  font-size: 30rpx;
  color: #C7C7CC;
  font-weight: 300;
}
