/* pages/add-event/add-event.wxss —— 优化版 */

.page-container {
  min-height: 100vh;
  padding: 0 32rpx;
  background: var(--bg-color);
}

/* ===== 页面标题 — 更有仪式感 ===== */
.page-header {
  padding: 32rpx 0 28rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.page-subtitle {
  font-size: 25rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.5rpx;
}

/* ===== 表单区域 — 更精致的卡片 ===== */
.form-section {
  background: var(--card-bg);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.form-item {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  position: relative;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 56rpx;
  font-size: 32rpx;
  color: var(--text-primary);
  background: transparent;
  border: none;
  border-bottom: 2rpx solid transparent;
  padding-right: 60rpx;
  font-weight: 500;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-bottom-color: var(--accent-color);
}

.input-count {
  position: absolute;
  right: 32rpx;
  bottom: 28rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 选择器 */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 56rpx;
  padding: 4rpx 0;
}

.value-text {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.placeholder {
  font-size: 30rpx;
  color: var(--text-tertiary);
  font-weight: 400;
}

.picker-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

/* 分类选择 — 胶囊式按钮 */
.category-list {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.category-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 26rpx;
  border-radius: 36rpx;
  background: rgba(142, 142, 147, 0.06);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.category-item.active {
  background: rgba(0, 122, 255, 0.07);
  border-color: var(--accent-color);
  box-shadow: 0 2rpx 12rpx rgba(0, 122, 255, 0.1);
}

.category-icon {
  font-size: 28rpx;
}

.category-name {
  font-size: 25rpx;
  color: var(--text-secondary);
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.category-item.active .category-name {
  color: var(--accent-color);
}

/* 计时模式切换 — 卡片式 */
.mode-switch {
  display: flex;
  gap: 16rpx;
}

.mode-option {
  flex: 1;
  padding: 24rpx 20rpx;
  border-radius: var(--radius-md);
  background: rgba(142, 142, 147, 0.04);
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  transition: all 0.2s ease;
}

.mode-option.active {
  background: rgba(0, 122, 255, 0.05);
  border-color: var(--accent-color);
}

.mode-title {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 0.5rpx;
}

.mode-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.3;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 120rpx;
  max-height: 300rpx;
  font-size: 29rpx;
  color: var(--text-primary);
  background: transparent;
  border: none;
  line-height: 1.7;
  font-weight: 400;
}

.textarea-count {
  bottom: 16rpx;
}

/* 开关项 */
.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.switch-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ===== 预览卡片 — 模拟首页效果 ===== */
.preview-section {
  margin-top: 32rpx;
}

.preview-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 14rpx;
  font-weight: 500;
}

.preview-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-radius: var(--radius-lg) !important;
}

.preview-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.preview-dot {
  width: 8rpx;
  height: 52rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.dot-pink { background: linear-gradient(180deg, #FFB6C1, #FF9FAB); }
.dot-red { background: linear-gradient(180deg, #FF6B6B, #FF3B30); }
.dot-green { background: linear-gradient(180deg, #5CD168, #34C759); }
.dot-blue { background: linear-gradient(180deg, #4CADFF, #007AFF); }

.preview-title {
  font-size: 31rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.5rpx;
}

.preview-right {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.preview-days {
  font-size: 52rpx;
  font-weight: 300;
  color: var(--text-primary);
  line-height: 1;
  letter-spacing: -2rpx;
}

.preview-unit {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

/* ===== 操作按钮 ===== */
.action-section {
  margin-top: 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 20rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: var(--text-primary);
  color: #ffffff;
  font-size: 33rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 6rpx;
  transition: opacity 0.15s;
}

.save-btn.disabled {
  opacity: 0.25;
}

.save-btn::after {
  border: none;
}

.delete-btn-text {
  font-size: 26rpx;
  color: var(--festival-red);
  background: transparent;
  padding: 14rpx 36rpx;
  border: none;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.delete-btn-text::after {
  border: none;
}

.bottom-spacer {
  height: 60rpx;
}
