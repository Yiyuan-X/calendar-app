/* 功课计数器主页面 */
.page { min-height:100vh; background:#F5F5F7; padding:0 24rpx; }

/* 头部 */
.header { padding:28rpx 0 16rpx; }
.header-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:8rpx; }
.title { font-size: 37rpx; font-weight:700; color:#1D1D1F; }
.title text { color:#FFB300; }
.add-btn { padding: 14rpx 32rpx; border-radius: 28rpx; background: linear-gradient(135deg, #FFB300, #FF8F00); display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 16rpx rgba(255, 179, 0, 0.35); }
.add-btn text { color: #fff; font-size: 29rpx; font-weight: 600; line-height: 1; white-space: nowrap; letter-spacing: 2rpx; }

/* 理念引导语 */
.motto { text-align:center; font-size: 29rpx; color:#B09A68; margin-top:8rpx; letter-spacing:2rpx; }

/* 今日概览 */
.summary-card { background:#fff; border-radius:20rpx; padding:24rpx 28rpx; margin-bottom:20rpx; box-shadow:0 2rpx 12rpx rgba(0,0,0,.03); }
.summary-row { display:flex; align-items:center; justify-content:space-around; }
.sum-item { display:flex; flex-direction:column; align-items:center; gap:4rpx; }
.sum-num { font-size: 41rpx; font-weight:750; color:#1D1D1F; font-family:-apple-system,'SF Pro Display',sans-serif; }
.sum-num.purple { color:#FFB300; }
.sum-num.green { color:#34C759; }
.sum-label { font-size: 24rpx; color:#AEAEB2; }
.sum-divider { width:1rpx; height:44rpx; background:rgba(0,0,0,.06); }
.summary-hint { text-align:center; margin-top:12rpx; padding:10rpx 0; border-radius:12rpx; }
.summary-hint text { font-size: 30rpx; color:#FFB300; }
.summary-hint:active { background:#FFF8E1; opacity:.85; }

/* 提示 */
.tip-bar { background:linear-gradient(135deg,#FFF3E0,#FFF8E1); border-radius:12rpx; padding:14rpx 20rpx; margin-bottom:20rpx; display:flex; align-items:center; gap:12rpx; }
.tip-bar text { font-size: 25rpx; color:#E65100; }
.tip-bar .tip-icon { width:30rpx; height:30rpx; flex-shrink:0; }

/* 功课列表 */
.task-list { display:flex; flex-direction:column; gap:16rpx; padding-bottom:20rpx; }
.task-card { background:#fff; border-radius:18rpx; padding:22rpx 24rpx; box-shadow:0 2rpx 10rpx rgba(0,0,0,.03); }
.task-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:14rpx; padding-bottom: 8rpx; gap:6rpx; flex-wrap:nowrap; }
.task-info { display:flex; align-items:center; gap:10rpx; flex:1; min-width:0; overflow:hidden; }
.task-name { font-size: 30rpx; font-weight:600; color:#1D1D1F; overflow:hidden;text-overflow:ellipsis;white-space:nowrap; flex-shrink:1; }
.task-target { font-size: 24rpx; color:#AEAEB2; white-space:nowrap; flex-shrink:0; }
.task-total { font-size: 24rpx; color:#FFB300; font-weight:600; white-space:nowrap; flex-shrink:0; }
.task-arrow { font-size: 28rpx; color:#C7C7CC; }

/* 功课列表顶部提示语 */
.task-list-hint { font-size: 25rpx; color: #B09A68; text-align: center; padding: 16rpx 0 8rpx; line-height: 1.5; }

/* 卡片内删除按钮 */
.btn-del-task { width:46rpx; height:46rpx; border-radius:50%; background:#FFF5F5; border:1.5rpx solid rgba(198,40,40,.28); display:flex;align-items:center;justify-content:center; flex-shrink:0; margin-left:10rpx; box-shadow:0 2rpx 8rpx rgba(198,40,40,.08); }
.btn-del-task-text { font-size: 30rpx; color:#E53935; font-weight:600; line-height:1; }
.btn-del-task:active { background:#FFE1E1; transform:scale(.94); }

/* 进度条 */
.progress-wrap { margin-bottom:10rpx; }
.progress-bar { height:10rpx; background:#F2F2F7; border-radius:5rpx; overflow:hidden; }
.progress-fill { height:100%; border-radius:5rpx; background:linear-gradient(90deg,#FFB300,#FFD54F); transition:width .3s; }
.progress-text { font-size: 24rpx; color:#AEAEB2; text-align:right; display:block; margin-top:2rpx; }

/* 总目标进度 */
.progress-total { margin-bottom:8rpx; }
.progress-bar-total { height:8rpx; background:#FFF3E0; border-radius:4rpx; overflow:hidden; }
.progress-fill-total { height:100%; border-radius:4rpx; background:linear-gradient(90deg,#E65100,#FF9800); transition:width .3s; }
.progress-text-total { font-size: 24rpx; color:#E65100; }

/* 达标标记 */
.task-badge-done { display:inline-flex; align-items:center; gap:6rpx; background:linear-gradient(135deg,#E8F5E9,#C8E6C9); border-radius:20rpx; padding:4rpx 16rpx; margin-top:4rpx; }
.task-badge-done text { font-size: 24rpx; color:#2E7D32; font-weight:600; }
.task-badge-icon { width:22rpx; height:22rpx; flex-shrink:0; }

/* 目标标签 */
.task-target-total { color:#E65100 !important; }

/* 计数区 */
.count-area { display:flex; align-items:center; gap:10rpx; }
.count-display { flex:1; text-align:center; display:flex; flex-direction:column; align-items:center; gap:2rpx; }
.count-num { font-size: 56rpx; font-weight:750; color:#1D1D1F; font-family:-apple-system,'SF Pro Display',sans-serif; line-height:1.2; }
.count-unit { font-size: 25rpx; color:#AEAEB2; }
.count-total { font-size: 24rpx; color:#FFB300; font-weight:600; }

/* 清零按钮 */
.btn-clear { padding:6rpx 16rpx; border-radius:10rpx; background:#FFF0E0; flex-shrink:0; display:inline-flex; align-items:center; justify-content:center; line-height:1; }
.btn-clear text { font-size: 24rpx; color:#E65100; font-weight:600; }
.btn-clear:active { background:#FFE0B2; }

/* +1 按钮（黄色） */
.btn-count { width:96rpx; height:96rpx; border-radius:50%; background:linear-gradient(135deg,#FFB300,#FF8F00); display:flex;align-items:center;justify-content:center; box-shadow:0 4rpx 16rpx rgba(255,179,0,0.35); }
.btn-count text { color:#fff; font-size: 44rpx; font-weight:300; }
.btn-count:active { transform:scale(0.92); opacity:.85; }
.btn-sub { width:64rpx; height:64rpx; border-radius:50%; background:#FFF0F0; display:flex;align-items:center;justify-content:center; border:1.5rpx solid rgba(198,40,40,.15); }
.btn-sub text { color:#E53935; font-size: 32rpx; font-weight:600; }
.btn-sub:active { background:#FFCDD2; }

/* 空状态 */
.empty-state { display:flex; flex-direction:column; align-items:center; padding:100rpx 0 40rpx; }
.empty-icon { width:88rpx; height:88rpx; margin-bottom:20rpx; opacity:.45; }
.empty-text { font-size: 30rpx; color:#AEAEB2; margin-bottom:12rpx; }
.empty-hint { font-size: 26rpx; color:#C7C7CC; }
.quick-suggestions { display:flex; flex-wrap:wrap; justify-content:center; gap:12rpx; margin-top:24rpx; max-width:620rpx; }
.suggestion-chip { padding:12rpx 22rpx; border-radius:28rpx; background:#FFF8E1; color:#8B6914; font-size: 26rpx; font-weight:600; border:1rpx solid rgba(255,179,0,.28); }
.suggestion-chip:active { background:#FFECB3; transform:scale(.97); }
.empty-add { margin-top:28rpx; padding:18rpx 48rpx; background:linear-gradient(135deg,#FFB300,#FF8F00); color:#fff; border-radius:50rpx; font-size: 29rpx; font-weight:600; display:inline-flex; align-items:center; justify-content:center; line-height:1; }

/* 底部留白 */
.bottom-pad { height:40rpx; }

/* 分享操作栏 */
.share-bar { display:flex; gap:16rpx; padding:12rpx 24rpx 22rpx; opacity:.76; }
.share-btn { flex:1; display:flex; align-items:center; justify-content:center; gap:8rpx; height:80rpx; border-radius:40rpx; font-size: 27rpx; font-weight:600; border:none; line-height:1; padding:0; margin:0; background:transparent !important; }
.share-btn::after { border:none; }
.share-btn-primary { background:#fff !important; color:#8B6914; box-shadow:none; }
.share-btn-save { background:linear-gradient(135deg,#FFF3E0,#FFE0B2) !important; color:#E65100; box-shadow:0 2rpx 10rpx rgba(230,81,0,0.12); }
.share-btn-icon { width:30rpx; height:30rpx; flex-shrink:0; }
.share-btn-text { font-size: 27rpx; }

/* 通用计数器 */
.quick-counter-section { background:#fff; border-radius:18rpx; padding:28rpx 24rpx; margin:0 24rpx 30rpx; box-shadow:0 2rpx 10rpx rgba(0,0,0,.03); }
.qc-title { display:flex; align-items:center; justify-content:space-between; margin-bottom:20rpx; }
.qc-title-text { font-size: 30rpx; font-weight:700; color:#1D1D1F; display:flex; align-items:center; gap:8rpx; }
.qc-title-icon { width:32rpx; height:32rpx; flex-shrink:0; }
.qc-subtitle { font-size: 24rpx; color:#AEAEB2; }
.qc-body { display:flex; align-items:center; justify-content:center; gap:24rpx; }
.qc-btn { width:88rpx; height:88rpx; border-radius:50%; display:flex;align-items:center;justify-content:center; flex-shrink:0; }
.qc-btn text { font-size: 72rpx; font-weight:300; line-height:1; }
.qc-btn-add { background:linear-gradient(135deg,#FFB300,#FF8F00); box-shadow:0 4rpx 16rpx rgba(255,179,0,0.35); }
.qc-btn-add text { color:#fff; }
.qc-btn-add:active { transform:scale(0.92); opacity:.85; }
.qc-btn-sub { background:#FFF8E1; }
.qc-btn-sub text { color:#FF8F00; font-size: 60rpx !important; font-weight:600; }
.qc-btn-sub:active { background:#FFECB3; }
.qc-display { min-width:200rpx; text-align:center; padding:10rpx 20rpx; }
.qc-num { font-size: 72rpx; font-weight:750; color:#1D1D1F; font-family:-apple-system,'SF Pro Display',sans-serif; line-height:1.2; }
.qc-actions { display:flex; justify-content:center; margin-top:16rpx; }
.qc-action-btn { padding:8rpx 32rpx; border-radius:20rpx; background:#FFF0E0; display:inline-flex; align-items:center; justify-content:center; line-height:1; }
.qc-action-btn text { font-size: 25rpx; color:#E65100; font-weight:600; }
.qc-action-btn:active { background:#FFE0B2; }
