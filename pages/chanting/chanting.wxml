<!--pages/chanting/chanting.wxml — 功课计数器主页面-->
<view class="page {{elderMode ? 'elder-mode' : ''}}">
  <!-- 头部 -->
  <view class="header">
    <view class="header-top">
      <view class="title">计数器</view>
      <view class="add-btn" bindtap="goAdd"><text>添加功课</text></view>
    </view>
    <view class="motto">{{pageMotto}}</view>
  </view>

  <!-- 今日概览 -->
  <view class="summary-card" wx:if="{{tasks.length > 0}}">
    <view class="summary-row">
      <view class="sum-item">
        <text class="sum-num purple">{{todaySummary.completed}}</text>
        <text class="sum-label">已完成 / {{todaySummary.total > 0 ? todaySummary.total : tasks.length}}项</text>
      </view>
      <view class="sum-divider"></view>
      <view class="sum-item">
        <text class="sum-num green">{{tasks.length}}</text>
        <text class="sum-label">功课总数</text>
      </view>
    </view>
    <view class="summary-hint" wx:if="{{todaySummary.total === 0}}" bindtap="goSetTarget">
      <text>设置每日目标后可追踪完成进度 →</text>
    </view>
  </view>

  <!-- 昨日未完成提示 -->
  <view class="tip-bar" wx:if="{{showYesterdayTip}}" bindtap="goSupplement">
    <image class="tip-icon" src="/images/icons/gen-bulb.svg" mode="aspectFit"></image>
    <text>昨日有 {{yesterdayIncomplete.length}} 项功课未达标，要补吗？</text>
  </view>

  <!-- 功课列表 -->
  <view class="task-list" wx:if="{{tasks.length > 0}}">
    <!-- 列表顶部提示语 -->
    <view class="task-list-hint">点击具体功课可报数、设置每日目标、总目标等具体功能</view>

    <!-- 排序 + 拖拽提示（同一行） -->
    <view class="sort-row">
      <view class="sort-entry" bindtap="showSortModal">
        <image class="sort-icon" src="/images/icons/gen-gear.svg" mode="aspectFit"></image>
        <text>输入数字调整顺序</text>
      </view>
      <text class="drag-hint-text" wx:if="{{!isDragging}}">长按卡片拖动 ↕</text>
    </view>

    <view
      class="task-card {{item.warmClass}} {{item.isDragging ? 'task-card-dragging' : ''}}"
      wx:for="{{taskData}}"
      wx:key="id"
      style="{{item.isDragging ? 'position:fixed;z-index:999;transition:none;' : ''}}"
      data-index="{{index}}"
      data-id="{{item.id}}"
      bindtouchstart="onDragStart"
      bindtouchmove="onDragMove"
      bindtouchend="onDragEnd"
      bindlongpress="onLongPress"
    >
      <!-- 占位符（拖拽时原位置显示） -->
      <block wx:if="{{item.isPlaceholder}}">
        <view class="placeholder-box"></view>
      </block>

      <!-- 正常内容 -->
      <block wx:else>
        <!-- 头部：名称 + 总数 + 删除按钮 -->
        <view class="task-header" bindtap="goDetail" data-id="{{item.id}}">
          <view class="task-info">
            <text class="task-name">{{item.name}}</text>
            <text class="task-target task-target-combo" wx:if="{{item.comboProgressText}}">{{item.comboProgressText}}</text>
            <text class="task-target task-target-combo" wx:if="{{item.comboTodayProgressText}}">{{item.comboTodayProgressText}}</text>
            <text class="task-target" wx:if="{{item.dailyTarget > 0}}">每日 {{item.dailyTarget}}{{item.unit}}</text>
            <text class="task-target task-target-total" wx:if="{{item.totalTarget > 0}}">总目标 {{item.totalTarget}}{{item.unit}}</text>
          </view>
          <text class="task-total">累计 {{item.total}}<text style="font-size:19rpx">{{item.unit}}</text></text>
          <view class="btn-del-task" catchtap="onDeleteTask" data-id="{{item.id}}" data-name="{{item.name}}">
            <text class="btn-del-task-text">×</text>
          </view>
        </view>

        <!-- 进度条（每日目标） -->
        <view class="progress-wrap" wx:if="{{item.dailyTarget > 0}}">
          <view class="progress-bar">
            <view class="progress-fill" style="width:{{item.progressPercent}}%"></view>
          </view>
          <text class="progress-text">{{item.todayCount}}/{{item.dailyTarget}}</text>
        </view>

        <!-- 达标标记 -->
        <view class="task-badge-done" wx:if="{{item.isDailyDone}}">
          <image class="task-badge-icon" src="/images/icons/gen-check.svg" mode="aspectFit"></image><text>已达标</text>
        </view>

        <!-- 计数区：清零 | -1 | 今日+累计 | +1 -->
        <view class="count-area">
          <view class="btn-clear" catchtap="onClear" data-id="{{item.id}}" wx:if="{{item.todayCount > 0}}">
            <text>清零</text>
          </view>
          <view class="btn-sub" catchtap="onDecrement" data-id="{{item.id}}" wx:if="{{item.todayCount > 0}}">
            <text>−</text>
          </view>
          <view class="count-display">
            <text class="count-num number-display">{{item.todayCount}}</text>
            <text class="count-unit">{{item.unit}}</text>
          </view>
          <view class="btn-count" catchtap="onIncrement" data-id="{{item.id}}">
            <text>+</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{tasks.length === 0}}">
    <image class="empty-icon" src="/images/icons/gen-beads.svg" mode="aspectFit"></image>
    <text class="empty-text">还没有添加功课</text>
    <text class="empty-hint">可以从常用功课开始，也可以添加自己的功课</text>
  </view>

  <!-- 隐藏的 Canvas（用于生成朋友圈海报） -->
  <canvas type="2d" id="shareCanvas" style="position:fixed;left:-9999px;top:-9999px;width:500px;height:750px;"></canvas>

  <!-- 通用计数器（日常使用） -->
  <view class="quick-counter-section">
    <view class="qc-title">
      <view class="qc-title-text"><image class="qc-title-icon" src="/images/icons/gen-counter.svg" mode="aspectFit"></image><text>通用计数器</text></view>
      <text class="qc-subtitle">日常临时计数</text>
    </view>
    <view class="qc-body">
      <view class="qc-btn qc-btn-sub" bindtap="onQcDecrement" wx:if="{{quickCount > 0}}">
        <text>−</text>
      </view>
      <view class="qc-display">
        <text class="qc-num">{{quickCount}}</text>
      </view>
      <view class="qc-btn qc-btn-add" bindtap="onQcIncrement">
        <text>+</text>
      </view>
    </view>
    <view class="qc-actions">
      <view class="qc-action-btn" bindtap="onQcReset" wx:if="{{quickCount > 0}}">
        <text>重置</text>
      </view>
    </view>
  </view>

  <!-- 备忘录 -->
  <view class="memo-section">
    <view class="memo-title"><image class="memo-title-icon" src="/images/icons/gen-pencil.svg" mode="aspectFit"></image><text>备忘录</text></view>
    <view class="memo-card">
      <textarea
        class="memo-editor"
        placeholder="记录今日待办、灵感或任何想记下的..."
        value="{{memoContent}}"
        bindinput="onMemoInput"
        auto-height
        maxlength="300"
      ></textarea>
      <view class="memo-footer">
        <text class="memo-count">{{memoContent.length}}/300</text>
        <text class="memo-save-btn" catchtap="saveMemo">保存</text>
      </view>
    </view>
  </view>

  <!-- 排序弹窗 -->
  <view class="sort-mask" wx:if="{{showSort}}" catchtap="hideSortModal">
    <view class="sort-modal" catchtap="stopPropagation">
      <view class="sort-header">
        <text class="sort-title">调整功课顺序</text>
        <text class="sort-desc">数字越小越靠前（1 = 最上面）</text>
      </view>
      <view class="sort-list">
        <view class="sort-item" wx:for="{{taskData}}" wx:key="id">
          <text class="sort-item-name">{{item.name}}</text>
          <input
            class="sort-input"
            type="digit"
            value="{{item.sortDisplay}}"
            data-id="{{item.id}}"
            data-index="{{index}}"
            bindinput="onSortInput"
            confirm-type="done"
          />
        </view>
      </view>
      <view class="sort-footer">
        <view class="sort-btn sort-btn-cancel" catchtap="hideSortModal"><text>取消</text></view>
        <view class="sort-btn sort-btn-save" catchtap="saveSort"><text>保存顺序</text></view>
      </view>
    </view>
  </view>

  <!-- 分享操作栏（页面最底部） -->
  <view class="share-bar" wx:if="{{tasks.length > 0}}">
    <button class="share-btn share-btn-primary" bindtap="shareToMoments">
      <image class="share-btn-icon" src="/images/icons/gen-camera.svg" mode="aspectFit"></image>
      <text class="share-btn-text">生成朋友圈图</text>
    </button>
    <button class="share-btn share-btn-save" bindtap="saveShareImage">
      <image class="share-btn-icon" src="/images/icons/gen-save.svg" mode="aspectFit"></image>
      <text class="share-btn-text">保存</text>
    </button>
  </view>

  <view class="bottom-pad safe-area-bottom"></view>

</view>
