.page-container {
  min-height: 100vh;
  padding: 28rpx;
  background: #F5F5F7;
  box-sizing: border-box;
}

.header-card,
.stat-card,
.growth-section,
.section {
  background: #FFFFFF;
  border-radius: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.header-card {
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 30rpx;
  color: #86868B;
  margin-bottom: 10rpx;
}

.net-value {
  display: block;
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1.2;
}

.header-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 27rpx;
  color: #8B6914;
  font-weight: 600;
}

.positive,
.good {
  color: #2E7D32;
}

.negative,
.bad {
  color: #C62828;
}

.level-badge {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
}

.level-badge text {
  font-size: 27rpx;
  font-weight: 650;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  padding: 24rpx;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 43rpx;
  font-weight: 750;
  color: #1D1D1F;
}

.stat-num.good {
  color: #2E7D32;
}

.stat-num.bad {
  color: #C62828;
}

.stat-label {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #8E8E93;
}

.growth-section {
  padding: 26rpx 24rpx 24rpx;
  margin-bottom: 20rpx;
}

.growth-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.growth-title,
.growth-subtitle {
  display: block;
}

.growth-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1D1D1F;
}

.growth-subtitle {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #8E8E93;
}

.growth-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.growth-item {
  min-height: 112rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #F8F8FA;
  box-sizing: border-box;
}

.growth-item.primary {
  background: linear-gradient(135deg, #FFF7E6 0%, #F4FAEA 100%);
}

.growth-num {
  display: block;
  font-size: 39rpx;
  font-weight: 800;
  color: #1D1D1F;
  line-height: 1.2;
}

.growth-label {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.3;
}

.section {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 16rpx;
}

.category-row,
.record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.category-row:first-of-type,
.record-row:first-of-type {
  border-top: none;
}

.category-name,
.record-date {
  font-size: 30rpx;
  color: #1D1D1F;
  font-weight: 600;
}

.category-value,
.record-net {
  font-size: 32rpx;
  font-weight: 750;
}

.record-main {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.record-meta {
  font-size: 25rpx;
  color: #8E8E93;
}

.empty {
  padding: 36rpx 0 16rpx;
  text-align: center;
  color: #AEAEB2;
  font-size: 28rpx;
}
