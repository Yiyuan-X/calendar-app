<!--pages/merit/merit.wxml — 功过格-->
<view class="page-container {{elderMode ? 'elder-mode' : ''}}">

  <!-- 日期头部 + 引文 -->
  <view class="header-section">
    <view class="date-header">
      <text class="date-main">{{displayDate}}</text>
      <text class="date-sub">{{weekdayText}}</text>
    </view>

    <!-- 每日修身金句 -->
    <view class="quote-card" wx:if="{{dailyQuote}}">
      <text class="quote-mark">「</text>
      <text class="quote-text">{{dailyQuote.text}}</text>
      <text class="quote-close">」</text>
      <text class="quote-source">— {{dailyQuote.source}}</text>
    </view>
  </view>

  <!-- 积善总览卡片 -->
  <view class="overview-card" wx:if="{{selectedItems.length > 0 || hasExistingRecord}}">
    <view class="overview-row">
      <view class="overview-item good">
        <text class="overview-label">积善</text>
        <text class="overview-value">+{{currentGoodTotal}}</text>
      </view>
      <view class="overview-divider"></view>
      <view class="overview-item bad">
        <text class="overview-label">削善</text>
        <text class="overview-value">-{{currentBadTotal}}</text>
      </view>
      <view class="overview-divider"></view>
      <view class="overview-item net {{currentNetMerit >= 0 ? 'positive' : 'negative'}}">
        <text class="overview-label">净善</text>
        <text class="overview-value">{{currentNetMerit >= 0 ? '+' : ''}}{{currentNetMerit}}</text>
        <text class="overview-label">功德 {{currentNetGongDe}}</text>
      </view>
    </view>
  </view>

  <!-- 已选统计（只显示分数汇总） -->
  <view class="selected-section" wx:if="{{selectedItems.length > 0}}">
    <view class="section-title-row">
      <text class="section-title-text">今日记录</text>
      <text class="selected-count">{{selectedItems.length}} 条</text>
    </view>

    <!-- 善行组 -->
    <view class="selected-group" wx:if="{{currentGoodTotal > 0}}">
      <view class="group-label group-label-good">
        <image class="group-label-icon-img" src="/images/icons/gen-check.svg" mode="aspectFit"></image>
        <text class="group-label-text">积善</text>
        <text class="group-label-total">+{{currentGoodTotal}}</text>
      </view>
    </view>

    <!-- 过失组 -->
    <view class="selected-group" wx:if="{{currentBadTotal > 0}}">
      <view class="group-label group-label-bad">
        <image class="group-label-icon-img" src="/images/icons/gen-cross.svg" mode="aspectFit"></image>
        <text class="group-label-text">削善</text>
        <text class="group-label-total">-{{currentBadTotal}}</text>
      </view>
    </view>
  </view>

  <!-- ==================== 内置条目区域（默认收起，避免页面过长） ==================== -->
  <view class="builtin-toggle card" bindtap="toggleBuiltinItems">
    <view class="builtin-toggle-main">
      <text class="builtin-toggle-title">积善方法条目</text>
      <text class="builtin-toggle-desc">{{showBuiltinItems ? '收起后页面更短，方便快速上拉' : '默认隐藏，需要时展开记录积善或削善'}}</text>
    </view>
    <text class="builtin-toggle-action">{{showBuiltinItems ? '收起' : '展开'}}</text>
  </view>

  <view class="builtin-list" wx:if="{{showBuiltinItems}}">
    <!-- 善行分类（累计模式：点击 +1，长按删除） -->
    <view class="category-section" wx:for="{{goodCategories}}" wx:key="id">
      <view class="category-header good-header">
        <image class="category-icon-img" src="{{item.iconPath}}" mode="aspectFit"></image>
        <text class="category-name">{{item.name}}</text>
        <text class="category-desc">{{item.desc}}</text>
      </view>
      <view class="items-grid">
        <view
          class="merit-item good-item {{mItem.count > 0 ? 'has-count' : ''}}"
          wx:for="{{item.items}}"
          wx:for-item="mItem"
          wx:for-index="mIdx"
          wx:key="id"
        >
          <!-- 减少按钮 -->
          <view
            class="item-btn item-btn-dec"
            wx:if="{{mItem.count > 0}}"
            catchtap="onDecrementGoodItem"
            data-item-id="{{mItem.id}}"
          ><text>−</text></view>
          <view class="item-btn item-btn-dec item-btn-placeholder" wx:else></view>

          <!-- 中间内容区（点击 +1） -->
          <view class="item-body" bindtap="onToggleGoodItem" bindlongpress="onLongPressBuiltinItem" data-category-id="{{item.id}}" data-category-name="{{item.name}}" data-item-id="{{mItem.id}}" data-text="{{mItem.text}}" data-merit="{{mItem.merit}}" data-type="good">
            <view class="item-check {{mItem.count > 0 ? 'checked' : ''}} good">
              <text wx:if="{{mItem.count > 0}}">✓</text>
            </view>
            <text class="item-text">{{mItem.text}}</text>
          </view>

          <!-- 右侧分数 + 增加按钮 -->
          <view class="item-right">
            <text class="item-points">+{{mItem.merit}}</text>
            <view class="count-bubble count-good" wx:if="{{mItem.count > 0}}"><text>{{mItem.count}}</text></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 恶行分类（累计模式：点击 +1，长按删除） -->
    <view class="category-section" wx:for="{{badCategories}}" wx:key="id">
      <view class="category-header bad-header">
        <image class="category-icon-img" src="{{item.iconPath}}" mode="aspectFit"></image>
        <text class="category-name">{{item.name}}</text>
        <text class="category-desc">{{item.desc}}</text>
      </view>
      <view class="items-grid">
        <view
          class="merit-item bad-item {{mItem.count > 0 ? 'has-count' : ''}}"
          wx:for="{{item.items}}"
          wx:for-item="mItem"
          wx:for-index="mIdx"
          wx:key="id"
        >
          <!-- 减少按钮 -->
          <view
            class="item-btn item-btn-dec btn-bad"
            wx:if="{{mItem.count > 0}}"
            catchtap="onDecrementBadItem"
            data-item-id="{{mItem.id}}"
          ><text>−</text></view>
          <view class="item-btn item-btn-dec item-btn-placeholder" wx:else></view>

          <!-- 中间内容区（点击 +1） -->
          <view class="item-body" bindtap="onToggleBadItem" bindlongpress="onLongPressBuiltinItem" data-category-id="{{item.id}}" data-category-name="{{item.name}}" data-item-id="{{mItem.id}}" data-text="{{mItem.text}}" data-demerit="{{mItem.demerit}}" data-type="bad">
            <view class="item-check {{mItem.count > 0 ? 'checked' : ''}} bad">
              <text wx:if="{{mItem.count > 0}}">✕</text>
            </view>
            <text class="item-text">{{mItem.text}}</text>
          </view>

          <!-- 右侧分数 + 增加按钮 -->
          <view class="item-right">
            <text class="item-points">-{{mItem.demerit}}</text>
            <view class="count-bubble count-bad" wx:if="{{mItem.count > 0}}"><text>{{mItem.count}}</text></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 自定义积善条目区域（累计模式 + 增减按钮） ==================== -->
  <view class="custom-section card">
    <view class="custom-header">
      <view class="custom-title-row">
        <image class="custom-title-icon-img" src="/images/icons/edit.svg" mode="aspectFit"></image>
        <text class="custom-title-text">自定义条目</text>
        <text class="custom-count" wx:if="{{customGoodItems.length + customBadItems.length > 0}}">{{customGoodItems.length + customBadItems.length}}</text>
      </view>
      <view class="custom-add-btns">
        <view class="add-btn add-good" bindtap="onShowAddCustom" data-type="good">
          <text>+ 积善</text>
        </view>
        <view class="add-btn add-bad" bindtap="onShowAddCustom" data-type="bad">
          <text>+ 削善</text>
        </view>
      </view>
    </view>

    <!-- 自定义积善列表（带增减按钮） -->
    <view class="custom-group" wx:if="{{customGoodItems.length > 0}}">
      <view class="custom-group-label good-label">
        <view class="custom-group-label-icon"><image class="leaf-icon-sm" src="/images/icons/leaf.svg" mode="aspectFit"></image><text>自定义积善（{{customGoodItems.length}}）</text></view>
      </view>
      <view class="custom-items-list">
        <view
          class="custom-item-row {{cItem.selected ? 'selected-good' : ''}} {{cItem.count > 0 ? 'has-count' : ''}}"
          wx:for="{{customGoodItems}}"
          wx:for-item="cItem"
          wx:key="id"
        >
          <!-- 点击区域：增加 +1 -->
          <view class="custom-item-body" bindtap="onIncrementCustomGood" data-item-id="{{cItem.id}}" data-text="{{cItem.text}}" data-merit="{{cItem.merit}}">
            <view class="custom-check {{cItem.selected ? 'checked' : ''}} good">
              <text wx:if="{{cItem.selected}}">✓</text>
            </view>
            <text class="custom-item-text">{{cItem.text}}</text>
            <text class="custom-item-score score-good">+{{cItem.merit}}</text>
            <!-- 累计次数 -->
            <view class="count-bubble count-good-custom" wx:if="{{cItem.count > 0}}">
              <text>{{cItem.count}}</text>
            </view>
          </view>
          <!-- 操作区：减少 -1 / 编辑 / 删除 -->
          <view class="custom-item-actions">
            <!-- 减少按钮（仅在已选时显示） -->
            <view
              class="action-decrement"
              wx:if="{{cItem.count > 0}}"
              catchtap="onDecrementCustomGood"
              data-item-id="{{cItem.id}}"
            >
              <text>−</text>
            </view>
            <view class="action-edit" catchtap="onShowEditCustom" data-id="{{cItem.id}}">
              <image class="action-edit-img" src="/images/icons/edit.svg" mode="aspectFit"></image>
            </view>
            <view class="action-delete" catchtap="onDeleteCustomItem" data-id="{{cItem.id}}">
              <image class="action-delete-img" src="/images/icons/gen-cross.svg" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 自定义削善列表（带增减按钮） -->
    <view class="custom-group" wx:if="{{customBadItems.length > 0}}">
      <view class="custom-group-label bad-label">
        <image class="custom-group-label-img" src="/images/icons/gen-lightning.svg" mode="aspectFit"></image><text>自定义削善（{{customBadItems.length}}）</text>
      </view>
      <view class="custom-items-list">
        <view
          class="custom-item-row {{cItem.selected ? 'selected-bad' : ''}} {{cItem.count > 0 ? 'has-count' : ''}}"
          wx:for="{{customBadItems}}"
          wx:for-item="cItem"
          wx:key="id"
        >
          <!-- 点击区域：增加 +1 -->
          <view class="custom-item-body" bindtap="onIncrementCustomBad" data-item-id="{{cItem.id}}" data-text="{{cItem.text}}" data-demerit="{{cItem.demerit}}">
            <view class="custom-check {{cItem.selected ? 'checked' : ''}} bad">
              <text wx:if="{{cItem.selected}}">✕</text>
            </view>
            <text class="custom-item-text">{{cItem.text}}</text>
            <text class="custom-item-score score-bad">-{{cItem.demerit}}</text>
            <!-- 累计次数 -->
            <view class="count-bubble count-bad-custom" wx:if="{{cItem.count > 0}}">
              <text>{{cItem.count}}</text>
            </view>
          </view>
          <!-- 操作区：减少 -1 / 编辑 / 删除 -->
          <view class="custom-item-actions">
            <view
              class="action-decrement"
              wx:if="{{cItem.count > 0}}"
              catchtap="onDecrementCustomBad"
              data-item-id="{{cItem.id}}"
            >
              <text>−</text>
            </view>
            <view class="action-edit" catchtap="onShowEditCustom" data-id="{{cItem.id}}">
              <image class="action-edit-img" src="/images/icons/edit.svg" mode="aspectFit"></image>
            </view>
            <view class="action-delete" catchtap="onDeleteCustomItem" data-id="{{cItem.id}}">
              <image class="action-delete-img" src="/images/icons/gen-cross.svg" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态提示 -->
    <view class="custom-empty" wx:if="{{customGoodItems.length === 0 && customBadItems.length === 0}}">
      <text class="empty-text">还没有自定义条目</text>
      <text class="empty-hint">点击上方按钮添加你自己的积善项目</text>
    </view>
  </view>

  <!-- 反省备注 -->
  <view class="reflection-section card">
    <view class="reflection-header">
      <text class="reflection-title">今日反省/学习笔记</text>
    </view>
    <textarea
      class="reflection-editor"
      placeholder="今日有何特别的心得或反省？亦可记录学习笔记或金句。"
      value="{{reflectionNote}}"
      bindinput="onNoteInput"
      auto-height
      maxlength="200"
    ></textarea>
    <view class="editor-footer">
      <text class="char-count">{{reflectionNote.length}}/200</text>
      <text class="reflection-save-btn" catchtap="saveReflectionOnly">保存</text>
    </view>
  </view>

  <!-- 统计概览入口 -->
  <view class="stats-summary card" wx:if="{{stats}}" bindtap="goToStats">
    <view class="summary-header">
      <text class="summary-title">积善累计</text>
      <text class="summary-arrow">›</text>
    </view>
    <view class="summary-body">
      <view class="summary-item">
        <text class="summary-num {{stats.totalNet >= 0 ? 'num-good' : 'num-bad'}}">{{stats.totalNet}}</text>
        <text class="summary-label">净善</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="summary-num num-good">{{stats.totalNetGongDe}}</text>
        <text class="summary-label">功德</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="summary-num num-good">{{streakDays}}</text>
        <text class="summary-label">连续天数</text>
      </view>
    </view>
    <view class="level-badge" wx:if="{{meritLevel}}" style="background: {{meritLevel.color}}15; color: {{meritLevel.color}};">
      <text>{{meritLevel.title}} — {{meritLevel.desc}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button
      class="save-btn {{selectedItems.length > 0 || reflectionNote.trim() ? '' : 'disabled'}}"
      disabled="{{selectedItems.length === 0 && !reflectionNote.trim()}}"
      bindtap="onSave"
    >
      {{hasExistingRecord ? '更新积善' : '记录今日积善'}}
    </button>

    <button
      class="clear-btn"
      wx:if="{{hasExistingRecord}}"
      bindtap="onClear"
    >
      清除记录
    </button>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-spacer safe-area-bottom"></view>
</view>

<!-- ==================== 自定义条目弹窗 ==================== -->
<view class="modal-mask" wx:if="{{showCustomModal}}" bindtap="onCloseCustomModal"></view>
<view class="custom-modal {{showCustomModal ? 'show' : ''}}" wx:if="{{showCustomModal}}">
  <view class="modal-content">
    <!-- 弹窗标题 -->
    <view class="modal-head">
      <text class="modal-title">{{customModalMode === 'add' ? '添加自定义条目' : '编辑自定义条目'}}</text>
      <view class="modal-close" bindtap="onCloseCustomModal">
        <image class="modal-close-img" src="/images/icons/gen-cross.svg" mode="aspectFit"></image>
      </view>
    </view>

    <!-- 类型切换 -->
    <view class="type-switch">
      <view
        class="type-option {{customEditType === 'good' ? 'active-good' : ''}}"
        bindtap="onCustomTypeSwitch"
        data-type="good"
      >
        <image class="type-option-icon" src="/images/icons/gen-check.svg" mode="aspectFit"></image><text>积善</text>
      </view>
      <view
        class="type-option {{customEditType === 'bad' ? 'active-bad' : ''}}"
        bindtap="onCustomTypeSwitch"
        data-type="bad"
      >
        <image class="type-option-icon" src="/images/icons/gen-cross.svg" mode="aspectFit"></image><text>削善</text>
      </view>
    </view>

    <!-- 内容输入 -->
    <view class="form-group">
      <text class="form-label">条目内容</text>
      <input
        class="form-input"
        placeholder="{{customEditPlaceholder}}"
        value="{{customEditText}}"
        bindinput="onCustomTextInput"
        maxlength="30"
        confirm-type="done"
      />
    </view>

    <!-- 分数设置（可自由输入） -->
    <view class="form-group">
      <text class="form-label">善数（{{customEditType === 'good' ? '积善' : '削善'}}）</text>
      <view class="score-input-row">
        <input
          class="score-number-input"
          type="number"
          placeholder="可输入任意正整数"
          value="{{customEditScore}}"
          bindinput="onCustomScoreInput"
        />
        <text class="score-unit">善</text>
      </view>
      <!-- 快捷选择 -->
      <view class="score-quick-btns">
        <view
          class="quick-btn {{customEditScore === s ? 'active' : ''}}"
          wx:for="{{[1, 3, 5, 10, 20, 50]}}"
          wx:key="*this"
          wx:for-item="s"
          bindtap="onQuickScore"
          data-score="{{s}}"
        >
          <text>{{s}}</text>
        </view>
      </view>
    </view>

    <!-- 确认按钮 -->
    <button class="modal-confirm-btn {{customEditType === 'good' ? 'btn-good' : 'btn-bad'}}" bindtap="onConfirmCustom">
      {{customModalMode === 'add' ? '确认添加' : '确认修改'}}
    </button>
  </view>
</view>

<!-- 分享操作栏 -->
<view class="share-bar">
  <button class="share-btn share-btn-primary" open-type="share">
    <image class="share-btn-icon" src="/images/icons/share-wechat.svg" mode="aspectFit"></image>
    <text class="share-btn-text">一键分享</text>
  </button>
  <button class="share-btn share-btn-primary" bindtap="shareToMoments">
    <image class="share-btn-icon" src="/images/icons/share-moments.svg" mode="aspectFit"></image>
    <text class="share-btn-text">朋友圈</text>
  </button>
  <button class="share-btn share-btn-save" bindtap="saveImage">
    <image class="share-btn-icon" src="/images/icons/save.svg" mode="aspectFit"></image>
    <text class="share-btn-text">保存</text>
  </button>
  <button class="share-btn share-btn-export" bindtap="exportMeritRecords">
    <image class="share-btn-icon" src="/images/icons/scroll.svg" mode="aspectFit"></image>
    <text class="share-btn-text">导出</text>
  </button>
</view>

<!-- 底部留白 -->
<view class="bottom-spacer safe-area-bottom"></view>

<!-- 隐藏的 Canvas（用于生成分享海报） -->
<canvas type="2d" id="shareCanvas" style="position:fixed;left:-9999px;top:-9999px;width:500px;height:750px;"></canvas>
