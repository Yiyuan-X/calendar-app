.export-page {
  min-height: 100vh;
  padding: 30rpx 28rpx 0;
  background: linear-gradient(180deg, #FAF3EA 0%, #F8F6F1 100%);
  color: #3D3028;
}

.preview-shell {
  min-height: 930rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview {
  width: 640rpx;
  border-radius: 8rpx;
  box-shadow: 0 18rpx 60rpx rgba(62, 44, 28, 0.16);
}

.generating {
  width: 640rpx;
  height: 854rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  border-radius: 8rpx;
  background: #FFFDF8;
  color: #9C7D5E;
  font-size: 28rpx;
}

.loader {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 6rpx solid #E8DDD0;
  border-top-color: #A77E50;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin: 18rpx 0 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 800;
  color: #3D3028;
}

.sub {
  font-size: 25rpx;
  color: #9C8A7A;
}

.actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1fr 1.4fr;
  gap: 14rpx;
  padding: 18rpx 24rpx;
  background: rgba(255, 252, 247, 0.96);
  border-top: 1rpx solid rgba(125, 92, 61, 0.12);
}

.btn {
  height: 78rpx;
  padding: 0;
  margin: 0;
  border-radius: 10rpx;
  font-size: 27rpx;
  font-weight: 800;
}

.btn::after {
  border: 0;
}

.btn.ghost {
  color: #8A6847;
  background: #F1E6D9;
}

.btn.primary {
  color: #FFFFFF;
  background: linear-gradient(135deg, #B58A57, #8B623D);
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750px;
  height: 1000px;
}
