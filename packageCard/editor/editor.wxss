  box-shadow: 0 4rpx 14rpx rgba(218, 165, 32, 0.22);
}

.size-btn::after {
  border: 0;
}

.bg-palette {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.bg-swatch {
  height: 50rpx;
  border-radius: 12rpx;
  border: 2rpx solid rgba(125, 92, 61, 0.12);
  box-shadow: 0 3rpx 10rpx rgba(109, 79, 48, 0.08);
}

.bg-swatch.active {
  border-color: #FFFFFF;
  box-shadow: 0 0 0 4rpx rgba(218, 165, 32, 0.48), 0 6rpx 16rpx rgba(139, 105, 20, 0.12);
}

.bottom-actions {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  margin-top: auto;
  background: transparent;
  box-shadow: none;
}

/* 我的草稿入口 */
.draft-entry {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 0 18rpx;
  height: 68rpx;
  border-radius: 10rpx;
  background: #FFFFFF;
  border: 2rpx solid rgba(139, 105, 20, 0.14);
