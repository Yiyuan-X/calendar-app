  margin: 0;
  border-radius: 10rpx;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 68rpx;
}

.action.ghost {
  color: #8B6914;
  background: #FFFFFF;
  box-shadow: inset 0 0 0 2rpx rgba(139, 105, 20, 0.18);
