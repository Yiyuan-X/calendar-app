  height: 74rpx;
  padding: 7rpx 6rpx;
  margin: 0;
  border-radius: 10rpx;
  color: #6D5138;
  background: #F7F0E7;
  border: 2rpx solid rgba(139, 105, 20, 0.10);
  box-shadow: 0 3rpx 10rpx rgba(109, 79, 48, 0.05);
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0;
  line-height: 1.15;
