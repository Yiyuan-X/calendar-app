.editor-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: linear-gradient(180deg, #F7F0E8 0%, #F3EAE0 48%, #FFFCF7 100%);
  color: #3D3028;
}

.stage-wrap {
  flex: 0 0 720rpx;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0 14rpx;
}

.poster-stage {
  position: relative;
  width: 520rpx;
  height: 693rpx;
  overflow: hidden;
  border-radius: 8rpx;
  box-shadow: 0 14rpx 44rpx rgba(62, 44, 28, 0.15);
  background-size: cover;
  background-position: center;
}

.stage-bg-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.stage-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
}

.stage-mask.blur {
  background: rgba(255,255,255,0.22);
  backdrop-filter: blur(12px);
}

.movable-area {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  width: 520rpx;
  height: 693rpx;
  z-index: 2;
}

.text-block {
  min-height: 48rpx;
  padding: 0;
  color: #4B4038;
  overflow: visible;
}

.text-block.active {
  outline: 2rpx solid rgba(167, 126, 80, 0.72);
  background: rgba(255,255,255,0.16);
}

.qr-preview {
  position: absolute;
  right: 64rpx;
  bottom: 64rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 6rpx;
  z-index: 3;
}

.editor-card {
  flex: 1;
  min-height: 0;
  max-height: none;
  padding: 16rpx 22rpx 18rpx;
  background: #FFFCF7;
  border-top: 1rpx solid rgba(125, 92, 61, 0.12);
  box-sizing: border-box;
}

.rich-editor {
  min-height: 118rpx;
  max-height: 150rpx;
  padding: 16rpx 18rpx;
  border-radius: 8rpx;
  background: #F7F1EA;
  font-size: 30rpx;
  color: #3D3028;
}

.auto-panel {
  padding: 16rpx;
  border-radius: 8rpx;
  background: linear-gradient(180deg, #FFF8ED 0%, #F7EBDC 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.auto-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.auto-title,
.auto-sub {
  display: block;
}

.auto-title {
  color: #5D4037;
  font-size: 30rpx;
  font-weight: 900;
}

.auto-sub {
  margin-top: 4rpx;
  color: #9A7A5B;
  font-size: 23rpx;
}

.auto-btn {
  width: 104rpx;
  height: 58rpx;
  padding: 0;
  margin: 0;
  border-radius: 8rpx;
  color: #FFFFFF;
  background: #A77E50;
  font-size: 25rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.auto-btn::after,
.style-pill::after {
  border: 0;
}

.sentence-input {
  width: 100%;
  min-height: 92rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: rgba(255, 252, 247, 0.82);
  color: #4B382D;
  font-size: 30rpx;
  line-height: 1.62;
  box-sizing: border-box;
}

.style-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 14rpx;
}

.style-pill {
  height: 54rpx;
  padding: 0 8rpx;
  margin: 0;
  border-radius: 8rpx;
  background: rgba(244, 236, 226, 0.92);
  color: #7B6048;
  font-size: 23rpx;
  font-weight: 800;
}

.style-pill.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #B58A57, #8B623D);
}

.panel-section {
  margin-top: 14rpx;
  padding: 12rpx;
  border-radius: 8rpx;
  background: #FBF6EF;
}

.panel-section.compact {
  padding-bottom: 14rpx;
}

.section-head {
  display: flex;
  align-items: center;
  height: 30rpx;
  margin-bottom: 8rpx;
}

.section-head text {
  color: #9C7B5A;
  font-size: 23rpx;
  font-weight: 800;
}

.toolbar,
.swatches,
.font-row,
.seg-row,
.background-row {
  display: flex;
  gap: 10rpx;
  margin-top: 10rpx;
}

.tool {
  flex: 1;
  min-width: 0;
  height: 54rpx;
  padding: 0;
  margin: 0;
  border-radius: 8rpx;
  background: #F1E6D9;
  color: #6D5138;
  font-size: 25rpx;
  font-weight: 800;
}

.tool.on {
  color: #FFFFFF;
  background: #A77E50;
}

.tool::after,
.seg::after,
.bg-btn::after,
.action::after {
  border: 0;
}

.swatch {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 2rpx 10rpx rgba(60, 43, 28, 0.12);
}

.font-btn {
  flex: 1;
  height: 54rpx;
  padding: 0 8rpx;
  margin: 0;
  border-radius: 8rpx;
  color: #6D5138;
  background: #F4ECE2;
  font-size: 24rpx;
  font-weight: 700;
}

.font-btn::after {
  border: 0;
}

.control-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 52rpx;
}

.label {
  width: 64rpx;
  font-size: 25rpx;
  color: #8A7461;
  font-weight: 700;
}

.slider {
  flex: 1;
}

.value {
  width: 52rpx;
  text-align: right;
  font-size: 24rpx;
  color: #A77E50;
}

.seg,
.bg-btn {
  flex: 1;
  height: 54rpx;
  padding: 0 8rpx;
  margin: 0;
  border-radius: 8rpx;
  background: #F4ECE2;
  color: #6D5138;
  font-size: 24rpx;
  font-weight: 700;
}

.bottom-actions {
  display: grid;
  grid-template-columns: 1fr 1.45fr;
  gap: 16rpx;
  padding: 14rpx 22rpx;
  background: #FFFCF7;
  box-shadow: 0 -8rpx 24rpx rgba(66, 47, 31, 0.05);
}

.action {
  height: 72rpx;
  margin: 0;
  border-radius: 10rpx;
  font-size: 29rpx;
  font-weight: 800;
}

.action.ghost {
  color: #8A6847;
  background: #F1E6D9;
}

.action.primary {
  color: #FFFFFF;
  background: linear-gradient(135deg, #B58A57, #8B623D);
  box-shadow: 0 8rpx 24rpx rgba(139, 98, 61, 0.24);
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750px;
  height: 1000px;
}
