  color: #9A7215;
}

.font-btn::after {
  border: 0;
}

.control-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 50rpx;
}

.label {
  width: 64rpx;
  font-size: 25rpx;
  color: #9A7A5B;
  font-weight: 700;
}

.slider {
