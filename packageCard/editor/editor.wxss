}

.draft-list-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #9A7A5B;
  border-radius: 50%;
  background: transparent;
}

.draft-list-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 16rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 空状态 */
.draft-list-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0 80rpx;
}

.draft-list-empty-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.draft-list-empty-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #9A7A5B;
  margin-bottom: 10rpx;
}

.draft-list-empty-hint {
  font-size: 24rpx;
  color: #B8A08A;
}

/* 草稿项 */
.draft-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx;
  margin-bottom: 12rpx;
  background: #FBF6EF;
  border-radius: 14rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  transition: border-color 0.15s ease;
}

.draft-item:active {
  border-color: rgba(218, 165, 32, 0.36);
}

.draft-item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.draft-item-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #3D3028;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.draft-item-time {
  font-size: 23rpx;
  color: #B8A08A;
}

.draft-item-actions {
  flex-shrink: 0;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
}

.draft-item-delete {
  padding: 8rpx 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #C62828;
  background: #FFF5F2;
  border-radius: 8rpx;
}
