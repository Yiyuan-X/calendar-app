}

.font-btn-name {
  display: block;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.12;
}

.font-btn-mood {
  display: block;
  max-width: 100%;
  color: #A08365;
  font-size: 17rpx;
  font-weight: 500;
  line-height: 1.1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

