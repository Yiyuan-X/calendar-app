.editor-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FFFDF7 0%, #F6F4EF 100%);
  color: #5D4037;
  overflow: hidden;
  position: relative;
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
}

.stage-wrap {
  flex: 1 1 auto;
  width: 100%;
  min-height: 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 18rpx 0 74rpx;
  background: linear-gradient(180deg, #FFFDF7 0%, #F6F4EF 100%);
  position: relative;
  z-index: 1;
  overflow: visible;
}

.poster-stage {
  position: relative;
  width: 680rpx;
  height: 907rpx;
  overflow: visible;
  border-radius: 12rpx;
  box-shadow: 0 12rpx 36rpx rgba(109, 79, 48, 0.12);
  background-size: cover;
  background-position: center;
}

.preview-canvas {
  position: absolute;
  left: 0;
  top: 0;
  width: 680rpx;
  height: 907rpx;
  z-index: 1;
  border-radius: 12rpx;
  overflow: hidden;
  pointer-events: none;
  opacity: 1;
}

.stage-bg-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

/* 背景图容器：占满画布区域 */
.bg-image-container {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  z-index: 1;
  border-radius: 12rpx;
}

.poster-stage.bg-editing .bg-image-container {
  z-index: 3;
}

.bg-canvas-touch {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
}

/* 背景编辑模式下：文字框可见，但触摸优先给背景图拖动 */
.poster-stage.bg-editing .movable-area {
  display: block;
  pointer-events: none;
  z-index: 10;
}

.poster-stage.bg-editing .stage-mask,
.poster-stage.bg-editing .cross-guide {
  z-index: 4;
}

.bg-image-container .stage-bg-image {
  position: absolute;
  left: 50%;
  top: 50%;
  transform-origin: center center;
  object-fit: contain;
}

/* 撤销 / 重做 工具栏（标签栏内联样式） */
.undo-redo-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 10rpx 20rpx;
  margin-bottom: 8rpx;
}

/* 标签栏内的撤销/重做按钮（紧凑图标版） */
.editor-tabs .undo-btn,
.editor-tabs .redo-btn {
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  border-radius: 12rpx;
}

/* 独立工具栏的撤销/重做按钮（完整文字版） */

.undo-btn,
.redo-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 8rpx 22rpx;
  background: linear-gradient(135deg, #F5ECD8, #EDD9B3);
  border: 1.5rpx solid rgba(180, 140, 50, 0.35);
  border-radius: 999rpx;
  color: #8B6914;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 0.5rpx;
  box-shadow: 0 2rpx 10rpx rgba(139, 105, 20, 0.12);
  transition: all 0.15s ease;
}

.undo-btn:active,
.redo-btn:active {
  background: linear-gradient(135deg, #FFECB3, #FFE082);
  transform: scale(0.95);
  opacity: 0.85;
}

.undo-btn.disabled,
.redo-btn.disabled {
  background: #F5F5F7;
  border-color: #E0E0E2;
  color: #C7C7CC;
  pointer-events: none;
  box-shadow: none;
}
.bg-drag-hint {
  position: absolute;
  bottom: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 6rpx 20rpx;
  background: rgba(0, 0, 0, 0.45);
  color: rgba(255, 255, 255, 0.85);
  font-size: 22rpx;
  border-radius: 20rpx;
  z-index: 5;
  pointer-events: none;
  white-space: nowrap;
}

/* 文字块容器（替代 movable-view，用绝对定位） */
.text-block-wrapper {
  position: absolute;
  box-sizing: border-box;
}

/* 调整大小手柄覆盖层（在 movable-area 上层，独立于文字框） */
.resize-handles-overlay {
  z-index: 15;
  pointer-events: auto;
}

.resize-edit-hotspot {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 18rpx;
  bottom: 18rpx;
  z-index: 1;
}

.resize-handle {
  z-index: 2;
}
.cross-guide {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  pointer-events: none;
}

.cross-guide::before,
.cross-guide::after {
  content: '';
  position: absolute;
  background: rgba(0, 0, 0, 0.12);
}

.cross-guide::before {
  left: 50%;
  top: 0;
  bottom: 0;
  width: 1rpx;
  transform: translateX(-50%);
}

.cross-guide::after {
  top: 50%;
  left: 0;
  right: 0;
  height: 1rpx;
  transform: translateY(-50%);
}

.stage-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 2;
}

.stage-mask.blur {
  background: rgba(255,255,255,0.22);
}

.movable-area {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  width: 680rpx;
  height: 907rpx;
  z-index: 10;
  overflow: visible;
}

.text-block {
  min-height: 48rpx;
  padding: 0;
  color: #4B4038;
  overflow: visible;
  box-sizing: border-box;
  position: relative;
  border: 1.5rpx solid transparent;
  border-radius: 8rpx;
  background: transparent;
}

.text-block:not(.active) {
  border-color: transparent;
  background: transparent;
}

.text-block.active {
  border-color: transparent;
}

.block-control {
  position: absolute;
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.96);
  color: #6D5138;
  font-size: 26rpx;
  font-weight: 800;
  border-radius: 50%;
  box-shadow: 0 5rpx 16rpx rgba(109, 79, 48, 0.16);
  z-index: 13;
  line-height: 1;
}

.block-control.delete {
  right: -20rpx;
  top: -20rpx;
  color: #C62828;
  background: #FFF5F2;
  box-shadow: 0 5rpx 16rpx rgba(198, 40, 40, 0.12);
}

.block-control.copy {
  left: -20rpx;
  top: -20rpx;
  background: #FFFDF7;
}

.block-control.rotate {
  left: 50%;
  bottom: -72rpx;
  transform: translateX(-50%);
}

/* 调整大小手柄（四角 + 四边，共8个） */
.resize-handle {
  position: absolute;
  width: 26rpx;
  height: 26rpx;
  background: #FFFFFF;
  border: 3rpx solid #F1B62D;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(139, 105, 20, 0.18);
  z-index: 12;
  box-sizing: border-box;
}

.resize-handle:active {
  background: #FFF3D6;
  transform: scale(1.2);
}

/* 四角手柄 */
.resize-tl { left: -13rpx; top: -13rpx; }
.resize-tm { left: 50%; top: -13rpx; transform: translateX(-50%); }
.resize-tr { right: -13rpx; top: -13rpx; }
.resize-ml { left: -13rpx; top: 50%; transform: translateY(-50%); }
.resize-mr { right: -13rpx; top: 50%; transform: translateY(-50%); }
.resize-bl { left: -13rpx; bottom: -13rpx; }
.resize-bm { left: 50%; bottom: -13rpx; transform: translateX(-50%); }
.resize-br { right: -13rpx; bottom: -13rpx; }

.resize-tl::before,
.resize-tl::after,
.resize-tr::before,
.resize-tr::after,
.resize-bl::before,
.resize-bl::after,
.resize-br::before,
.resize-br::after {
  display: none;
}

.resize-tm::before,
.resize-bm::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 10rpx;
  height: 4rpx;
  background: #F1B62D;
  border-radius: 2rpx;
  transform: translate(-50%, -50%);
}
.resize-ml::before,
.resize-mr::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 4rpx;
  height: 10rpx;
  background: #F1B62D;
  border-radius: 2rpx;
  transform: translate(-50%, -50%);
}

.placeholder-text {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 120rpx;
  padding: 14rpx 24rpx;
  border: 2rpx dashed rgba(175, 126, 82, 0.34);
  border-radius: 8rpx;
  background: rgba(255, 250, 241, 0.58);
  color: rgba(83, 60, 41, 0.48);
  font-size: 30rpx;
  font-weight: 700;
  text-align: inherit;
  line-height: inherit;
  box-shadow: none;
  box-sizing: border-box;
}

.text-block.vertical .placeholder-text,
.text-block.vertical .stage-editor,
.text-block.vertical .block-rich-text {
  writing-mode: vertical-rl;
  text-orientation: upright;
}

.text-block.vertical .placeholder-text,
.text-block.vertical .stage-editor {
  line-height: 1.45;
}

.text-block.active {
  outline: none;
  background: transparent;
  box-shadow: none;
}

.text-block.active::before,
.text-block.active::after {
  display: none;
}

.text-block.active::before {
  left: -12rpx;
  top: -12rpx;
}

.text-block.active::after {
  right: -12rpx;
  bottom: -12rpx;
}

.block-rich-text {
  display: block;
  width: 100%;
  height: 100%;
  white-space: pre-wrap;
  word-break: break-all;
  overflow-wrap: anywhere;
}

.stage-editor {
  position: absolute;
  left: 0;
  top: 0;
  display: block;
  width: 100%;
  height: 100%;
  min-height: 120rpx;
  padding: 14rpx 24rpx;
  margin: 0;
  color: transparent;
  -webkit-text-fill-color: transparent;
  caret-color: transparent;
  opacity: 0;
  background: transparent;
  font-size: 30rpx;
  line-height: inherit;
  text-align: inherit;
  border: 2rpx solid transparent;
  border-radius: 8rpx;
  box-sizing: border-box;
  z-index: 5;
  outline: none;
}

.custom-caret {
  position: absolute;
  z-index: 9;
  width: 4rpx;
  background: #34C759;
  border-radius: 999rpx;
  pointer-events: none;
  animation: customCaretBlink 1s steps(2, start) infinite;
}

@keyframes customCaretBlink {
  50% {
    opacity: 0;
  }
}

.edit-block-actions {
  position: absolute;
  right: -56rpx;
  top: 50%;
  z-index: 18;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  transform: translateY(-50%);
}

.edit-block-action {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6D5138;
  background: rgba(255, 253, 247, 0.96);
  border-radius: 50%;
  box-shadow: 0 5rpx 16rpx rgba(109, 79, 48, 0.18);
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
}

.edit-block-action.delete {
  color: #C62828;
  background: #FFF5F2;
}

.edit-block-action:active {
  transform: scale(0.94);
}

.stage-editor.selection-mode {
  color: transparent;
  -webkit-text-fill-color: transparent;
  caret-color: transparent;
  opacity: 0;
  background: transparent;
  white-space: pre-wrap;
  overflow: visible;
}

.selection-overlay {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 8;
  width: 100%;
  height: 100%;
  min-height: 120rpx;
  padding: 0;
  border: 0;
  box-sizing: border-box;
  pointer-events: auto;
}

.selection-rect {
  position: absolute;
  z-index: 9;
  background: rgba(255, 211, 78, 0.14);
  border-radius: 6rpx;
  pointer-events: none;
}

.selection-mode-text {
  display: block;
  width: 100%;
  height: 100%;
}

.selection-flow-text {
  display: block;
  width: 100%;
  height: 100%;
  line-height: inherit;
  text-align: inherit;
  white-space: pre-wrap;
  word-break: break-all;
  overflow-wrap: anywhere;
}

.selection-segment {
  display: inline;
}

.selection-segment.muted {
  color: transparent !important;
  text-shadow: none !important;
  -webkit-text-stroke: 0 transparent !important;
  background: transparent !important;
}

.selection-segment.selected {
  color: transparent !important;
  text-shadow: none !important;
  -webkit-text-stroke: 0 transparent !important;
  border-radius: 4rpx;
}

.selection-handle {
  position: absolute;
  width: 36rpx;
  height: 54rpx;
  margin-left: -18rpx;
  background: #0A84FF;
  border-radius: 18rpx;
  z-index: 30;
  box-shadow: 0 4rpx 12rpx rgba(10, 132, 255, 0.26);
}

.selection-handle::before {
  content: '';
  position: absolute;
  left: 15rpx;
  top: -30rpx;
  width: 6rpx;
  height: 34rpx;
  background: #0A84FF;
  border-radius: 6rpx;
}

.selection-handle.start {
  margin-left: -34rpx;
}

.selection-handle.end {
  margin-left: -2rpx;
}

.selection-handle.start::before {
  left: 31rpx;
}

.selection-handle.end::before {
  left: -1rpx;
}

.selection-inline-handle {
  display: inline-block;
  position: relative;
  width: 36rpx;
  height: 1em;
  margin-left: -18rpx;
  margin-right: -18rpx;
  vertical-align: text-bottom;
  z-index: 30;
}

.selection-inline-handle::before {
  content: '';
  position: absolute;
  left: -2rpx;
  top: -40rpx;
  width: 6rpx;
  height: 72rpx;
  background: #0A84FF;
  border-radius: 6rpx;
}

.selection-inline-handle::after {
  content: '';
  position: absolute;
  left: -18rpx;
  top: 22rpx;
  width: 38rpx;
  height: 54rpx;
  background: #0A84FF;
  border-radius: 19rpx;
  box-shadow: 0 4rpx 12rpx rgba(10, 132, 255, 0.26);
}

.paste-tip {
  position: absolute;
  left: 50%;
  top: -70rpx;
  z-index: 20;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  max-width: 710rpx;
  min-height: 60rpx;
  padding: 8rpx 12rpx;
  color: #FFFFFF;
  background: rgba(55, 43, 34, 0.94);
  border-radius: 16rpx;
  box-shadow: 0 6rpx 18rpx rgba(55, 43, 34, 0.24);
  box-sizing: border-box;
  overflow-x: auto;
  white-space: nowrap;
  transform: translateX(-50%);
}

.paste-tip::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -10rpx;
  width: 0;
  height: 0;
  margin-left: -10rpx;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 10rpx solid rgba(55, 43, 34, 0.94);
}

.paste-menu-row {
  display: flex;
  flex-direction: row;
  gap: 0;
  width: 100%;
}

.paste-menu-btn {
  flex: 0 0 auto;
  min-width: 58rpx;
  height: 44rpx;
  padding: 0 12rpx;
  color: #FFFFFF;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
  box-sizing: border-box;
}

.paste-menu-btn:not(:first-child) {
  border-left: 0;
}

.paste-menu-btn.danger {
  color: #FF7777;
}

.paste-menu-btn.strong {
  font-size: 27rpx;
}

.paste-menu-btn.on {
  color: #FFD34E;
  background: rgba(255, 255, 255, 0.12);
}

.paste-menu-hint {
  position: absolute;
  display: none;
  left: 50%;
  top: -58rpx;
  z-index: 19;
  min-width: 96rpx;
  height: 44rpx;
  padding: 0 16rpx;
  color: #FFD34E;
  background: rgba(55, 43, 34, 0.88);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
  transform: translateX(-50%);
  box-shadow: 0 4rpx 12rpx rgba(55, 43, 34, 0.18);
}

/* 保留类名兼容旧结构，当前格式菜单已合并进浮层 */
.editor-format-bar {
  position: fixed;
  left: -9999rpx;
  bottom: -9999rpx;
  display: flex;
}

.editor-format-btn {
  flex: 0 0 auto;
  min-width: 66rpx;
  height: 44rpx;
  padding: 0 14rpx;
  color: #4B4038;
  background: transparent;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
  box-sizing: border-box;
}

.editor-format-btn.icon {
  min-width: 46rpx;
  font-size: 28rpx;
}

.editor-format-btn.on {
  color: #8B6914;
  background: #FFF3D6;
}

.editor-format-btn.danger {
  color: #C62828;
}

.editor-format-btn::after {
  border: 0;
}

/* 编辑模式下的文本框：锁定尺寸，隐藏控制按钮 */
.text-block.editing {
  outline: none !important;
  overflow: visible !important;
}

.text-block.editing .block-control,
.text-block.editing .resize-handle,
.text-block.editing .block-rich-text,
.text-block.editing .placeholder-text {
  display: none;
}

.qr-wrap {
  position: absolute;
  right: 64rpx;
  bottom: 64rpx;
  z-index: 3;
}

.qr-preview {
  width: 104rpx;
  height: 104rpx;
  border-radius: 6rpx;
}

.qr-delete {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  font-size: 22rpx;
  line-height: 40rpx;
}

.editor-card {
  flex: 0 0 486rpx;
  width: 100%;
  max-width: 750rpx;
  height: 486rpx;
  min-height: 8rpx;
  position: relative;
  bottom: 98rpx;
  margin-bottom: -98rpx;
  z-index: 3;
  display: flex;
  flex-direction: column;
  padding: 8rpx 24rpx 0;
  background: #FFFCF7;
  border-top: 1rpx solid rgba(125, 92, 61, 0.12);
  box-shadow: 0 -6rpx 24rpx rgba(109, 79, 48, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.editor-tabs {
  display: flex;
  align-items: end;
  height: 66rpx;
  margin-top: 0;
  border-bottom: 1rpx solid rgba(125, 92, 61, 0.12);
}

.editor-tab {
  position: relative;
  min-width: 150rpx;
  height: 66rpx;
  line-height: 66rpx;
  text-align: center;
  color: #9A7A5B;
  font-size: 30rpx;
  font-weight: 800;
}

.editor-tab.active {
  color: #5D4037;
}

.editor-tab.active::after {
  content: '';
  position: absolute;
  left: 34%;
  right: 34%;
  bottom: 0;
  height: 6rpx;
  border-radius: 999rpx;
  background: #DAA520;
}

.panel-body {
  flex: 1;
  min-height: 0;
  padding-top: 8rpx;
  padding-bottom: 18rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.rich-editor {
  min-height: 118rpx;
  max-height: 150rpx;
  padding: 16rpx 18rpx;
  border-radius: 8rpx;
  background: #F7F1EA;
  font-size: 30rpx;
  color: #3D3028;
}

.auto-panel {
  padding: 16rpx;
  border-radius: 8rpx;
  background: linear-gradient(180deg, #FFF8ED 0%, #F7EBDC 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.auto-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.auto-title,
.auto-sub {
  display: block;
}

.auto-title {
  color: #5D4037;
  font-size: 30rpx;
  font-weight: 900;
}

.auto-sub {
  margin-top: 4rpx;
  color: #9A7A5B;
  font-size: 23rpx;
}

.auto-btn {
  width: 104rpx;
  height: 58rpx;
  padding: 0;
  margin: 0;
  border-radius: 8rpx;
  color: #FFFFFF;
  background: #A77E50;
  font-size: 25rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.auto-btn::after,
.style-pill::after {
  border: 0;
}

.sentence-input {
  width: 100%;
  min-height: 92rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: rgba(255, 252, 247, 0.82);
  color: #4B382D;
  font-size: 30rpx;
  line-height: 1.62;
  box-sizing: border-box;
}

.style-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.style-pill {
  height: 62rpx;
  padding: 0 8rpx;
  margin: 0;
  border-radius: 12rpx;
  background: #F4ECE2;
