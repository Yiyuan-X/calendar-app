}

.value {
  width: 52rpx;
  text-align: right;
  font-size: 24rpx;
  color: #B8860B;
}

.seg,
.bg-btn {
  flex: 1;
  height: 66rpx;
  padding: 0 8rpx;
  margin: 0;
  border-radius: 12rpx;
  background: #F4ECE2;
  color: #6D5138;
  font-size: 25rpx;
  font-weight: 700;
}

.asset-mini-row {
  margin-top: 12rpx;
}

.size-row {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 6rpx;
  margin-top: 12rpx;
}

.size-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  min-width: 0;
  padding: 0 2rpx;
  margin: 0;
  border-radius: 10rpx;
  background: #F4ECE2;
  color: #6D5138;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
  box-sizing: border-box;
  overflow: visible;
}

.size-btn.active {
  color: #8B6914;
  background: #FFF3D6;
  box-shadow: inset 0 0 0 3rpx rgba(218, 165, 32, 0.36);
}

.size-btn::after {
  border: 0;
}

/* ===== 自定义尺寸输入 ===== */
.custom-size-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  background: linear-gradient(180deg, #FFF8ED 0%, #F7EBDC 100%);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.custom-size-field {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.custom-size-label {
  font-size: 23rpx;
  font-weight: 700;
  color: #8B7355;
  white-space: nowrap;
  flex-shrink: 0;
}

.custom-size-input {
  flex: 1;
  min-width: 0;
  height: 56rpx;
  padding: 0 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #3D3028;
  background: #FFFFFF;
  border: 2rpx solid rgba(180, 140, 50, 0.20);
