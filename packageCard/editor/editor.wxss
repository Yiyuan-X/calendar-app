}

.action.primary {
  color: #FFFFFF;
  background: linear-gradient(135deg, #DAA520, #B8860B);
  box-shadow: 0 8rpx 26rpx rgba(218, 165, 32, 0.24);
  flex: 1.45;
}

.style-subtabs {
  display: flex;
  gap: 34rpx;
  margin-bottom: 14rpx;
}

.style-subtab {
  color: #9A7A5B;
  font-size: 28rpx;
  font-weight: 800;
}

.style-subtab.active {
  color: #5D4037;
}

.tool-strip {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 16rpx;
}

.style-control-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 58rpx;
  margin-bottom: 12rpx;
}

.style-control-label {
  flex: 0 0 112rpx;
  color: #5D4037;
  font-size: 27rpx;
  font-weight: 800;
}

.opacity-row {
  margin-bottom: 14rpx;
}

.opacity-row .slider {
  flex: 1;
  min-width: 0;
}

.circle-tool,
.current-color {
  width: 56rpx;
  height: 56rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
}

.circle-tool {
  color: #5D4037;
  background: #F4ECE2;
  font-size: 30rpx;
  line-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.circle-tool.on {
  background: #DAA520;
  box-shadow: 0 4rpx 14rpx rgba(218, 165, 32, 0.24);
}

.circle-tool::after {
  border: 0;
}

.tool-check-icon {
  width: 32rpx;
  height: 32rpx;
}

.color-wheel {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF2F67 0%, #FFD447 32%, #36D46A 50%, #37A7FF 72%, #9F5BFF 100%);
}

.thin-line {
  width: 2rpx;
  height: 56rpx;
  background: rgba(125, 92, 61, 0.14);
}

.current-color {
  background: #FFFFFF;
  box-shadow: inset 0 0 0 6rpx #FFFCF7, 0 0 0 4rpx #FFFFFF, 0 3rpx 10rpx rgba(109, 79, 48, 0.08);
}

.panel-label {
  display: block;
  color: #5D4037;
  font-size: 29rpx;
  font-weight: 800;
  margin: 14rpx 0 10rpx;
}

.color-scroll {
  gap: 16rpx;
  overflow-x: auto;
  flex-wrap: nowrap;
  -webkit-overflow-scrolling: touch;
  padding: 4rpx 0 12rpx;
}

.control-stack {
  margin-top: 14rpx;
}

.layout-format-row,
.block-action-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 14rpx;
  margin: 10rpx 0 0;
}

.layout-format-row .format-key {
  flex: 1;
}

.block-action-row {
  margin: 0 0 8rpx;
}

.layout-secondary-actions {
  margin-top: 10rpx;
  padding-bottom: 8rpx;
}

.block-action {
  flex: 1;
  height: 54rpx;
  padding: 0;
  margin: 0;
  border-radius: 12rpx;
  color: #8B6914;
  background: #F4ECE2;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 54rpx;
}

.block-action.danger {
  color: #C62828;
  background: #FFE5E5;
}

.block-action::after {
  border: 0;
}

.format-key {
  height: 52rpx;
  padding: 0;
  margin: 0;
  border-radius: 12rpx;
  background: #F4ECE2;
  color: #6D5138;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 52rpx;
}

.format-key[data-name="italic"] {
  font-style: italic;
}

.format-key[data-name="underline"] {
  text-decoration: underline;
}

.format-key.on {
  background: #FFF3D6;
  color: #8B6914;
  box-shadow: inset 0 0 0 3rpx rgba(218, 165, 32, 0.36);
}

.format-key.mute {
  opacity: 0.72;
}

.format-key::after,
.align-key::after {
  border: 0;
}

.align-row {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.layout-align-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.layout-align-row .align-key {
  flex: 1;
  min-width: 0;
}

.align-key {
  height: 52rpx;
  padding: 0;
  margin: 0;
  border-radius: 12rpx;
  background: #F4ECE2;
  color: #6D5138;
  font-size: 38rpx;
  line-height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.layout-slider-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 42rpx;
  margin-top: 6rpx;
}

.layout-slider-label {
  flex: 0 0 84rpx;
  color: #6D5138;
  font-size: 25rpx;
  font-weight: 800;
}

.layout-slider-row .slider {
  min-width: 0;
}

.align-key.on {
  background: #FFF3D6;
  box-shadow: inset 0 0 0 3rpx rgba(218, 165, 32, 0.36);
}

/* 对齐图标 */
.align-icon {
  width: 36rpx;
  height: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-start;
}

.align-icon .bar {
  width: 100%;
  height: 5rpx;
  background: #6D5138;
  border-radius: 2rpx;
  transition: all 0.15s;
}

.align-icon .bar.short {
  width: 65%;
}

/* 居中 */
.align-icon.center {
  align-items: center;
}

/* 右对齐 */
.align-icon.right {
  align-items: flex-end;
}

.valign-icon {
  width: 36rpx;
  height: 30rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
  position: relative;
}

.valign-icon .v-guide {
  width: 4rpx;
  height: 100%;
  border-radius: 999rpx;
  background: #B89C7C;
  flex-shrink: 0;
}

.valign-icon .v-block {
  width: 8rpx;
  height: 22rpx;
  border-radius: 3rpx;
  background: #6D5138;
}

.valign-icon.top {
  align-items: flex-start;
}

.valign-icon.middle {
  align-items: center;
}

.valign-icon.bottom {
  align-items: flex-end;
}

.valign-icon.middle .v-guide {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.valign-icon.middle .v-block {
  position: relative;
  z-index: 1;
}

.valign-icon.bottom .v-guide {
  order: 1;
}

.valign-icon.bottom .v-block {
  order: 2;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750px;
  height: 1000px;
}

/* ===== 颜色选择器弹窗 ===== */
.color-picker-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(61, 48, 40, 0.34);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.color-picker-popup {
  width: 100%;
  background: #FFFCF7;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 28rpx 48rpx;
  box-sizing: border-box;
  animation: cpSlideUp 0.25s ease-out;
}

@keyframes cpSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.color-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.color-picker-title {
  color: #5D4037;
  font-size: 30rpx;
  font-weight: 700;
}

.color-picker-preview {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  border: 2rpx solid rgba(125, 92, 61, 0.12);
  box-shadow: inset 0 0 0 4rpx rgba(255,255,255,0.6), 0 3rpx 10rpx rgba(109, 79, 48, 0.08);
}

.color-picker-body {
  display: flex;
  gap: 16rpx;
  height: 360rpx;
}

.cp-sv-panel {
  width: 480rpx;
  height: 360rpx;
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
}

.cp-sv-cursor {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  margin-left: -14rpx;
  margin-top: -14rpx;
  border-radius: 50%;
  border: 2rpx solid #FFFFFF;
  box-shadow: 0 0 4rpx rgba(0,0,0,0.5), inset 0 0 2rpx rgba(0,0,0,0.3);
  pointer-events: none;
}

.cp-hue-bar {
  width: 40rpx;
  height: 360rpx;
  border-radius: 20rpx;
  position: relative;
  background: linear-gradient(to bottom, #FF0000, #FFFF00, #00FF00, #00FFFF, #0000FF, #FF00FF, #FF0000);
}

.cp-hue-cursor {
  position: absolute;
  left: -6rpx;
  width: 52rpx;
  height: 16rpx;
  margin-top: -8rpx;
  border-radius: 8rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.4);
  pointer-events: none;
}

.color-picker-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.cp-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  padding: 0;
  margin: 0;
  border: none;
}

.cp-btn::after {
  border: 0;
}

.cp-btn-cancel {
  background: #FFFFFF;
  color: #8B6914;
  box-shadow: inset 0 0 0 2rpx rgba(139, 105, 20, 0.18);
}

.cp-btn-confirm {
  background: linear-gradient(135deg, #DAA520, #B8860B);
  color: #FFFFFF;
}

/* ===== 草稿恢复弹窗 ===== */
.draft-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
