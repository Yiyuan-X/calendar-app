<view class="editor-page">
    <view class="stage-wrap">
    <view class="poster-stage {{activePanel === 'background' && previewBackgroundImage ? 'bg-editing' : ''}}" style="width: {{previewStageWidth}}rpx; height: {{previewStageHeight}}rpx; background: {{previewBackground}};" bindtap="clearTextSelectionAndEditing">
      <canvas type="2d" id="previewCanvas" class="preview-canvas" style="width: {{previewStageWidth}}rpx; height: {{previewStageHeight}}rpx;"></canvas>
      <view class="bg-image-container" wx:if="{{previewBackgroundImage && !useCanvasPreview}}" bindtouchstart="onBgTouchStart" bindtouchmove="onBgTouchMove" bindtouchend="onBgTouchEnd">
        <image
          class="stage-bg-image"
          src="{{previewBackgroundImage}}"
          mode="aspectFit"
          style="width: {{bgDisplayWidth}}rpx; height: {{bgDisplayHeight}}rpx; transform: translate(-50%, -50%) translate({{bgOffsetX}}rpx, {{bgOffsetY}}rpx);"
        ></image>
        <view class="bg-drag-hint">☝ 可拖动调整背景位置</view>
      </view>
      <view
        class="bg-canvas-touch"
        wx:if="{{previewBackgroundImage && useCanvasPreview && activePanel === 'background'}}"
        bindtouchstart="onBgTouchStart"
        bindtouchmove="onBgTouchMove"
        bindtouchend="onBgTouchEnd"
      >
        <view class="bg-drag-hint">☝ 可拖动调整背景位置</view>
      </view>
      <view class="cross-guide" wx:if="{{previewBackgroundImage && !useCanvasPreview}}"></view>
      <view wx:if="{{!useCanvasPreview}}" class="stage-mask {{design.background.blur ? 'blur' : ''}}" style="{{previewBlurStyle}}"></view>
      <movable-area class="movable-area" style="width: {{previewStageWidth}}rpx; height: {{previewStageHeight}}rpx;">
        <view
          wx:for="{{design.blocks}}"
          wx:key="id"
          class="text-block-wrapper"
          style="position: absolute; left: {{item.previewX}}rpx; top: {{item.previewY}}rpx;"
          data-id="{{item.id}}"
          catchtap="editBlockText"
          bindlongpress="editBlockText"
          catchtouchstart="onBlockTouchStart"
          catchtouchmove="onBlockMoveByResize"
          catchtouchend="onBlockTouchEnd"
        >
        <view
          class="text-block {{activeBlockId === item.id ? 'active' : ''}} {{item.previewVerticalClass}} {{inlineEditing && activeBlockId === item.id ? 'editing' : ''}}"
          style="width: {{item.previewWidth}}rpx; {{inlineEditing && activeBlockId === item.id ? item.editingHeightStyle : item.previewHeightStyle}} text-align: {{item.align}}; line-height: {{item.lineHeight}}; {{item.previewFontSizeStyle}} {{item.previewLetterSpacingStyle}} {{item.previewFontFamilyStyle}} {{item.previewTransformStyle}}"
          data-id="{{item.id}}"
          catchtap="editBlockText"
          catchtouchstart="onTextBlockTouchStart"
          catchtouchmove="onTextBlockTouchMove"
          catchtouchend="onTextBlockTouchEnd"
        >
          <!-- 始终使用 canvas 渲染导出效果（与最终图片一致） -->
          <rich-text wx:if="{{!useCanvasPreview}}" class="block-rich-text" node="{{nodeVersion}}" nodes="{{item.previewNodes}}"></rich-text>
          <view wx:if="{{!activePlainText}}" class="placeholder-text">{{item.placeholder || '输入文字...'}}</view>

          <!-- 编辑模式：textarea 在底层接收输入，rich-text 覆盖显示预览 -->
          <textarea
            wx:if="{{inlineEditing && activeBlockId === item.id}}"
            class="stage-editor"
            value="{{activePlainText}}"
            placeholder=""
            focus="{{textInputFocus}}"
            selection-start="{{selectionStart}}"
            selection-end="{{selectionEnd}}"
            maxlength="-1"
            auto-height="{{false}}"
            adjust-position="{{false}}"
            cursor-color="transparent"
            cursor-spacing="24"
            bindinput="onActiveTextInput"
            bindblur="finishInlineEditing"
          ></textarea>
          <view
            wx:if="{{inlineEditing && activeBlockId === item.id && caretVisible && !selectionModeActive}}"
            class="custom-caret"
            style="left: {{caretX}}rpx; top: {{caretY}}rpx; height: {{caretHeight}}rpx;"
          ></view>
          <view
            wx:if="{{inlineEditing && activeBlockId === item.id}}"
            class="edit-block-actions"
            catchtouchstart="keepInlineEditing"
          >
            <view class="edit-block-action copy" data-id="{{item.id}}" catchtouchstart="keepInlineEditing" catchtap="copyActiveBlock" catchtouchend="copyActiveBlock">⧉</view>
            <view class="edit-block-action delete" data-id="{{item.id}}" catchtouchstart="keepInlineEditing" catchtap="deleteActiveBlock" catchtouchend="deleteActiveBlock">×</view>
          </view>
          <view
            wx:if="{{selectionModeActive && activeBlockId === item.id}}"
            class="selection-overlay"
          >
            <view
              wx:for="{{selectionRects}}"
              wx:key="index"
              class="selection-rect"
              style="{{item.style}}"
            ></view>
            <view
              class="selection-handle start"
              data-handle="start"
              style="left: {{selectionHandleStartX}}rpx; top: {{selectionHandleStartY}}rpx;"
              catchtouchstart="onSelectionHandleStart"
              catchtouchmove="onSelectionHandleMove"
              catchtouchend="onSelectionHandleEnd"
            ></view>
            <view
              class="selection-handle end"
              data-handle="end"
              style="left: {{selectionHandleEndX}}rpx; top: {{selectionHandleEndY}}rpx;"
              catchtouchstart="onSelectionHandleStart"
              catchtouchmove="onSelectionHandleMove"
              catchtouchend="onSelectionHandleEnd"
            ></view>
          </view>
          <!-- 编辑工具栏 -->
          <view wx:if="{{inlineEditing && activeBlockId === item.id && showPasteTip}}" class="paste-tip" catchtouchstart="keepInlineEditing">
            <view class="paste-menu-btn" catchtouchend="pasteClipboardToActiveText">粘贴</view>
            <view class="paste-menu-btn danger" catchtap="deleteSelectedText" catchtouchend="deleteSelectedText">删除</view>
            <view class="paste-menu-btn" catchtouchend="selectCurrentLineText">选择</view>
            <view class="paste-menu-btn" catchtouchend="selectAllActiveText">全选</view>
            <view class="paste-menu-btn strong {{formats.bold ? 'on' : ''}}" catchtouchend="toggleSelectedBold">B</view>
            <view class="paste-menu-btn" catchtouchend="decreaseSelectedFontSize">A-</view>
            <view class="paste-menu-btn strong" catchtouchend="increaseSelectedFontSize">A+</view>
            <view class="paste-menu-btn" catchtouchend="showFontPanelForSelection">字体</view>
            <view class="paste-menu-btn" catchtouchend="showColorPanelForSelection">颜色</view>
          </view>
          <view wx:if="{{inlineEditing && activeBlockId === item.id && selectionHint}}" class="paste-menu-hint">{{selectionHint}}</view>
        </view>
        </view>

        <!-- 调整大小手柄（放在 movable-area 上层，不参与 movable-view 拖拽） -->
        <view
          wx:for="{{design.blocks}}"
          wx:key="id"
          wx:if="{{activeBlockId === item.id && !inlineEditing}}"
          class="resize-handles-overlay"
          data-id="{{item.id}}"
          style="position: absolute; left: {{item.previewX}}rpx; top: {{item.previewY}}rpx; width: {{item.previewWidth}}rpx; height: {{item.previewOverlayHeight}}rpx;"
          catchtap="editBlockText"
          catchtouchstart="onBlockTouchStart"
          catchtouchmove="onBlockMoveByResize"
          catchtouchend="onBlockTouchEnd"
        >
          <view
            class="resize-edit-hotspot"
            data-id="{{item.id}}"
            catchtap="editBlockText"
            catchtouchstart="onBlockTouchStart"
            catchtouchmove="onBlockMoveByResize"
            catchtouchend="onBlockTouchEnd"
          ></view>
          <view class="resize-handle resize-tl" data-id="{{item.id}}" data-edge="tl" catchtouchstart="onResizeStart" catchtouchmove="onResizeMove" catchtouchend="onResizeEnd"></view>
          <view class="resize-handle resize-tm" data-id="{{item.id}}" data-edge="tm" catchtouchstart="onResizeStart" catchtouchmove="onResizeMove" catchtouchend="onResizeEnd"></view>
          <view class="resize-handle resize-tr" data-id="{{item.id}}" data-edge="tr" catchtouchstart="onResizeStart" catchtouchmove="onResizeMove" catchtouchend="onResizeEnd"></view>
          <view class="resize-handle resize-ml" data-id="{{item.id}}" data-edge="ml" catchtouchstart="onResizeStart" catchtouchmove="onResizeMove" catchtouchend="onResizeEnd"></view>
          <view class="resize-handle resize-mr" data-id="{{item.id}}" data-edge="mr" catchtouchstart="onResizeStart" catchtouchmove="onResizeMove" catchtouchend="onResizeEnd"></view>
          <view class="resize-handle resize-bl" data-id="{{item.id}}" data-edge="bl" catchtouchstart="onResizeStart" catchtouchmove="onResizeMove" catchtouchend="onResizeEnd"></view>
          <view class="resize-handle resize-bm" data-id="{{item.id}}" data-edge="bm" catchtouchstart="onResizeStart" catchtouchmove="onResizeMove" catchtouchend="onResizeEnd"></view>
          <view class="resize-handle resize-br" data-id="{{item.id}}" data-edge="br" catchtouchstart="onResizeStart" catchtouchmove="onResizeMove" catchtouchend="onResizeEnd"></view>
        </view>
        <!-- 二维码：可拖拽 + 可缩放 + 透明背景（必须在 movable-area 内） -->
        <!-- useCanvasPreview 时隐藏 image（canvas 已绘制），只用透明热区做交互；非 canvas 模式才显示 image -->
        <movable-view
          wx:if="{{design.qrcode.visible && design.qrcode.src}}"
          class="qr-movable {{qrcodeActive ? 'qr-active' : ''}}"
          x="{{qrPreviewX}}"
          y="{{qrPreviewY}}"
          direction="all"
          inertia="true"
          damping="6"
          friction="4"
          bindchange="onQrMove"
          bindtouchstart="onQrTouchStart"
          catchtap="onQrTap"
        >
          <view class="qr-inner" style="width: {{qrPreviewSize}}rpx; height: {{qrPreviewSize}}rpx;">
            <image wx:if="{{!useCanvasPreview}}" class="qr-preview-img" src="{{design.qrcode.src}}" mode="aspectFit"></image>
            <!-- 选中时显示操作按钮 -->
            <view wx:if="{{qrcodeActive}}" class="qr-actions">
              <view class="qr-action-btn qr-copy" catchtouchend="copyQrCode" catchtap="copyQrCode">⧉</view>
              <view class="qr-action-btn qr-change" catchtouchend="chooseQrCode" catchtap="chooseQrCode">↻</view>
              <view class="qr-action-btn qr-del" catchtouchend="deleteQrCode" catchtap="deleteQrCode">×</view>
            </view>
            <!-- 缩放手柄（右下角） -->
            <view wx:if="{{qrcodeActive}}" class="qr-resize-handle" catchtouchstart="onQrResizeStart" catchtouchmove="onQrResizeMove" catchtouchend="onQrResizeEnd"></view>
          </view>
        </movable-view>
      </movable-area>
    </view>
  </view>

  <view class="editor-card">
    <view class="editor-tabs">
      <view class="editor-tab {{activePanel === 'background' ? 'active' : ''}}" data-panel="background" bindtap="switchPanel">背景</view>
      <view class="editor-tab {{activePanel === 'font' ? 'active' : ''}}" data-panel="font" bindtap="switchPanel">字体</view>
      <view class="editor-tab {{activePanel === 'style' ? 'active' : ''}}" data-panel="style" bindtap="switchPanel">样式</view>
      <view class="editor-tab {{activePanel === 'layout' ? 'active' : ''}}" data-panel="layout" bindtap="switchPanel">排列</view>
      <!-- 撤销 / 重做 -->
      <view class="undo-btn {{!canUndo ? 'disabled' : ''}}" bindtap="undo">
        <text>↩</text>
      </view>
      <view class="redo-btn {{!canRedo ? 'disabled' : ''}}" bindtap="redo">
        <text>↪</text>
      </view>
    </view>

    <view class="panel-body">
      <view wx:if="{{activePanel === 'background'}}">
        <view class="seg-row asset-mini-row">
          <button class="seg" bindtap="addTextBlock">增加文字</button>
          <button class="seg" bindtap="chooseBackground">替换背景</button>
          <button class="seg" bindtap="chooseQrCode">插入二维码</button>
        </view>
        <view class="background-row">
          <button class="bg-btn" data-type="solid" bindtap="setBackgroundType">纯色</button>
          <button class="bg-btn" data-type="gradient" bindtap="setBackgroundType">渐变</button>
          <button class="bg-btn" data-type="blur" bindtap="setBackgroundType">毛玻璃</button>
        </view>
        <view class="size-row">
          <view
            class="size-btn {{activeCanvasSizeId === item.id ? 'active' : ''}}"
            wx:for="{{canvasSizeOptions}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="setCanvasSize"
          >{{item.name}}</view>
          <view
            class="size-btn {{activeCanvasSizeId === 'custom' ? 'active' : ''}} custom-size-btn"
            bindtap="toggleCustomSizeInput"
          >自定义</view>
        </view>
        <!-- 自定义尺寸输入 -->
        <view wx:if="{{showCustomSizeInput}}" class="custom-size-row">
          <view class="custom-size-field">
            <text class="custom-size-label">宽</text>
            <input
              class="custom-size-input"
              type="number"
              placeholder="750"
              value="{{customWidth}}"
              bindinput="onCustomWidthInput"
              confirm-type="next"
            />
          </view>
          <text class="custom-size-times">×</text>
          <view class="custom-size-field">
            <text class="custom-size-label">高</text>
            <input
              class="custom-size-input"
              type="number"
              placeholder="1000"
              value="{{customHeight}}"
              bindinput="onCustomHeightInput"
              confirm-type="done"
              bindconfirm="confirmCustomSize"
            />
          </view>
          <button class="custom-size-confirm" bindtap="confirmCustomSize">确定</button>
        </view>
        <view wx:if="{{showSolidPalette}}" class="bg-palette">
          <view
            wx:for="{{backgroundColors}}"
            wx:key="*this"
            class="bg-swatch {{(design.background.color === item || design.background.glassColor === item || design.background.baseColor === item) ? 'active' : ''}}"
            style="background: {{item}};"
            data-color="{{item}}"
            bindtap="setBackgroundPaletteColor"
          ></view>
        </view>
      </view>

      <view wx:elif="{{activePanel === 'font'}}" bindtouchstart="keepInlineEditing">
        <scroll-view class="font-scroll" scroll-y enhanced show-scrollbar="{{false}}">
          <view class="font-row">
            <button
              class="font-btn {{activeFontId === item.id ? 'active' : ''}}"
              wx:for="{{fonts}}"
              wx:key="id"
              data-id="{{item.id}}"
              catchtouchend="setFontFamily"
            >
              <text class="font-btn-name">{{item.name}}</text>
              <text class="font-btn-mood">{{item.mood || item.scene || ''}}</text>
            </button>
          </view>
        </scroll-view>
      </view>

      <view wx:elif="{{activePanel === 'style'}}" bindtouchstart="keepInlineEditing">
        <view class="style-subtabs">
          <view class="style-subtab {{activeStyleTool === 'text' ? 'active' : ''}}" data-tool="text" bindtap="switchStyleTool">文字</view>
          <view class="style-subtab {{activeStyleTool === 'stroke' ? 'active' : ''}}" data-tool="stroke" bindtap="switchStyleTool">描边</view>
          <view class="style-subtab {{activeStyleTool === 'bg' ? 'active' : ''}}" data-tool="bg" bindtap="switchStyleTool">背景</view>
          <view class="style-subtab {{activeStyleTool === 'shadow' ? 'active' : ''}}" data-tool="shadow" bindtap="switchStyleTool">阴影</view>
        </view>

        <!-- 文字：颜色 + 透明度 -->
        <view wx:if="{{activeStyleTool === 'text'}}">
          <view class="style-control-row">
            <text class="style-control-label">默认颜色</text>
            <view class="color-wheel" catchtap="pickTextColor"></view>
            <view class="current-color" style="background: {{activeTextColor}};" catchtap="pickTextColor"></view>
          </view>
          <view class="style-control-row opacity-row">
            <text class="style-control-label">透明度</text>
            <slider class="slider neon" min="0.2" max="1" step="0.05" value="{{textOpacity}}" bindchanging="changeOpacity" bindchange="changeOpacity" activeColor="#DAA520" backgroundColor="#E8DCCB"></slider>
          </view>
          <view class="swatches color-scroll">
            <view class="swatch {{activeTextColor === item ? 'active' : ''}}" wx:for="{{colors}}" wx:key="*this" style="background: {{item}};" data-name="color" data-value="{{item}}" bindtap="format"></view>
          </view>
        </view>

        <!-- 描边：开关 + 颜色选择 -->
        <view wx:elif="{{activeStyleTool === 'stroke'}}">
          <view class="tool-strip">
            <button class="circle-tool {{activeBlock.stroke ? 'on' : ''}}" catchtap="toggleStroke">
              <image wx:if="{{activeBlock.stroke}}" class="tool-check-icon" src="/images/icons/check-white.svg" mode="aspectFit"></image>
              <text wx:else>✎</text>
            </button>
            <view class="color-wheel" catchtap="pickStrokeColor"></view>
            <view class="thin-line"></view>
            <view class="current-color" style="background: {{activeStrokeColor}};" catchtap="pickStrokeColor"></view>
          </view>
          <text class="panel-label">描边颜色</text>
          <view class="swatches color-scroll">
            <view class="swatch {{activeStrokeColor === item ? 'active' : ''}}" wx:for="{{colors}}" wx:key="*this" style="background: {{item}};" data-value="{{item}}" catchtap="setStrokeColor"></view>
          </view>
        </view>

        <!-- 背景：颜色选择 + 透明度 -->
        <view wx:elif="{{activeStyleTool === 'bg'}}">
          <view class="tool-strip">
            <button class="circle-tool" catchtap="pickBackgroundColor">
              <text>🎨</text>
            </button>
            <view class="color-wheel" catchtap="pickBackgroundColor"></view>
            <view class="thin-line"></view>
            <view class="current-color" style="background: {{activeBackground}};" catchtap="pickBackgroundColor"></view>
          </view>
          <text class="panel-label">背景颜色</text>
          <view class="swatches color-scroll">
            <view class="swatch {{activeBackground === item ? 'active' : ''}}" wx:for="{{bgColors}}" wx:key="*this" style="background: {{item}};" data-value="{{item}}" catchtap="setBgColor"></view>
          </view>
          <view class="control-stack">
            <text class="panel-label">透明度</text>
            <slider class="slider neon" min="0.05" max="1" step="0.05" value="{{bgOpacity || 0.8}}" bindchange="changeBgOpacity" activeColor="#DAA520" backgroundColor="#E8DCCB"></slider>
          </view>
        </view>

        <!-- 阴影：开关 + 颜色选择 + 强度 -->
        <view wx:elif="{{activeStyleTool === 'shadow'}}">
          <view class="tool-strip">
            <button class="circle-tool {{activeBlock.shadow ? 'on' : ''}}" catchtap="toggleShadow" catchtouchend="toggleShadow">
              <image wx:if="{{activeBlock.shadow}}" class="tool-check-icon" src="/images/icons/check-white.svg" mode="aspectFit"></image>
              <text wx:else>◐</text>
            </button>
            <view class="color-wheel" catchtap="pickShadowColor"></view>
            <view class="thin-line"></view>
            <view class="current-color" style="background: {{activeShadowColor}};" catchtap="pickShadowColor"></view>
          </view>
          <text class="panel-label">阴影颜色</text>
          <view class="swatches color-scroll">
            <view class="swatch {{activeShadowColor === item ? 'active' : ''}}" wx:for="{{colors}}" wx:key="*this" style="background: {{item}};" data-value="{{item}}" catchtap="setShadowColor"></view>
          </view>
          <view class="control-stack">
            <text class="panel-label">柔和强度</text>
            <slider class="slider neon" min="0" max="1" step="0.1" value="{{shadowStrength}}" bindchange="changeShadowStrength" activeColor="#DAA520" backgroundColor="#E8DCCB"></slider>
          </view>
        </view>
      </view>

      <view wx:elif="{{activePanel === 'layout'}}" bindtouchstart="keepInlineEditing">
        <view class="layout-format-row">
          <button class="format-key {{formats.bold ? 'on' : ''}}" data-name="bold" bindtap="format">B</button>
          <button class="format-key {{formats.italic ? 'on' : ''}}" data-name="italic" bindtap="format">I</button>
          <button class="format-key {{formats.underline ? 'on' : ''}}" data-name="underline" bindtap="format">U</button>
        </view>
        <!-- 对齐：左 / 中 / 右 + 垂直上 / 中 / 下 -->
        <view class="align-row layout-align-row">
          <button class="align-key {{activeBlock.textDirection !== 'vertical' && activeBlock.align === 'left' ? 'on' : ''}}" data-align="left" bindtap="setAlign">
            <view class="align-icon"><view class="bar"></view><view class="bar"></view><view class="bar short"></view></view>
          </button>
          <button class="align-key {{activeBlock.textDirection !== 'vertical' && activeBlock.align === 'center' ? 'on' : ''}}" data-align="center" bindtap="setAlign">
            <view class="align-icon center"><view class="bar"></view><view class="bar"></view><view class="bar short"></view></view>
          </button>
          <button class="align-key {{activeBlock.textDirection !== 'vertical' && activeBlock.align === 'right' ? 'on' : ''}}" data-align="right" bindtap="setAlign">
            <view class="align-icon right"><view class="bar"></view><view class="bar"></view><view class="bar short"></view></view>
          </button>
          <button class="align-key {{activeBlock.textDirection === 'vertical' && (!activeBlock.verticalAlign || activeBlock.verticalAlign === 'top') ? 'on' : ''}}" data-vertical-align="top" data-valign="top" bindtap="setVerticalAlign">
            <view class="valign-icon top"><view class="v-guide"></view><view class="v-block"></view></view>
          </button>
          <button class="align-key {{activeBlock.textDirection === 'vertical' && activeBlock.verticalAlign === 'middle' ? 'on' : ''}}" data-vertical-align="middle" data-valign="middle" bindtap="setVerticalAlign">
            <view class="valign-icon middle"><view class="v-guide"></view><view class="v-block"></view></view>
          </button>
          <button class="align-key {{activeBlock.textDirection === 'vertical' && activeBlock.verticalAlign === 'bottom' ? 'on' : ''}}" data-vertical-align="bottom" data-valign="bottom" bindtap="setVerticalAlign">
            <view class="valign-icon bottom"><view class="v-guide"></view><view class="v-block"></view></view>
          </button>
        </view>
        <!-- 大小 slider -->
        <view class="layout-slider-row">
          <text class="layout-slider-label">大小</text>
          <slider class="slider neon" min="12" max="160" step="1" value="{{fontSize || 32}}" bindchanging="changeFontSize" bindchange="changeFontSize" activeColor="#DAA520" backgroundColor="#E8DCCB"></slider>
        </view>
        <!-- 行间距 slider -->
        <view class="layout-slider-row">
          <text class="layout-slider-label">行间距</text>
          <slider class="slider neon" min="0.8" max="3.0" step="0.1" value="{{activeBlock.lineHeight || 1.6}}" bindchanging="changeLineHeight" bindchange="changeLineHeight" activeColor="#DAA520" backgroundColor="#E8DCCB"></slider>
        </view>
        <!-- 字间距 slider -->
        <view class="layout-slider-row">
          <text class="layout-slider-label">字间距</text>
          <slider class="slider neon" min="-2" max="10" step="0.5" value="{{activeBlock.letterSpacing || 0}}" bindchanging="changeLetterSpacing" bindchange="changeLetterSpacing" activeColor="#DAA520" backgroundColor="#E8DCCB"></slider>
        </view>
        <view class="block-action-row layout-secondary-actions">
          <button class="block-action" catchtap="copyActiveBlock">复制</button>
          <button class="block-action" catchtap="rotateActiveBlock">旋转</button>
          <button class="block-action danger" catchtap="deleteActiveBlock">删除</button>
        </view>
      </view>

    </view>

    <view class="bottom-actions safe-area-bottom">
      <view class="draft-entry" bindtap="openDraftList">
        <text class="draft-entry-icon">📋</text>
        <text class="draft-entry-text">我的草稿</text>
        <text wx:if="{{draftListCount > 0}}" class="draft-entry-count">{{draftListCount}}</text>
      </view>
      <button class="action ghost" bindtap="saveDraft">存草稿</button>
      <button class="action primary" bindtap="goExport">导出分享图</button>
    </view>
  </view>

  <canvas type="2d" id="exportCanvas" class="hidden-canvas"></canvas>

  <!-- 草稿恢复弹窗 -->
  <view wx:if="{{showDraftModal}}" class="draft-modal-mask" catchtouchend="dismissDraftModal">
    <view class="draft-modal" catchtouchend>
      <view class="draft-modal-header">
        <text class="draft-modal-icon">📝</text>
        <text class="draft-modal-title">发现上次未完成的草稿</text>
      </view>
      <text class="draft-modal-name">"{{latestDraftName}}"</text>
      <view class="draft-modal-actions">
        <button class="draft-modal-btn resume" catchtouchend="resumeLatestDraft">继续编辑</button>
        <button class="draft-modal-btn new" catchtouchend="dismissDraftModal">新建卡片</button>
      </view>
    </view>
  </view>

  <!-- 草稿列表面板 -->
  <view wx:if="{{showDraftList}}" class="draft-list-mask" bindtap="closeDraftList">
    <view class="draft-list-panel" catchtap stopPropagation>
      <view class="draft-list-header">
        <text class="draft-list-title">我的草稿（{{draftListCount}}）</text>
        <view class="draft-list-close" bindtap="closeDraftList">✕</view>
      </view>
      <scroll-view class="draft-list-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view wx:if="{{!draftList.length}}" class="draft-list-empty">
          <text class="draft-list-empty-icon">📭</text>
          <text class="draft-list-empty-text">暂无草稿</text>
          <text class="draft-list-empty-hint">编辑卡片后点「存草稿」即可保存</text>
        </view>
        <view
          wx:for="{{draftList}}"
          wx:key="id"
          class="draft-item"
          data-id="{{item.id}}"
          bindtap="openDraftFromList"
        >
          <view class="draft-item-info">
            <text class="draft-item-name">{{item.name}}</text>
            <text class="draft-item-time">{{item.timeLabel}}</text>
          </view>
          <view class="draft-item-actions">
            <view class="draft-item-delete" data-id="{{item.id}}" catchtap="deleteDraftFromList">删除</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 颜色选择器弹窗 -->
  <view wx:if="{{showColorPicker}}" class="color-picker-mask" catchtap="closeColorPicker">
    <view class="color-picker-popup" catchtap stopPropagation>
      <view class="color-picker-header">
        <text class="color-picker-title">{{colorPickerTitle || '选取颜色'}}</text>
        <view class="color-picker-preview" style="background: {{colorPickerPreview}};"></view>
      </view>
      <view class="color-picker-body">
        <view class="cp-sv-panel" style="background: linear-gradient(to bottom, {{colorPickerHuePure}}, #000000), linear-gradient(to right, #FFF, transparent);" bindtouchstart="onSvPanelTouchStart" bindtouchmove="onSvPanelTouchMove" bindtouchend="onSvPanelTouchEnd">
          <view class="cp-sv-cursor" style="left: {{colorPickerSvX}}px; top: {{colorPickerSvY}}px;"></view>
        </view>
        <view class="cp-hue-bar" bindtouchstart="onHueBarTouchStart" bindtouchmove="onHueBarTouchMove" bindtouchend="onHueBarTouchEnd">
          <view class="cp-hue-cursor" style="top: {{colorPickerHueY}}px;"></view>
        </view>
      </view>
      <view class="color-picker-actions">
        <button class="cp-btn cp-btn-cancel" bindtap="closeColorPicker">取消</button>
        <button class="cp-btn cp-btn-confirm" bindtap="confirmColorPicker">确定</button>
      </view>
    </view>
  </view>
</view>
