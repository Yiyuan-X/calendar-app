<view class="card-page">
  <view class="topbar">
    <view class="title-group">
      <text class="eyebrow">禅意分享卡</text>
      <text class="title">一段文字，生成一张图</text>
    </view>
    <button class="plain-btn" bindtap="createBlank">空白</button>
  </view>

  <view class="tabs">
    <view class="tab {{activeTab === 'templates' ? 'active' : ''}}" data-tab="templates" bindtap="switchTab">模板</view>
    <view class="tab {{activeTab === 'recent' ? 'active' : ''}}" data-tab="recent" bindtap="switchTab">最近编辑</view>
  </view>

  <view wx:if="{{activeTab === 'templates'}}" class="template-grid">
    <view class="template-card" wx:for="{{templates}}" wx:key="id" data-id="{{item.id}}" bindtap="openTemplate">
      <view class="poster-mini {{item.id}}">
        <view class="mini-line main"></view>
        <view class="mini-line"></view>
        <view class="mini-line short"></view>
      </view>
      <view class="template-info">
        <text class="template-name">{{item.name}}</text>
        <text class="template-scene">{{item.scene}}</text>
      </view>
    </view>
  </view>

  <view wx:else class="works-list">
    <view wx:if="{{drafts.length === 0}}" class="empty">
      <text class="empty-title">还没有最近编辑</text>
      <text class="empty-sub">仅保存在本机，最多缓存最近 10 条</text>
    </view>

    <view class="section-title" wx:if="{{drafts.length > 0}}">本地草稿</view>
    <view class="work-item" wx:for="{{drafts}}" wx:key="id" data-id="{{item.id}}" bindtap="openDraft">
      <view class="work-thumb"></view>
      <view class="work-main">
        <text class="work-name">{{item.name}}</text>
        <text class="work-time">{{item.timeText}}</text>
      </view>
      <text class="work-action">继续</text>
      <text class="work-delete" catchtap="deleteDraft" data-id="{{item.id}}">删除</text>
    </view>
  </view>
</view>
