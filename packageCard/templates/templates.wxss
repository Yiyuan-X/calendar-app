.card-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
  background: linear-gradient(180deg, #FAF3EA 0%, #F5F1EA 46%, #F9F7F2 100%);
  color: #352B24;
}

.topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 26rpx;
}

.title-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.eyebrow {
  font-size: 24rpx;
  color: #A77E50;
  letter-spacing: 3rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #3D3028;
  letter-spacing: 0;
}

.plain-btn {
  height: 64rpx;
  min-width: 104rpx;
  padding: 0 22rpx;
  margin: 0;
  border-radius: 12rpx;
  background: #FFFFFF;
  color: #8A6847;
  font-size: 26rpx;
  box-shadow: 0 4rpx 18rpx rgba(109, 79, 48, 0.08);
}

.plain-btn::after {
  border: 0;
}

.tabs {
  display: flex;
  gap: 12rpx;
  padding: 8rpx;
  margin-bottom: 28rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.68);
}

.tab {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  color: #8B7A6D;
  font-size: 28rpx;
  font-weight: 700;
}

.tab.active {
  color: #3E332B;
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(88, 63, 40, 0.08);
}

.template-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22rpx;
}

.template-card {
  overflow: hidden;
  border-radius: 8rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 26rpx rgba(77, 58, 40, 0.08);
}

.poster-mini {
  height: 300rpx;
  padding: 56rpx 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 18rpx;
}

.poster-mini.daily-sign-warm { background: linear-gradient(180deg, #FFF7E8, #F5EEE1); }
.poster-mini.solar-term-paper { background: linear-gradient(135deg, #F8F2E8, #EAF1E7); }
.poster-mini.mindful-quote { background: #F7F1EA; }
.poster-mini.practice-check { background: linear-gradient(180deg, #FFF9EF, #F1E8DB); }

.mini-line {
  height: 12rpx;
  width: 78%;
  border-radius: 2rpx;
  background: rgba(93, 70, 54, 0.26);
}

.mini-line.main {
  height: 18rpx;
  width: 100%;
  background: rgba(93, 70, 54, 0.52);
}

.mini-line.short {
  width: 52%;
}

.template-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 18rpx 20rpx 20rpx;
}

.template-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #3F332B;
}

.template-scene {
  font-size: 23rpx;
  color: #B08A63;
}

.works-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-title {
  margin-top: 16rpx;
  font-size: 27rpx;
  color: #9C7D5E;
  font-weight: 800;
}

.work-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 112rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #FFFFFF;
}

.work-thumb,
.work-image {
  width: 76rpx;
  height: 96rpx;
  border-radius: 6rpx;
  background: linear-gradient(180deg, #FFF6E9, #EDE4D7);
  flex-shrink: 0;
}

.work-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.work-name {
  font-size: 29rpx;
  color: #3F332B;
  font-weight: 800;
}

.work-time {
  font-size: 24rpx;
  color: #A99A8D;
}

.work-action {
  font-size: 25rpx;
  color: #A77E50;
  font-weight: 800;
}

.work-delete {
  height: 54rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  border-radius: 8rpx;
  background: #F8EEE6;
  color: #A65F3D;
  font-size: 24rpx;
  font-weight: 800;
}

.empty {
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #9F8E81;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 800;
}

.empty-sub {
  font-size: 26rpx;
}
