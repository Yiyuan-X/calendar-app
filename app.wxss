.elder-mode .page-subtitle,
.elder-mode .setting-desc,
.elder-mode .event-subtitle,
.elder-mode .fc-desc,
.elder-mode .fc-desc-alt,
.elder-mode .task-target,
.elder-mode .task-total,
.elder-mode .sum-label,
.elder-mode .stat-label,
.elder-mode .overview-label,
.elder-mode .summary-label,
.elder-mode .form-label,
.elder-mode .preview-label,
.elder-mode .detail-label,
.elder-mode .info-label,
.elder-mode .st-label,
.elder-mode .hl-nongli-label,
.elder-mode .r-date,
.elder-mode .p-meta,
.elder-mode .qc-subtitle,
.elder-mode .nav-text {
