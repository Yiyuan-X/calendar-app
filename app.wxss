}

.elder-mode input,
.elder-mode textarea,
.elder-mode .form-input,
.elder-mode .form-textarea,
.elder-mode .search-input,
.elder-mode .c-input,
.elder-mode .c-input-sm,
.elder-mode .ts-input,
.elder-mode .m-input,
