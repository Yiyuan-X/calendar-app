/* 隐私授权弹窗 */
.privacy-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.45);
}

.privacy-dialog {
  width: 100%;
  max-width: 640rpx;
  padding: 36rpx 32rpx 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.18);
}

.privacy-title {
  color: #1D1D1F;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.35;
}

.privacy-content {
  margin-top: 20rpx;
  color: #5F6368;
  font-size: 29rpx;
  line-height: 1.7;
}

.privacy-link {
  color: #007AFF;
  font-weight: 500;
}

.privacy-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 34rpx;
}

.privacy-btn {
  flex: 1;
  height: 84rpx;
  margin: 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1;
}

.privacy-btn::after {
  border: 0;
}

.privacy-btn-cancel {
  color: #5F6368;
  background: #F2F3F5;
}

.privacy-btn-agree {
  color: #FFFFFF;
  background: linear-gradient(135deg, #DAA520, #B8860B);
}
