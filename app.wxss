.elder-mode .summary-title,
.elder-mode .modal-title,
.elder-mode .category-name,
.elder-mode .qc-title-text,
.elder-mode .setting-name,
.elder-mode .promo-title,
.elder-mode .tips-title,
.elder-mode .info-name,
.elder-mode .task-name,
.elder-mode .event-name,
.elder-mode .fc-name,
